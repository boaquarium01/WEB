# 複製此檔為 .env 後填入（勿將 .env 提交到 Git）
# 專案 ID：登入 https://www.sanity.io/manage → 你的專案 → Project ID

# Astro 建置／前端讀取
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Sanity Studio（npm run studio）建議一併設定，與上方相同即可
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Sanity 寫入 token（給 Astro API / 腳本用；Studio 請用瀏覽器登入，勿依賴 config 內嵌 token）
SANITY_STUDIO_TOKEN=
# SANITY_AUTH_TOKEN=
# SANITY_API_TOKEN=
# SANITY_WRITE_TOKEN=

# Studio 拖曳排序／儲存若出現 Request error：到 https://www.sanity.io/manage → 專案 → API → CORS origins
# 新增 http://localhost:3334（npm run studio）與 http://localhost:3333（npm run dev 的 /admin）
# 並在 Studio 右上角完成登入（Editor 以上權限）

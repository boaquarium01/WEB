{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "商品分類",
    "description": "對應 Sanity `category`：name、slug、拖曳排序字串 orderRank、舊欄位 legacySortOrder（sortOrder）"
  },
  "options": {
    "draftAndPublish": false
  },
  "config": {
    "metadatas": {
      "name": {
        "edit": {
          "label": "分類名稱"
        },
        "list": {
          "label": "分類名稱"
        }
      },
      "slug": {
        "edit": {
          "label": "分類代號（網址）",
          "description": "依分類名稱產生，用於前台網址路徑。"
        },
        "list": {
          "label": "代號"
        }
      },
      "orderRank": {
        "edit": {
          "label": "拖曳排序（orderRank）",
          "description": "與 Sanity 可排序列表對齊；請搭配外掛或維運流程調整順序。"
        },
        "list": {
          "label": "排序"
        }
      },
      "legacySortOrder": {
        "edit": {
          "label": "排序（備援，舊資料）",
          "description": "請優先使用拖曳排序；此欄僅相容舊資料或備援。"
        },
        "list": {
          "label": "舊排序"
        }
      },
      "products": {
        "edit": {
          "label": "此分類下的商品"
        },
        "list": {
          "label": "商品"
        }
      }
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "orderRank": {
      "type": "string",
      "maxLength": 256
    },
    "legacySortOrder": {
      "type": "integer",
      "default": 100,
      "min": 0
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "category"
    }
  }
}

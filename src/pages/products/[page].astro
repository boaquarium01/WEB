---
import Layout from '../../layouts/Layout.astro';
import {
  getProductsSortedForCatalog,
  PRODUCTS_PAGE_SIZE,
  getCatalogPageCount,
  type Product
} from '../../data/products';

/** SSR（output: 'server'）下不會執行 getStaticPaths，須依 params 即時查資料（同 product/[slug].astro） */
const pageSize = PRODUCTS_PAGE_SIZE;
const rawPage = String(Astro.params.page ?? '').trim();
const parsed = parseInt(rawPage, 10);

if (!rawPage || !Number.isFinite(parsed) || parsed < 1) {
  return Astro.redirect('/products/1');
}

const sorted = await getProductsSortedForCatalog();
const totalItems = sorted.length;
const totalPages = getCatalogPageCount(totalItems, pageSize);
const currentPage = parsed;

if (currentPage > totalPages) {
  return Astro.redirect(`/products/${totalPages}`);
}

if (String(currentPage) !== rawPage) {
  return Astro.redirect(`/products/${currentPage}`);
}

const items = sorted.slice(
  (currentPage - 1) * pageSize,
  currentPage * pageSize
) as Product[];
const pageTitle =
  currentPage === 1
    ? `全部商品｜水博館水族`
    : `全部商品（第 ${currentPage} 頁）｜水博館水族`;
const pageDesc = `水博館水族熱銷推薦列表，共 ${totalItems} 項，僅供參考，歡迎來店參觀。`;
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="page">
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="back-link" aria-label="返回首頁">
          <i class="fa-solid fa-arrow-left"></i>
        </a>
        <a href="/" class="brand">水博館水族</a>
        <span class="header-spacer" aria-hidden="true"></span>
      </div>
    </header>

    <main class="wrap">
      <nav class="breadcrumb" aria-label="麵包屑">
        <a href="/">首頁</a>
        <span class="sep">/</span>
        <span class="current">全部商品</span>
        {totalPages > 1 && (
          <>
            <span class="sep">/</span>
            <span class="current">第 {currentPage} 頁</span>
          </>
        )}
      </nav>

      <h1 class="page-title">全部商品</h1>
      <p class="page-meta">
        共 <strong>{totalItems}</strong> 項展示（每頁 {PRODUCTS_PAGE_SIZE} 筆，約 {totalPages} 頁）
      </p>
      <p class="page-lead">資料來自 Sanity；點擊卡片可開啟介紹分頁。</p>

      <div class="product-grid">
        {items.map((product) => (
          <article class="product-card">
            <a href={`/product/${product.slug}`} class="product-card-link">
              <div class="product-img-wrap">
                <img src={product.image} alt="" width="600" height="450" loading="lazy" />
              </div>
              <div class="product-body">
                <h2>{product.name}</h2>
                <p class="product-cat">{product.categoryLabel}</p>
                <p class="product-excerpt">{product.excerpt}</p>
              </div>
            </a>
          </article>
        ))}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="商品列表分頁">
          {currentPage > 1 ? (
            <a class="page-btn" href={currentPage === 2 ? '/products/1' : `/products/${currentPage - 1}`} rel="prev">
              上一頁
            </a>
          ) : (
            <span class="page-btn is-disabled">上一頁</span>
          )}

          <ul class="page-numbers">
            {Array.from({ length: totalPages }, (_, i) => {
              const p = i + 1;
              const isActive = p === currentPage;
              const href = p === 1 ? '/products/1' : `/products/${p}`;
              return (
                <li>
                  {isActive ? (
                    <span class="page-num is-current" aria-current="page">{p}</span>
                  ) : (
                    <a class="page-num" href={href}>{p}</a>
                  )}
                </li>
              );
            })}
          </ul>

          {currentPage < totalPages ? (
            <a class="page-btn" href={`/products/${currentPage + 1}`} rel="next">
              下一頁
            </a>
          ) : (
            <span class="page-btn is-disabled">下一頁</span>
          )}
        </nav>
      )}
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p class="footer-copy">© {new Date().getFullYear()} 水博館水族</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: #fff;
    color: #111;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 16px;
    min-height: 56px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: #111;
  }

  .back-link:hover {
    background: #f5f5f5;
  }

  .brand {
    justify-self: center;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    color: #111;
  }

  .header-spacer {
    width: 40px;
  }

  .wrap {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 20px;
  }

  .breadcrumb a {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    margin: 0 6px;
    color: #bbb;
  }

  .page-title {
    margin: 0 0 8px;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 800;
    text-align: center;
  }

  .page-meta {
    margin: 0 0 8px;
    text-align: center;
    font-size: 0.875rem;
    color: #555;
  }

  .page-lead {
    margin: 0 0 28px;
    text-align: center;
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.55;
  }

  .product-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .product-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #eee;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.2s;
  }

  .product-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .product-card-link {
    display: block;
    color: inherit;
  }

  .product-img-wrap {
    aspect-ratio: 4 / 3;
    background: #f5f5f5;
    overflow: hidden;
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-body {
    padding: 12px 10px 14px;
  }

  .pill {
    display: inline-block;
    margin-bottom: 6px;
    padding: 2px 8px;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #666;
    background: #f0f0f0;
    border-radius: 4px;
  }

  .product-body h2 {
    margin: 0 0 4px;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.4;
    color: #111;
  }

  @media (min-width: 640px) {
    .product-body h2 {
      font-size: 1rem;
    }
  }

  .product-cat {
    margin: 0 0 6px;
    font-size: 0.75rem;
    color: #888;
  }

  .product-excerpt {
    margin: 0;
    font-size: 0.75rem;
    color: #666;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .product-excerpt {
      font-size: 0.8125rem;
    }
  }

  .pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid #eee;
  }

  .page-btn {
    padding: 10px 18px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111;
    border: 1px solid #ccc;
    border-radius: 8px;
    background: #fff;
  }

  .page-btn:hover:not(.is-disabled) {
    background: #f5f5f5;
  }

  .page-btn.is-disabled {
    color: #bbb;
    border-color: #e5e5e5;
    cursor: not-allowed;
  }

  .page-numbers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }

  .page-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 10px;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 8px;
    border: 1px solid #ddd;
    color: #111;
    background: #fff;
  }

  a.page-num:hover {
    background: #f5f5f5;
  }

  .page-num.is-current {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  .site-footer {
    border-top: 1px solid #e5e5e5;
    padding: 24px 16px;
  }

  .footer-inner {
    text-align: center;
  }

  .footer-copy {
    margin: 0;
    font-size: 0.8125rem;
    color: #666;
  }
</style>

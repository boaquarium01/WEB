---
import Layout from '../../layouts/Layout.astro';
import ProductGridStagger from '../../components/ProductGridStagger.astro';
import {
  getAllCategories,
  getProductsSortedForCatalog,
  PRODUCTS_PAGE_SIZE,
  getCatalogPageCount,
  type Category,
  type Product
} from '../../data/products';
import { SITE_TITLE_SHORT } from '../../config/site';

function buildCatalogQs(categoryId: string, q: string): string {
  const p = new URLSearchParams();
  if (categoryId) p.set('category', categoryId);
  if (q) p.set('q', q);
  const s = p.toString();
  return s ? `?${s}` : '';
}

function productMatchesQuery(product: Product, q: string): boolean {
  const needle = q.trim().toLowerCase();
  if (!needle) return true;
  const hay = [product.name, product.excerpt, product.categoryLabel ?? '']
    .join(' ')
    .toLowerCase();
  return hay.includes(needle);
}

/** SSR（output: 'server'）下不會執行 getStaticPaths，須依 params 即時查資料（同 product/[slug].astro） */
const pageSize = PRODUCTS_PAGE_SIZE;
const rawPage = String(Astro.params.page ?? '').trim();
const parsed = parseInt(rawPage, 10);

if (!rawPage || !Number.isFinite(parsed) || parsed < 1) {
  return Astro.redirect('/products/1');
}

const rawCategory = Astro.url.searchParams.get('category')?.trim() ?? '';
const rawQ = Astro.url.searchParams.get('q')?.trim() ?? '';

const [sorted, categories] = await Promise.all([
  getProductsSortedForCatalog(),
  getAllCategories()
]);

const categoryIds = new Set((categories as Category[]).map((c) => c.id));
const activeCategory = rawCategory && categoryIds.has(rawCategory) ? rawCategory : '';
const activeQ = rawQ;

if (rawCategory && !activeCategory) {
  return Astro.redirect(`/products/${parsed}${buildCatalogQs('', rawQ)}`);
}

let filtered = sorted as Product[];
if (activeCategory) {
  filtered = filtered.filter((p) => p.category === activeCategory);
}
if (activeQ) {
  filtered = filtered.filter((p) => productMatchesQuery(p, activeQ));
}

const totalItems = filtered.length;
const totalPages = getCatalogPageCount(totalItems, pageSize);
const currentPage = parsed;
const qs = buildCatalogQs(activeCategory, activeQ);

if (currentPage > totalPages) {
  return Astro.redirect(`/products/${totalPages}${qs}`);
}

if (String(currentPage) !== rawPage) {
  return Astro.redirect(`/products/${currentPage}${qs}`);
}

const items = filtered.slice(
  (currentPage - 1) * pageSize,
  currentPage * pageSize
) as Product[];

const staggerItems = items.map((p) => ({
  slug: p.slug,
  name: p.name,
  excerpt: p.excerpt,
  categoryLabel: p.categoryLabel,
  imageUrl: p.image
}));

const activeCategoryLabel = activeCategory
  ? (categories as Category[]).find((c) => c.id === activeCategory)?.label ?? ''
  : '';

const filterHint =
  activeCategory || activeQ
    ? `篩選後 ${totalItems} 項（全站共 ${sorted.length} 項）`
    : `共 ${totalItems} 項展示`;

let pageTitleMain: string;
if (activeCategory && !activeQ && activeCategoryLabel) {
  pageTitleMain =
    currentPage === 1
      ? `${activeCategoryLabel}｜全部商品`
      : `${activeCategoryLabel}｜全部商品（第 ${currentPage} 頁）`;
} else {
  pageTitleMain =
    currentPage === 1 ? '全部商品' : `全部商品（第 ${currentPage} 頁）`;
  if (activeQ.trim()) {
    pageTitleMain = `${pageTitleMain}（搜尋）`;
  }
}
const pageTitle = `${pageTitleMain}｜${SITE_TITLE_SHORT}`;

let pageDesc = `桃園中壢水博館水族商品列表，${filterHint}，每頁 ${PRODUCTS_PAGE_SIZE} 筆，僅供參考，歡迎來店參觀。`;
if (activeCategory && !activeQ && activeCategoryLabel) {
  pageDesc = `桃園中壢水博館水族「${activeCategoryLabel}」分類展示，${filterHint}，歡迎來店參觀。`;
}
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="page">
    <header
      class="site-header sticky top-0 z-[100] border-b border-white/20 bg-white/75 shadow-[0_8px_30px_rgba(0,0,0,0.06)] backdrop-blur-xl backdrop-saturate-150"
    >
      <div class="header-inner">
        <a href="/" class="back-link" aria-label="返回首頁">
          <i class="fa-solid fa-arrow-left"></i>
        </a>
        <a href="/" class="brand">水博館水族</a>
        <span class="header-spacer" aria-hidden="true"></span>
      </div>
    </header>

    <main class="wrap">
      <nav class="breadcrumb" aria-label="麵包屑">
        <a href="/">首頁</a>
        <span class="sep">/</span>
        <a href="/products/1" class="breadcrumb-products">全部商品</a>
        {activeCategoryLabel ? (
          <>
            <span class="sep">/</span>
            <span class="current">{activeCategoryLabel}</span>
          </>
        ) : null}
        {activeQ ? (
          <>
            <span class="sep">/</span>
            <span class="current">關鍵字「{activeQ}」</span>
          </>
        ) : null}
        {totalPages > 1 ? (
          <>
            <span class="sep">/</span>
            <span class="current">第 {currentPage} 頁</span>
          </>
        ) : null}
      </nav>

      <h1 class="page-title">
        {activeCategory && !activeQ && activeCategoryLabel ? activeCategoryLabel : '全部商品'}
      </h1>
      {activeCategory && !activeQ && activeCategoryLabel ? (
        <p class="page-subtitle">
          由「全部商品」依分類篩選 ·{' '}
          <a href="/products/1">瀏覽全部品項</a>
        </p>
      ) : null}
      <p class="page-meta">
        {activeCategory || activeQ ? (
          <>
            篩選結果 <strong>{totalItems}</strong> 項；全站共 <strong>{sorted.length}</strong> 項（每頁{' '}
            {PRODUCTS_PAGE_SIZE} 筆，約 {totalPages} 頁）
          </>
        ) : (
          <>
            共 <strong>{totalItems}</strong> 項展示（每頁 {PRODUCTS_PAGE_SIZE} 筆，約 {totalPages} 頁）
          </>
        )}
      </p>

      <div class="catalog-toolbar" role="search" aria-label="商品篩選與搜尋">
        <form class="catalog-filter-form" method="get" action="/products/1">
          <div class="catalog-field">
            <label class="catalog-label" for="catalog-category">分類</label>
            <div class="catalog-select-wrap">
              <select
                id="catalog-category"
                class="catalog-select"
                name="category"
                onchange="this.form.requestSubmit()"
              >
                <option value="" selected={!activeCategory}>
                  全部分類
                </option>
                {(categories as Category[]).map((c) => (
                  <option value={c.id} selected={c.id === activeCategory}>
                    {c.label}
                  </option>
                ))}
              </select>
              <i class="fa-solid fa-chevron-down catalog-select-chevron" aria-hidden="true"></i>
            </div>
          </div>
          <div class="catalog-field catalog-field--search">
            <label class="catalog-label" for="catalog-q">關鍵字</label>
            <div class="catalog-input-wrap">
              <i class="fa-solid fa-magnifying-glass catalog-input-icon" aria-hidden="true"></i>
              <input
                id="catalog-q"
                class="catalog-input catalog-input--search"
                type="search"
                name="q"
                value={activeQ}
                placeholder="名稱、簡述或分類…"
                enterkeyhint="search"
                autocomplete="off"
              />
            </div>
          </div>
          <div class="catalog-actions">
            <button type="submit" class="catalog-btn catalog-btn--primary">
              <i class="fa-solid fa-magnifying-glass catalog-btn-icon" aria-hidden="true"></i>
              搜尋
            </button>
            {activeCategory || activeQ ? (
              <a class="catalog-btn catalog-btn--ghost" href="/products/1">
                清除條件
              </a>
            ) : null}
          </div>
        </form>
      </div>

      {staggerItems.length === 0 ? (
        <p class="catalog-empty">沒有符合條件的商品，請調整分類或搜尋關鍵字。</p>
      ) : (
        <ProductGridStagger items={staggerItems} />
      )}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="商品列表分頁">
          {currentPage > 1 ? (
            <a
              class="page-btn"
              href={`${currentPage === 2 ? '/products/1' : `/products/${currentPage - 1}`}${qs}`}
              rel="prev"
            >
              上一頁
            </a>
          ) : (
            <span class="page-btn is-disabled">上一頁</span>
          )}

          <ul class="page-numbers">
            {Array.from({ length: totalPages }, (_, i) => {
              const p = i + 1;
              const isActive = p === currentPage;
              const href = `${p === 1 ? '/products/1' : `/products/${p}`}${qs}`;
              return (
                <li>
                  {isActive ? (
                    <span class="page-num is-current" aria-current="page">{p}</span>
                  ) : (
                    <a class="page-num" href={href}>{p}</a>
                  )}
                </li>
              );
            })}
          </ul>

          {currentPage < totalPages ? (
            <a class="page-btn" href={`/products/${currentPage + 1}${qs}`} rel="next">
              下一頁
            </a>
          ) : (
            <span class="page-btn is-disabled">下一頁</span>
          )}
        </nav>
      )}
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p class="footer-copy">© {new Date().getFullYear()} 水博館水族</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: #fff;
    color: #111;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 16px;
    min-height: 56px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: #111;
  }

  .back-link:hover {
    background: #f5f5f5;
  }

  .brand {
    justify-self: center;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    color: #111;
  }

  .header-spacer {
    width: 40px;
  }

  .wrap {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 20px;
  }

  .breadcrumb a,
  a.breadcrumb-products {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .page-subtitle {
    margin: -4px 0 12px;
    text-align: center;
    font-size: 0.875rem;
    color: #666;
  }

  .page-subtitle a {
    color: #111;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    margin: 0 6px;
    color: #bbb;
  }

  .page-title {
    margin: 0 0 8px;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 800;
    text-align: center;
  }

  .page-meta {
    margin: 0 0 28px;
    text-align: center;
    font-size: 0.875rem;
    color: #555;
  }

  .catalog-toolbar {
    margin: 0 0 clamp(1.25rem, 4vw, 1.75rem);
    padding: clamp(14px, 3vw, 20px);
    border-radius: var(--aq-radius, 14px);
    border: 1px solid var(--aq-line, rgba(26, 34, 33, 0.08));
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--aq-sand, #faf8f4) 92%, white) 0%,
      #fff 48%
    );
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.8) inset, 0 8px 28px rgba(26, 34, 33, 0.06);
  }

  .catalog-filter-form {
    display: grid;
    gap: 14px;
    align-items: end;
  }

  @media (min-width: 768px) {
    .catalog-filter-form {
      grid-template-columns: minmax(168px, 220px) minmax(0, 1fr) auto;
      gap: 16px;
    }
  }

  .catalog-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .catalog-field--search {
    min-width: 0;
  }

  .catalog-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--aq-muted, #5c6563);
  }

  .catalog-select-wrap {
    position: relative;
    display: block;
  }

  .catalog-select {
    width: 100%;
    min-height: 44px;
    padding: 10px 40px 10px 12px;
    font-size: 0.9375rem;
    line-height: 1.3;
    border: 1px solid color-mix(in srgb, var(--aq-ink, #1a2221) 14%, transparent);
    border-radius: var(--aq-radius-sm, 10px);
    background: #fff;
    color: var(--aq-ink, #1a2221);
    appearance: none;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .catalog-select:hover {
    border-color: color-mix(in srgb, var(--aq-primary, #156a66) 35%, transparent);
  }

  .catalog-select:focus {
    outline: none;
    border-color: var(--aq-primary, #156a66);
    box-shadow: 0 0 0 3px var(--aq-primary-soft, rgba(21, 106, 102, 0.12));
  }

  .catalog-select-chevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    font-size: 0.65rem;
    color: var(--aq-muted, #5c6563);
    opacity: 0.75;
  }

  .catalog-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .catalog-input-icon {
    position: absolute;
    left: 14px;
    font-size: 0.85rem;
    color: var(--aq-muted, #5c6563);
    opacity: 0.75;
    pointer-events: none;
  }

  .catalog-input {
    width: 100%;
    min-height: 44px;
    padding: 10px 12px;
    font-size: 0.9375rem;
    border: 1px solid color-mix(in srgb, var(--aq-ink, #1a2221) 14%, transparent);
    border-radius: var(--aq-radius-sm, 10px);
    background: #fff;
    color: var(--aq-ink, #1a2221);
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .catalog-input--search {
    padding-left: 40px;
  }

  .catalog-input:hover {
    border-color: color-mix(in srgb, var(--aq-primary, #156a66) 35%, transparent);
  }

  .catalog-input:focus {
    outline: none;
    border-color: var(--aq-primary, #156a66);
    box-shadow: 0 0 0 3px var(--aq-primary-soft, rgba(21, 106, 102, 0.12));
  }

  .catalog-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .catalog-actions {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: flex-end;
      justify-content: flex-end;
    }
  }

  @media (max-width: 767.98px) {
    .catalog-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
    }

    .catalog-actions:not(:has(.catalog-btn--ghost)) {
      grid-template-columns: 1fr;
    }
  }

  .catalog-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 44px;
    padding: 10px 18px;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: var(--aq-radius-sm, 10px);
    border: 1px solid color-mix(in srgb, var(--aq-ink, #1a2221) 18%, transparent);
    background: #fff;
    color: var(--aq-ink, #1a2221);
    cursor: pointer;
    text-decoration: none;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .catalog-btn-icon {
    font-size: 0.85em;
    opacity: 0.9;
  }

  .catalog-btn--primary {
    background: var(--aq-primary, #156a66);
    color: #fff;
    border-color: var(--aq-primary-dark, #0f4d4a);
    box-shadow: 0 1px 2px rgba(21, 106, 102, 0.2);
  }

  .catalog-btn--primary:hover {
    background: var(--aq-primary-dark, #0f4d4a);
    border-color: var(--aq-primary-dark, #0f4d4a);
  }

  .catalog-btn--primary:active {
    transform: scale(0.98);
  }

  @media (prefers-reduced-motion: reduce) {
    .catalog-btn--primary:active {
      transform: none;
    }
  }

  .catalog-btn--ghost {
    border-color: color-mix(in srgb, var(--aq-ink, #1a2221) 12%, transparent);
    background: #fff;
  }

  .catalog-btn--ghost:hover {
    background: var(--aq-sand-2, #f0ebe2);
    border-color: color-mix(in srgb, var(--aq-primary, #156a66) 25%, transparent);
  }

  .catalog-empty {
    margin: 2rem 0;
    text-align: center;
    color: #666;
    font-size: 0.9375rem;
  }

  .product-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .product-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #eee;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.2s;
  }

  .product-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .product-card-link {
    display: block;
    color: inherit;
  }

  .product-img-wrap {
    aspect-ratio: 4 / 3;
    background: #f5f5f5;
    overflow: hidden;
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-body {
    padding: 12px 10px 14px;
  }

  .pill {
    display: inline-block;
    margin-bottom: 6px;
    padding: 2px 8px;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #666;
    background: #f0f0f0;
    border-radius: 4px;
  }

  .product-body h2 {
    margin: 0 0 4px;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.4;
    color: #111;
  }

  @media (min-width: 640px) {
    .product-body h2 {
      font-size: 1rem;
    }
  }

  .product-cat {
    margin: 0 0 6px;
    font-size: 0.75rem;
    color: #888;
  }

  .product-excerpt {
    margin: 0;
    font-size: 0.75rem;
    color: #666;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .product-excerpt {
      font-size: 0.8125rem;
    }
  }

  .pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid #eee;
  }

  .page-btn {
    padding: 10px 18px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111;
    border: 1px solid #ccc;
    border-radius: 8px;
    background: #fff;
  }

  .page-btn:hover:not(.is-disabled) {
    background: #f5f5f5;
  }

  .page-btn.is-disabled {
    color: #bbb;
    border-color: #e5e5e5;
    cursor: not-allowed;
  }

  .page-numbers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }

  .page-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 10px;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 8px;
    border: 1px solid #ddd;
    color: #111;
    background: #fff;
  }

  a.page-num:hover {
    background: #f5f5f5;
  }

  .page-num.is-current {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  .site-footer {
    border-top: 1px solid #e5e5e5;
    padding: 24px 16px;
  }

  .footer-inner {
    text-align: center;
  }

  .footer-copy {
    margin: 0;
    font-size: 0.8125rem;
    color: #666;
  }
</style>

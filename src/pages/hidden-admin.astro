---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE_SHORT } from '../config/site';
---

<Layout title={`管理後台入口｜${SITE_TITLE_SHORT}`} description="管理 Sanity Studio（嵌入版）">
  <div
    style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 24px;"
  >
    <div style="max-width: 720px; width: 100%; border: 1px solid #e5e5e5; border-radius: 12px; padding: 20px;">
      <h1 style="margin: 0 0 12px; font-size: 20px; font-weight: 800;">管理後台</h1>
      <p style="margin: 0 0 16px; color: #444; line-height: 1.7; font-size: 14px;">
        你要做的「商品/分類管理」已改為使用嵌入式 Sanity Studio（包含登入與編輯能力）。
      </p>
      <a
        href="/cms-studio"
        style="display: inline-block; padding: 10px 14px; background: #0b0b0b; color: #fff; border-radius: 10px; font-weight: 700; font-size: 14px;"
      >
        進入 Sanity Studio（/cms-studio）
      </a>
      <p style="margin: 14px 0 0; color: #666; line-height: 1.7; font-size: 12px;">
        夥伴請直接登入 Sanity Studio 進行管理。
      </p>
    </div>
  </div>
</Layout>


---
import Layout from '../layouts/Layout.astro';
import { getAllCategories, getFeaturedProducts } from '../data/products';

const navItems = [
  { name: '首頁', href: '#home' },
  { name: '服務項目', href: '#services' },
  { name: '關於我們', href: '#about' },
  { name: '熱銷推薦', href: '#products' }
];

const featuredProducts = await getFeaturedProducts(7);
const categories = (await getAllCategories()) ?? [];
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

const heroSlides = [
  {
    title: '水博館水族｜淡水魚水族販售',
    subtitle: '每週新增極品特選，嚴選健康且具觀賞價值的淡水魚與水草景觀魚缸。',
    image:
      'https://images.unsplash.com/photo-1522069169874-c58ec4b76be5?auto=format&fit=crop&w=1920&q=80'
  },
  {
    title: '專業、用心、苛求完美',
    subtitle: '以專業經驗與細節管理，提供穩定水質與健康魚況的門市服務。',
    image:
      'https://images.unsplash.com/photo-1520301255226-bf5f144451c1?auto=format&fit=crop&w=1920&q=80'
  },
  {
    title: '專業養殖與完整售後',
    subtitle: '服務涵蓋專業養殖、魚病治療、魚缸保養與水族器材銷售。',
    image:
      'https://images.unsplash.com/photo-1535591273668-578e31182c4f?auto=format&fit=crop&w=1920&q=80'
  }
];

const services = [
  { icon: 'fa-solid fa-fish-fins', title: '專業養殖', desc: '淡水魚健康管理、品系維護與專業飼養建議' },
  { icon: 'fa-solid fa-ruler-combined', title: '客製化魚缸規劃', desc: '依空間、預算與需求提供魚缸尺寸、設備與造景整體規劃' },
  { icon: 'fa-solid fa-seedling', title: '水草景觀魚缸', desc: '客製水草造景、魚缸配置與生態平衡規劃' },
  { icon: 'fa-solid fa-stethoscope', title: '魚病治療', desc: '常見魚病檢測、隔離處理與用藥方向建議' },
  { icon: 'fa-solid fa-water', title: '魚缸保養', desc: '定期換水、水質檢測與過濾系統保養維護' },
  { icon: 'fa-solid fa-screwdriver-wrench', title: '水族器材銷售', desc: '過濾、燈具、打氣與耗材一站式選購建議' }
];
---

<Layout
  title="水博館水族｜官方網站"
  description="淡水魚、觀賞魚、水草、專業養殖、魚病治療、魚缸保養、水族器材銷售"
>
  <div class="site" id="home">
    <header class="site-header">
      <div class="header-inner">
        <button type="button" id="menuButton" class="icon-btn" aria-label="開啟選單">
          <i class="fa-solid fa-bars"></i>
        </button>
        <a href="/" class="brand">水博館水族</a>
        <nav class="nav-desktop" aria-label="主要導覽">
          <ul class="nav-desktop-list">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="nav-item">
                  {item.name}
                </a>
              </li>
            ))}
            <li class="nav-categories">
              <details>
                <summary class="nav-item nav-item--summary">商品</summary>
                <ul class="nav-categories-menu">
                  <li>
                    <a href="/products">全部商品</a>
                  </li>
                  {categories.length > 0 && <li class="nav-categories-menu-divider" aria-hidden="true"></li>}
                  {categories.map((c) => (
                    <li>
                      <a href={`/category/${c.id}`}>{c.label}</a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          </ul>
        </nav>
        <div class="header-end-spacer" aria-hidden="true"></div>
      </div>
    </header>

    <div id="mobileMenuBackdrop" class="drawer-backdrop" aria-hidden="true"></div>
    <aside id="mobileMenu" class="drawer" aria-label="側邊選單">
      <div class="drawer-head">
        <span class="drawer-title">選單</span>
        <button type="button" id="closeMenuButton" class="icon-btn" aria-label="關閉選單">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <nav>
        <ul class="drawer-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="mobile-menu-link drawer-link">
                {item.name}
              </a>
            </li>
          ))}
          <li class="drawer-categories">
            <details>
              <summary>商品</summary>
              <ul class="drawer-category-list">
                <li>
                  <a href="/products" class="mobile-menu-link drawer-link drawer-link--all">全部商品</a>
                </li>
                {categories.map((c) => (
                  <li>
                    <a href={`/category/${c.id}`} class="mobile-menu-link drawer-link">{c.label}</a>
                  </li>
                ))}
              </ul>
            </details>
          </li>
        </ul>
      </nav>
    </aside>

    <main>
      <!-- Hero 輪播：滿版大圖 -->
      <section class="hero" aria-label="主視覺輪播">
        <div class="hero-track">
          {heroSlides.map((slide, idx) => (
            <article
              class:list={['hero-slide', idx === 0 && 'is-active']}
              style={`--bg: url('${slide.image}')`}
            >
              <div class="hero-overlay"></div>
              <div class="hero-content wrap">
                <h1>{slide.title}</h1>
                <p>{slide.subtitle}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="hero-dots" role="tablist" aria-label="輪播指示">
          {heroSlides.map((_, idx) => (
            <button
              type="button"
              class:list={['carousel-dot', idx === 0 && 'is-active']}
              data-index={idx}
              aria-label={`第 ${idx + 1} 張`}
            ></button>
          ))}
        </div>
      </section>

      <!-- 服務項目 -->
      <section id="services" class="section wrap">
        <h2 class="section-title">服務項目</h2>
        <div class="services-grid">
          {services.map((service) => (
            <div class="service-card">
              <i class:list={[service.icon, 'service-icon']}></i>
              <h3>{service.title}</h3>
              <p>{service.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- 關於我們（與聯絡資訊同一區塊） -->
      <section id="about" class="section section--alt" aria-labelledby="about-title">
        <div class="about-unified wrap">
          <div class="about-panel">
            <div class="about-grid about-intro-grid">
              <img
                src="/about-us-store.png"
                alt="水博館水族門市展示空間"
                class="about-img"
                width="1200"
                height="800"
                loading="lazy"
              />
              <div class="about-text">
                <h2 id="about-title" class="section-title">關於我們</h2>
                <p>
                  水博館水族專注於淡水魚水族販售，每週新增極品特選。秉持「專業、用心、苛求完美」的理念，提供專業養殖、水草景觀魚缸規劃、魚病治療、魚缸保養與水族器材銷售，歡迎來店參觀諮詢。
                </p>
              </div>
            </div>
            <div id="contact" class="about-contact-integrated" aria-labelledby="contact-title">
              <div class="contact-layout">
                <div class="contact-card contact-card--integrated">
                  <div class="contact-info">
                    <h3 id="contact-title" class="about-contact-heading">聯絡資訊</h3>
                    <p><strong>地址：</strong>320桃園市中壢區環西路二段69號</p>
                    <p><strong>營業時間：</strong>10:00-21:00</p>
                    <p><strong>電話：</strong><a href="tel:034028721">03-402-8721</a></p>
                    <p>
                      <strong>Facebook：</strong>
                      <a
                        class="facebook-link"
                        href="https://www.facebook.com/Taoyuan.Zhongli.Water.Museum"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="前往水博館水族 Facebook 粉絲專頁（另開新視窗）"
                      >
                        <i class="fa-brands fa-facebook" aria-hidden="true"></i>
                        桃園中壢水博館水族
                      </a>
                    </p>
                  </div>
                  <iframe
                    class="contact-map"
                    title="水博館水族位置地圖"
                    src="https://www.google.com/maps?q=320%E6%A1%83%E5%9C%92%E5%B8%82%E4%B8%AD%E5%A3%A2%E5%8D%80%E7%92%B0%E8%A5%BF%E8%B7%AF%E4%BA%8C%E6%AE%B569%E8%99%9F&output=embed"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                  ></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="products" class="section wrap" aria-labelledby="products-heading">
        <div class="products-section-head">
          <h2 id="products-heading" class="products-page-title">熱銷推薦</h2>
          <a class="products-all-link" href="/products" aria-label="前往全部商品列表">
            全部商品
            <i class="fa-solid fa-chevron-right products-all-icon" aria-hidden="true"></i>
          </a>
        </div>
        {featuredProducts.length === 0 ? (
          <p class="products-empty">
            尚無商品資料。請執行 <code class="inline-code">npm run studio</code> 新增 <strong>product</strong> 文件（可勾選「首頁精選」），再重新建置網站。
          </p>
        ) : (
          <div class="product-grid">
            {featuredProducts.map((product) => (
              <article class="product-card">
                <a href={`/product/${product.slug}`} class="product-card-link">
                  <div class="product-img-wrap">
                    <img src={product.image} alt="" width="600" height="450" loading="lazy" />
                  </div>
                  <div class="product-body">
                    <h3>{product.name}</h3>
                    <p class="product-excerpt">{product.excerpt}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p class="footer-copy">© {new Date().getFullYear()} 水博館水族</p>
      </div>
    </footer>
  </div>

  <script>
    const menuButton = document.getElementById('menuButton');
    const closeMenuButton = document.getElementById('closeMenuButton');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');
    const mobileLinks = document.querySelectorAll('.mobile-menu-link');

    const openMenu = () => {
      mobileMenu?.classList.add('is-open');
      mobileMenuBackdrop?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      mobileMenu?.classList.remove('is-open');
      mobileMenuBackdrop?.classList.remove('is-open');
      document.body.style.overflow = '';
    };

    menuButton?.addEventListener('click', openMenu);
    closeMenuButton?.addEventListener('click', closeMenu);
    mobileMenuBackdrop?.addEventListener('click', closeMenu);
    mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

    const slides = Array.from(document.querySelectorAll('.hero-slide'));
    const dots = Array.from(document.querySelectorAll('.carousel-dot'));
    let currentSlide = 0;

    const setSlide = (index) => {
      const next = ((index % slides.length) + slides.length) % slides.length;
      slides.forEach((slide, i) => slide.classList.toggle('is-active', i === next));
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === next));
      currentSlide = next;
    };

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = Number(dot.getAttribute('data-index') ?? 0);
        setSlide(idx);
      });
    });

    setInterval(() => setSlide(currentSlide + 1), 5000);
  </script>
</Layout>

<style>
  .wrap {
    width: 100%;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 16px;
    padding-right: 16px;
  }

  .site {
    min-height: 100vh;
    background: #ffffff;
    color: #111111;
  }

  /* 頂欄：毛玻璃、層次與對齊 */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.88);
    border-bottom: 1px solid rgba(17, 17, 17, 0.07);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.9) inset,
      0 6px 28px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  @supports not (backdrop-filter: blur(1px)) {
    .site-header {
      background: #ffffff;
    }
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
    min-height: 58px;
  }

  .brand {
    justify-self: center;
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.14em;
    color: #0d0d0d;
    transition: opacity 0.18s ease;
  }

  .brand:hover {
    opacity: 0.72;
  }

  .nav-desktop {
    display: none;
  }

  .nav-desktop-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 4px 2px;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 14px;
    border-radius: 8px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #2a2a2a;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .nav-item:hover {
    background: rgba(17, 17, 17, 0.055);
    color: #111;
    text-decoration: none;
  }

  .nav-item:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }

  .nav-item--summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    gap: 6px;
  }

  .nav-item--summary::-webkit-details-marker {
    display: none;
  }

  .nav-item--summary::after {
    content: '';
    display: inline-block;
    width: 0;
    height: 0;
    margin-left: 2px;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    opacity: 0.45;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .nav-categories details[open] .nav-item--summary::after {
    transform: rotate(180deg);
    opacity: 0.65;
  }

  .nav-categories details[open] .nav-item--summary,
  .nav-item--summary:hover {
    color: #111;
  }

  .nav-categories {
    position: relative;
  }

  .nav-categories details {
    position: relative;
  }

  .nav-categories-menu {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    left: auto;
    transform: none;
    min-width: 200px;
    padding: 6px;
    margin: 0;
    list-style: none;
    display: grid;
    gap: 2px;
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 10px;
    box-shadow:
      0 4px 6px rgba(0, 0, 0, 0.03),
      0 16px 40px rgba(0, 0, 0, 0.1);
    z-index: 120;
  }

  .nav-categories-menu a {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    white-space: nowrap;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #333;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-categories-menu a:hover {
    background: rgba(17, 17, 17, 0.06);
    color: #111;
    text-decoration: none;
  }

  .nav-categories-menu li:first-child a {
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .nav-categories-menu-divider {
    height: 1px;
    margin: 6px 10px;
    padding: 0;
    background: rgba(17, 17, 17, 0.08);
    list-style: none;
  }

  .header-end-spacer {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    padding: 0;
    border: 1px solid transparent;
    background: transparent;
    color: #1a1a1a;
    cursor: pointer;
    border-radius: 10px;
    font-size: 1.125rem;
    transition:
      background 0.18s ease,
      border-color 0.18s ease,
      color 0.18s ease;
  }

  .icon-btn:hover {
    background: rgba(17, 17, 17, 0.05);
    border-color: rgba(17, 17, 17, 0.08);
  }

  .icon-btn:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }

  @media (min-width: 1024px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
    }

    #menuButton {
      display: none;
    }

    .brand {
      justify-self: start;
      grid-column: 1;
    }

    .nav-desktop {
      display: block;
      grid-column: 2;
    }

    .header-end-spacer {
      grid-column: 3;
    }
  }

  /* 側邊欄 */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .drawer-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 210;
    width: min(300px, 88vw);
    height: 100%;
    background: #fafafa;
    border-right: 1px solid rgba(17, 17, 17, 0.08);
    padding: 22px 20px;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
    box-shadow: 8px 0 40px rgba(0, 0, 0, 0.06);
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
  }

  .drawer-title {
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.12em;
    color: #0d0d0d;
  }

  .drawer-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .drawer-link {
    display: block;
    padding: 14px 14px;
    border-radius: 10px;
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #2a2a2a;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 0.18s ease,
      border-color 0.18s ease,
      color 0.18s ease;
  }

  .drawer-link:hover {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(17, 17, 17, 0.06);
    color: #111;
  }

  .drawer-link:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }

  .drawer-link--all {
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #111;
  }

  .drawer-categories details {
    border-top: 1px solid rgba(17, 17, 17, 0.07);
    margin-top: 10px;
    padding-top: 10px;
  }

  .drawer-categories summary {
    list-style: none;
    padding: 14px 14px;
    border-radius: 10px;
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #2a2a2a;
    cursor: pointer;
    transition: background 0.18s ease;
  }

  .drawer-categories summary::-webkit-details-marker {
    display: none;
  }

  .drawer-categories summary::after {
    content: '';
    float: right;
    margin-top: 6px;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #888;
    opacity: 0.7;
  }

  .drawer-categories summary:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .drawer-category-list {
    list-style: none;
    margin: 4px 0 0;
    padding: 0 0 0 8px;
  }

  .drawer-category-list a {
    padding: 11px 14px;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #444;
    border-radius: 8px;
  }

  .drawer-category-list a:hover {
    color: #111;
  }

  @media (min-width: 1024px) {
    .drawer,
    .drawer-backdrop {
      display: none !important;
    }
  }

  /* Hero */
  .hero {
    position: relative;
    width: 100%;
    min-height: 56vh;
    height: min(75vh, 640px);
    overflow: hidden;
    background: #f0f0f0;
  }

  .hero-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.7s ease;

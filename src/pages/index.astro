---
import Layout from '../layouts/Layout.astro';
import ProductGridStagger from '../components/ProductGridStagger.astro';
import HomeHeroSpotlight from '../components/HomeHeroSpotlight.astro';
import { getAllCategories, getFeaturedProducts, getHeroSpotlightProducts } from '../data/products';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config/site';

const navItems = [
  { name: '首頁', href: '#home' },
  { name: '每週新進魚隻🐠', href: '/promo/weekly-new' },
  { name: '預定優惠', href: '/promo/special-offers' },
  { name: '器材促銷', href: '/promo/equipment-sale' },
  { name: '服務項目', href: '#services' },
  { name: '關於我們', href: '#about' }
];

const [heroSpotlightProducts, categories] = await Promise.all([
  getHeroSpotlightProducts(),
  getAllCategories()
]);

const heroSpotlightItems = heroSpotlightProducts.map((p) => ({
  slug: p.slug,
  name: p.name,
  excerpt: p.excerpt,
  categoryLabel: p.categoryLabel,
  imageUrl: p.image
}));

/** 僅顯示 Sanity「首頁熱銷」已勾選之商品；未勾選任何筆時本區塊不顯示。 */
/** 勿因「主打」重複排除：同商品可同時在主打與熱銷，否則同時勾熱銷與主打的商品會從熱銷區被排除而看起來像沒顯示。 */
const featuredProducts = (await getFeaturedProducts(10)).slice(0, 10);

const featuredStaggerItems = featuredProducts.map((p) => ({
  slug: p.slug,
  name: p.name,
  excerpt: p.excerpt,
  imageUrl: p.image
}));
/** 縮短 CDN 快取，避免首頁熱銷／主打與 Sanity 後台改動長時間不一致 */
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=30, stale-while-revalidate=120, must-revalidate'
);

const heroSlides = [
  {
    title: '水博館水族｜淡水魚水族販售',
    subtitle: '每週新增極品特選，嚴選健康且具觀賞價值的淡水魚與水草景觀魚缸。',
    image: '/hero-slide-1.png'
  },
  {
    title: '專業、用心、苛求完美',
    subtitle: '以專業經驗與細節管理，提供穩定水質與健康魚況的門市服務。',
    image: '/hero-slide-2.png'
  },
  {
    title: '專業養殖與完整售後',
    subtitle: '服務涵蓋專業養殖、魚病治療、魚缸保養與水族器材銷售。',
    image: '/hero-slide-3.png'
  },
  {
    title: '中壢在地經營水族專賣',
    subtitle: '營業時間：10:00-21:00',
    image: '/hero-slide-4.png'
  },
  {
    title: '精選好魚與器材，一站購足更安心',
    subtitle: '地址：320桃園市中壢區環西路二段69號',
    image: '/hero-slide-5.png'
  }
];

const services = [
  { icon: 'fa-solid fa-fish-fins', title: '專業養殖', desc: '淡水魚健康管理，提供完整淡水魚專業養殖建議' },
  { icon: 'fa-solid fa-ruler-combined', title: '客製化魚缸規劃', desc: '依空間、預算與需求提供魚缸尺寸、設備與造景整體規劃' },
  { icon: 'fa-solid fa-seedling', title: '多品項烏龜展售', desc: '多種水龜、澤龜、陸龜飼育方式及提供周邊器材設備使用建議' },
  { icon: 'fa-solid fa-stethoscope', title: '水質檢測&魚病治療', desc: '水質改善處理、專業魚病判斷及治療、依預算建議正確用藥' },
  { icon: 'fa-solid fa-water', title: '魚缸定保', desc: '魚隻管理健檢、定期清潔水質改善、過濾系統保養維護' },
  { icon: 'fa-solid fa-screwdriver-wrench', title: '水族、兩棲周邊器材', desc: '預算內商品建議&選購解説器材優缺' }
];
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="site" id="home">
    <header
      id="siteHeader"
      class="site-header sticky top-0 z-[100] border-b border-[var(--aq-line)] bg-[color-mix(in_srgb,var(--aq-sand)_88%,white)] shadow-[0_6px_24px_rgba(26,34,33,0.05)] backdrop-blur-[14px] backdrop-saturate-150 supports-[backdrop-filter]:bg-[color-mix(in_srgb,var(--aq-sand)_78%,white)]"
    >
      <div class="header-inner">
        <button type="button" id="menuButton" class="icon-btn" aria-label="開啟選單">
          <i class="fa-solid fa-bars"></i>
        </button>
        <a href="/" class="brand">水博館水族</a>
        <nav class="nav-desktop" aria-label="主要導覽">
          <ul class="nav-desktop-list">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="nav-item nav-item--mark">
                  {item.name}
                </a>
              </li>
            ))}
            <li class="nav-categories">
              <details>
                <summary class="nav-item nav-item--summary">本店商品</summary>
                <ul class="nav-categories-menu">
                  <li>
                    <a href="/products/1">全部商品</a>
                  </li>
                  {categories.length > 0 && <li class="nav-categories-menu-divider" aria-hidden="true"></li>}
                  {categories.map((c) => (
                    <li>
                      <a href={`/products/1?category=${encodeURIComponent(c.id)}`}>{c.label}</a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          </ul>
        </nav>
        <div class="header-end-spacer" aria-hidden="true"></div>
      </div>
    </header>

    <div id="mobileMenuBackdrop" class="drawer-backdrop" aria-hidden="true"></div>
    <aside id="mobileMenu" class="drawer" aria-label="側邊選單">
      <div class="drawer-head">
        <span class="drawer-title">選單</span>
        <button type="button" id="closeMenuButton" class="icon-btn" aria-label="關閉選單">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <nav>
        <ul class="drawer-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="mobile-menu-link drawer-link">
                {item.name}
              </a>
            </li>
          ))}
          <li class="drawer-categories">
            <details id="drawerProductDetails">
              <summary>本店商品</summary>
              <ul class="drawer-category-list">
                <li>
                  <a href="/products/1" class="mobile-menu-link drawer-link drawer-link--all">全部商品</a>
                </li>
                {categories.map((c) => (
                  <li>
                    <a
                      href={`/products/1?category=${encodeURIComponent(c.id)}`}
                      class="mobile-menu-link drawer-link">{c.label}</a>
                  </li>
                ))}
              </ul>
            </details>
          </li>
        </ul>
      </nav>
    </aside>

    <main>
      <!-- Hero 輪播：滿版大圖 -->
      <section class="hero" aria-label="主視覺輪播">
        <div class="hero-track" data-hero-swipe>
          {heroSlides.map((slide, idx) => (
            <article class:list={['hero-slide', idx === 0 && 'is-active']}>
              <div class="hero-slide-bg" style={`--bg: url('${slide.image}')`}></div>
              <div class="hero-overlay"></div>
              <div class="hero-content wrap">
                <div class="hero-content-inner">
                  <div class="hero-drift-layer">
                    <h1>{slide.title}</h1>
                    <p>{slide.subtitle}</p>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="hero-dots" role="tablist" aria-label="輪播指示">
          {heroSlides.map((_, idx) => (
            <button
              type="button"
              class:list={['carousel-dot', idx === 0 && 'is-active']}
              data-index={idx}
              aria-label={`第 ${idx + 1} 張`}
            ></button>
          ))}
        </div>
      </section>

      <div class="home-below-hero">
      <section id="home-promo-links" class="wrap section -mt-8 pb-8" aria-label="促銷分頁導覽">
        <div class="home-promo-links-grid mx-auto grid max-w-5xl grid-cols-2 gap-3 sm:grid-cols-3">
          <a
            href="/promo/weekly-new"
            class="home-promo-link group col-span-2 rounded-2xl border border-[var(--aq-line)] bg-white/80 p-4 shadow-[0_10px_30px_rgba(26,34,33,0.06)] backdrop-blur transition hover:-translate-y-0.5 hover:shadow-[0_16px_42px_rgba(26,34,33,0.1)] sm:col-span-1"
          >
            <div class="relative flex items-center justify-center">
              <h2 class="text-center text-lg font-extrabold tracking-tight text-[var(--aq-ink)]">每週新進魚隻🐠</h2>
              <i class="fa-solid fa-chevron-right absolute right-0 text-sm text-[var(--aq-muted)] transition group-hover:translate-x-1" aria-hidden="true"></i>
            </div>
          </a>
          <a
            href="/promo/special-offers"
            class="home-promo-link group rounded-2xl border border-[var(--aq-line)] bg-white/80 p-4 shadow-[0_10px_30px_rgba(26,34,33,0.06)] backdrop-blur transition hover:-translate-y-0.5 hover:shadow-[0_16px_42px_rgba(26,34,33,0.1)]"
          >
            <div class="relative flex items-center justify-center">
              <h2 class="text-center text-lg font-extrabold tracking-tight text-[var(--aq-ink)]">預定優惠</h2>
              <i class="fa-solid fa-chevron-right absolute right-0 text-sm text-[var(--aq-muted)] transition group-hover:translate-x-1" aria-hidden="true"></i>
            </div>
          </a>
          <a
            href="/promo/equipment-sale"
            class="home-promo-link group rounded-2xl border border-[var(--aq-line)] bg-white/80 p-4 shadow-[0_10px_30px_rgba(26,34,33,0.06)] backdrop-blur transition hover:-translate-y-0.5 hover:shadow-[0_16px_42px_rgba(26,34,33,0.1)]"
          >
            <div class="relative flex items-center justify-center">
              <h2 class="text-center text-lg font-extrabold tracking-tight text-[var(--aq-ink)]">器材促銷</h2>
              <i class="fa-solid fa-chevron-right absolute right-0 text-sm text-[var(--aq-muted)] transition group-hover:translate-x-1" aria-hidden="true"></i>
            </div>
          </a>
        </div>
      </section>
      {heroSpotlightItems.length > 0 ? (
        <section id="hero-spotlight" class="section home-section wrap" aria-labelledby="hero-spotlight-heading">
          <HomeHeroSpotlight items={heroSpotlightItems} />
        </section>
      ) : null}
      <!-- 服務項目 -->
      <section id="services" class="section home-section wrap">
        <h2 class="home-section-title reveal-on-scroll">服務項目</h2>
        <div class="services-grid reveal-stagger">
          {services.map((service) => (
            <div class="service-card">
              <i class:list={[service.icon, 'service-icon']}></i>
              <h3>{service.title}</h3>
              <p>{service.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- 關於我們（與聯絡資訊同一區塊） -->
      <section id="about" class="section home-section wrap" aria-labelledby="about-title">
        <h2 id="about-title" class="home-section-title reveal-on-scroll">關於我們</h2>
        <div class="about-unified">
          <div class="about-panel">
            <div class="about-grid about-intro-grid">
              <img
                src="/about-us-store.png"
                alt="水博館水族門市展示空間"
                class="about-img reveal-on-scroll reveal-on-scroll--delay-md"
                width="1200"
                height="800"
                loading="lazy"
              />
              <div class="about-text reveal-on-scroll reveal-on-scroll--delay-sm">
                <p>
                  水博館水族專注於淡水魚水族販售，每週新增極品特選。秉持「專業、用心、苛求完美」的理念，提供完整水族系統規劃、魚隻健檢、魚缸保養與水族器材銷售，歡迎來店參觀諮詢。
                </p>
              </div>
            </div>
            <div id="contact" class="about-contact-integrated" aria-labelledby="contact-title">
              <div class="contact-layout">
                <div class="contact-card contact-card--integrated reveal-on-scroll reveal-on-scroll--delay-lg">
                  <div class="contact-info">
                    <h3 id="contact-title" class="about-contact-heading">聯絡資訊</h3>
                    <p class="contact-line">
                      <strong>LINE：</strong>
                      <a
                        class="line-official-link"
                        href="https://lin.ee/nG8kcR2"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="透過 LINE 私訊聯絡（另開新視窗）"
                      >
                        <img
                          src="https://scdn.line-apps.com/n/line_add_friends/btn/zh-Hant.png"
                          alt="加入好友"
                          height="36"
                          border="0"
                        />
                      </a>
                    </p>
                    <p><strong>電話：</strong><a href="tel:034028721">03-402-8721</a></p>
                    <p>
                      <strong>Facebook：</strong>
                      <a
                        class="facebook-link"
                        href="https://www.facebook.com/Taoyuan.Zhongli.Water.Museum"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="前往水博館水族 Facebook 粉絲專頁（另開新視窗）"
                      >
                        <i class="fa-brands fa-facebook" aria-hidden="true"></i>
                        桃園中壢水博館水族
                      </a>
                    </p>
                    <p><strong>地址：</strong>320桃園市中壢區環西路二段69號</p>
                    <p><strong>營業時間：</strong>10:00-21:00</p>
                  </div>
                  <iframe
                    class="contact-map"
                    title="水博館水族位置地圖"
                    src="https://www.google.com/maps?q=320%E6%A1%83%E5%9C%92%E5%B8%82%E4%B8%AD%E5%A3%A2%E5%8D%80%E7%92%B0%E8%A5%BF%E8%B7%AF%E4%BA%8C%E6%AE%B569%E8%99%9F&output=embed"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                  ></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {featuredProducts.length > 0 && (
        <section id="products" class="section home-section wrap" aria-labelledby="products-heading">
          <div class="products-section-head reveal-on-scroll">
            <h2 id="products-heading" class="home-section-title">熱銷推薦</h2>
            <a
              id="homeProductsAllLink"
              class="products-all-link"
              href="/products/1"
              aria-label="前往全部商品列表"
            >
              全部商品
              <i class="fa-solid fa-chevron-right products-all-icon" aria-hidden="true"></i>
            </a>
          </div>
          <ProductGridStagger items={featuredStaggerItems} compact />
        </section>
      )}
      </div>
    </main>

    <footer class="border-t border-[var(--aq-line)] bg-inherit px-4 py-8 sm:px-6">
      <div class="mx-auto flex w-full max-w-5xl flex-col items-center justify-center gap-2 text-center">
        <a
          href="/#about"
          class="text-sm font-semibold text-[var(--aq-primary-dark)] underline decoration-[1.5px] underline-offset-4 transition hover:text-[var(--aq-primary)]"
        >
          聯絡資訊
        </a>
        <p class="m-0 text-xs tracking-[0.02em] text-[var(--aq-muted)]">© 2026 水博館水族</p>
      </div>
    </footer>

    <button
      id="homeScrollTopBtn"
      type="button"
      class="promo-scroll-top-btn"
      aria-label="回到頁面頂部"
      title="回到頂部"
    >
      <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
    </button>
  </div>

  <script>
    import { applyBodyScrollLock, releaseBodyScrollLock } from '../scripts/scrollLock';

    const menuButton = document.getElementById('menuButton');
    const closeMenuButton = document.getElementById('closeMenuButton');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');
    const mobileLinks = document.querySelectorAll('.mobile-menu-link');

    const openMenu = () => {
      mobileMenu?.classList.add('is-open');
      mobileMenuBackdrop?.classList.add('is-open');
      applyBodyScrollLock('siteHeader');
      const drawerDetails = document.getElementById('drawerProductDetails');
      if (drawerDetails instanceof HTMLDetailsElement) {
        drawerDetails.open = true;
      }
    };

    const closeMenu = () => {
      mobileMenu?.classList.remove('is-open');
      mobileMenuBackdrop?.classList.remove('is-open');
      releaseBodyScrollLock('siteHeader');
    };

    menuButton?.addEventListener('click', openMenu);
    closeMenuButton?.addEventListener('click', closeMenu);
    mobileMenuBackdrop?.addEventListener('click', closeMenu);
    mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

    const slides = Array.from(document.querySelectorAll('.hero-slide'));
    const dots = Array.from(document.querySelectorAll('.carousel-dot'));
    let currentSlide = 0;
    let heroExitTimer: ReturnType<typeof setTimeout> | null = null;
    const HERO_CROSSFADE_MS = 780;

    const setSlide = (index) => {
      const next = ((index % slides.length) + slides.length) % slides.length;
      if (next === currentSlide) return;

      const prev = currentSlide;
      const prevEl = slides[prev];

      if (heroExitTimer !== null) {
        window.clearTimeout(heroExitTimer);
        heroExitTimer = null;
      }
      slides.forEach((slide) => slide.classList.remove('hero-slide--exiting'));
      if (prevEl) {
        prevEl.classList.add('hero-slide--exiting');
        prevEl.classList.remove('is-active');
      }

      slides.forEach((slide, i) => slide.classList.toggle('is-active', i === next));
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === next));
      currentSlide = next;

      if (prevEl) {
        heroExitTimer = window.setTimeout(() => {
          prevEl.classList.remove('hero-slide--exiting');
          heroExitTimer = null;
        }, HERO_CROSSFADE_MS);
      }
    };

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = Number(dot.getAttribute('data-index') ?? 0);
        setSlide(idx);
        restartAutoplay();
      });
    });

    const heroTrack = document.querySelector('[data-hero-swipe]');
    if (heroTrack instanceof HTMLElement && slides.length > 1) {
      const SWIPE_MIN_PX = 48;
      const SWIPE_DOMINANCE = 1.15;
      let swipePointerId: number | null = null;
      let swipeStartX = 0;
      let swipeStartY = 0;

      const onSwipePointerUp = (e: PointerEvent) => {
        if (swipePointerId !== e.pointerId) return;
        swipePointerId = null;
        try {
          heroTrack.releasePointerCapture(e.pointerId);
        } catch {
          /* ignore */
        }
        const dx = e.clientX - swipeStartX;
        const dy = e.clientY - swipeStartY;
        if (Math.abs(dx) < SWIPE_MIN_PX) return;
        if (Math.abs(dx) < Math.abs(dy) * SWIPE_DOMINANCE) return;
        if (dx < 0) setSlide(currentSlide + 1);
        else setSlide(currentSlide - 1);
        restartAutoplay();
      };

      heroTrack.addEventListener(
        'pointerdown',
        (e: PointerEvent) => {
          if (e.pointerType === 'mouse' && e.button !== 0) return;
          swipePointerId = e.pointerId;
          swipeStartX = e.clientX;
          swipeStartY = e.clientY;
          heroTrack.setPointerCapture(e.pointerId);
        },
        { passive: true }
      );
      heroTrack.addEventListener('pointerup', onSwipePointerUp, { passive: true });
      heroTrack.addEventListener('pointercancel', onSwipePointerUp, { passive: true });
    }
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const canAutoPlay = slides.length > 1 && !prefersReducedMotion;
    const AUTOPLAY_MS = 5000;
    let autoplayTimer: ReturnType<typeof setInterval> | null = null;
    const stopAutoplay = () => {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    };
    const startAutoplay = () => {
      if (!canAutoPlay || document.hidden) return;
      stopAutoplay();
      autoplayTimer = setInterval(() => setSlide(currentSlide + 1), AUTOPLAY_MS);
    };
    const restartAutoplay = () => {
      stopAutoplay();
      startAutoplay();
    };
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });
    startAutoplay();

    const siteHeader = document.getElementById('siteHeader');
    const heroEl = document.querySelector('.hero');
    let lastPastHero: boolean | null = null;
    let headerScrollQueued = false;
    const syncHeaderScroll = () => {
      if (!siteHeader || !heroEl) return;
      if (headerScrollQueued) return;
      headerScrollQueued = true;
      requestAnimationFrame(() => {
        headerScrollQueued = false;
        const pastHero = window.scrollY > Math.max(0, heroEl.offsetHeight - 48);
        if (pastHero === lastPastHero) return;
        lastPastHero = pastHero;
        siteHeader.classList.toggle('site-header--past-hero', pastHero);
      });
    };
    syncHeaderScroll();
    window.addEventListener('scroll', syncHeaderScroll, { passive: true });
    window.addEventListener('resize', () => {
      lastPastHero = null;
      syncHeaderScroll();
    });

    const scrollTopBtn = document.getElementById('homeScrollTopBtn');
    if (scrollTopBtn instanceof HTMLButtonElement) {
      const toggleScrollTop = () => {
        if (window.scrollY > 240) scrollTopBtn.classList.add('is-visible');
        else scrollTopBtn.classList.remove('is-visible');
      };
      toggleScrollTop();
      window.addEventListener('scroll', toggleScrollTop, { passive: true });
      document.addEventListener('astro:page-load', toggleScrollTop);
      scrollTopBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  </script>
</Layout>

<style>
  .wrap {
    width: 100%;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 16px;
    padding-right: 16px;
  }

  /**
   * 主打／服務：同一內容盒（與 #about 等 .wrap 區塊對齊）
   */
  #hero-spotlight.wrap,
  #services.wrap {
    box-sizing: border-box;
    max-width: 1200px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-left: 16px;
    padding-right: 16px;
  }

  .site {
    min-height: 100vh;
    min-height: 100svh;
    background: var(--aq-sand);
    color: var(--aq-ink);
  }

  /**
   * 錨點捲動：略小於頂欄實高，讓標題更靠近導覽列下緣。
   */
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  #hero-spotlight,
  #services,
  #about,
  #products,
  #contact {
    scroll-margin-top: calc(14px + 58px + 14px + 1px - 24px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
    min-height: 58px;
  }

  .brand {
    justify-self: center;
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.14em;
    color: var(--aq-ink);
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .brand:hover {
    color: var(--aq-primary);
    opacity: 0.92;
  }

  .nav-desktop {
    display: none;
  }

  .nav-desktop-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 4px 2px;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 14px;
    border-radius: var(--aq-radius-sm);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--aq-muted);
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .nav-item:hover {
    background: var(--aq-primary-soft);
    color: var(--aq-ink);
    text-decoration: none;
  }

  .nav-item:focus-visible {
    outline: 2px solid var(--aq-primary);
    outline-offset: 2px;
  }

  .nav-item--mark {
    position: relative;
  }

  .nav-item--mark::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 5px;
    width: 0;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--aq-primary), transparent);
    transform: translateX(-50%);
    transition:
      width 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.2s ease;
    opacity: 0;
    pointer-events: none;
  }

  .nav-item--mark:hover::after,
  .nav-item--mark:focus-visible::after {
    width: 72%;
    opacity: 1;
  }

  .nav-item--summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    gap: 6px;
  }

  .nav-item--summary::-webkit-details-marker {
    display: none;
  }

  .nav-item--summary::after {
    content: '';
    display: inline-block;
    width: 0;
    height: 0;
    margin-left: 2px;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    opacity: 0.45;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .nav-categories details[open] .nav-item--summary::after {
    transform: rotate(180deg);
    opacity: 0.65;
  }

  .nav-categories details[open] .nav-item--summary,
  .nav-item--summary:hover {
    color: var(--aq-ink);
  }

  .nav-categories {
    position: relative;
  }

  .nav-categories details {
    position: relative;
  }

  .nav-categories-menu {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    left: auto;
    transform: none;
    min-width: 200px;
    padding: 6px;
    margin: 0;
    list-style: none;
    display: grid;
    gap: 2px;
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid var(--aq-line);
    border-radius: var(--aq-radius);
    box-shadow:
      0 4px 6px rgba(0, 0, 0, 0.03),
      0 16px 40px rgba(0, 0, 0, 0.1);
    z-index: 120;
  }

  .nav-categories-menu a {
    display: block;
    padding: 10px 12px;
    border-radius: var(--aq-radius-sm);
    white-space: nowrap;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--aq-muted);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-categories-menu a:hover {
    background: var(--aq-primary-soft);
    color: var(--aq-ink);
    text-decoration: none;
  }

  .nav-categories-menu li:first-child a {
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .nav-categories-menu-divider {
    height: 1px;
    margin: 6px 10px;
    padding: 0;
    background: var(--aq-line);
    list-style: none;
  }

  .header-end-spacer {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    padding: 0;
    border: 1px solid transparent;
    background: transparent;
    color: var(--aq-ink);
    cursor: pointer;
    border-radius: var(--aq-radius-sm);
    font-size: 1.125rem;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .icon-btn:hover {
    background: var(--aq-primary-soft);
    border-color: var(--aq-line);
  }

  .icon-btn:focus-visible {
    outline: 2px solid var(--aq-primary);
    outline-offset: 2px;
  }

  @media (min-width: 1024px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
    }

    #menuButton {
      display: none;
    }

    .brand {
      justify-self: start;
      grid-column: 1;
    }

    .nav-desktop {
      display: block;
      grid-column: 2;
    }

    .header-end-spacer {
      grid-column: 3;
    }
  }

  /* 側邊欄 */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .drawer-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 210;
    width: min(300px, 88vw);
    height: 100%;
    background: var(--aq-sand);
    border-right: 1px solid var(--aq-line);
    padding: 22px 20px;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
    box-shadow: 8px 0 40px rgba(0, 0, 0, 0.06);
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--aq-line);
  }

  .drawer-title {
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.12em;
    color: var(--aq-ink);
  }

  .drawer-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .drawer-link {
    position: relative;
    display: block;
    padding: 14px 14px;
    border-radius: var(--aq-radius-sm);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--aq-muted);
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 0.18s ease,
      border-color 0.18s ease,
      color 0.18s ease;
  }

  .drawer-link::after {
    content: '';
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 10px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--aq-primary), transparent);
    opacity: 0;
    transform: scaleX(0.35);
    transition:
      opacity 0.24s ease,
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .drawer-link:hover::after,
  .drawer-link:focus-visible::after {
    opacity: 0.55;
    transform: scaleX(1);
  }

  .drawer-link:hover {
    background: color-mix(in srgb, white 92%, var(--aq-sand));
    border-color: var(--aq-line);
    color: var(--aq-ink);
  }

  .drawer-link:focus-visible {
    outline: 2px solid var(--aq-primary);
    outline-offset: 2px;
  }

  .drawer-link--all {
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--aq-ink);
  }

  .drawer-categories details {
    border-top: 1px solid var(--aq-line);
    margin-top: 10px;
    padding-top: 10px;
  }

  .drawer-categories summary {
    list-style: none;
    padding: 14px 14px;
    border-radius: var(--aq-radius-sm);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--aq-muted);
    cursor: pointer;
    transition: background 0.18s ease;
  }

  .drawer-categories summary::-webkit-details-marker {
    display: none;
  }

  .drawer-categories summary::after {
    content: '';
    float: right;
    margin-top: 6px;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #888;
    opacity: 0.7;
  }

  .drawer-categories summary:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .drawer-category-list {
    list-style: none;
    margin: 4px 0 0;
    padding: 0 0 0 8px;
  }

  .drawer-category-list a {
    padding: 11px 14px;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--aq-muted);
    border-radius: var(--aq-radius-sm);
  }

  .drawer-category-list a:hover {
    color: var(--aq-ink);
  }

  @media (min-width: 1024px) {
    .drawer,
    .drawer-backdrop {
      display: none !important;
    }
  }

  /**
   * 捲過 Hero 後：像「進入展缸區」— 背景略實、毛玻璃略強、邊線與陰影更清楚（情境轉場，非循環裝飾）
   */
  #siteHeader.site-header {
    transition:
      background-color 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      backdrop-filter 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      -webkit-backdrop-filter 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    #siteHeader.site-header {
      transition-duration: 0.01ms;
    }
  }

  #siteHeader.site-header--past-hero {
    background-color: color-mix(in srgb, var(--aq-sand) 66%, white) !important;
    backdrop-filter: blur(22px) saturate(1.68) !important;
    -webkit-backdrop-filter: blur(22px) saturate(1.68) !important;
    box-shadow:
      0 14px 44px rgba(26, 34, 33, 0.11),
      inset 0 1px 0 rgba(255, 255, 255, 0.42);
    border-bottom-color: color-mix(in srgb, var(--aq-primary) 20%, var(--aq-line));
  }

  /* Hero：底色與遮罩最底部一致，換圖時較不會透出「另一塊」青綠帶 */
  .hero {
    position: relative;
    width: 100%;
    min-height: 56vh;
    height: min(75vh, 640px);
    overflow: hidden;
    background-color: #0a2624;
    background-image: linear-gradient(180deg, #0f3a38 0%, #0a2624 100%);
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 56svh;
      height: min(75svh, 640px);
    }
  }

  .hero-track {
    position: relative;
    width: 100%;
    height: 100%;
    isolation: isolate;
    touch-action: pan-y;
    cursor: grab;
  }

  .hero-track:active {
    cursor: grabbing;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.75s ease,
      visibility 0s linear 0.75s;
    pointer-events: none;
  }

  /* 離場張在淡出期間置頂，底下新圖淡入，避免與其他底層張疊色、底部透出 hero 底色 */
  .hero-slide.hero-slide--exiting {
    z-index: 2;
  }

  .hero-slide.is-active {
    opacity: 1;
    z-index: 1;
    visibility: visible;
    transition:
      opacity 0.75s ease,
      visibility 0s linear 0s;
    pointer-events: auto;
  }

  .hero-slide-bg {
    position: absolute;
    inset: -1px;
    background-color: #0a2624;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    transform-origin: center center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(10, 38, 36, 0.88) 0%,
        rgba(14, 58, 55, 0.42) 38%,
        rgba(8, 24, 23, 0.35) 72%,
        rgba(0, 0, 0, 0.2) 100%
      ),
      radial-gradient(ellipse 90% 55% at 50% 100%, rgba(21, 106, 102, 0.35) 0%, transparent 58%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(58px, 11vw, 68px);
    padding-top: 24px;
  }

  .hero-content-inner {
    max-width: 100%;
  }

  .hero-slide .hero-content-inner {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.48s cubic-bezier(0.22, 1, 0.36, 1) 0.08s,
      transform 0.48s cubic-bezier(0.22, 1, 0.36, 1) 0.08s;
  }

  .hero-slide.is-active .hero-content-inner {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide .hero-content-inner {
      transition-duration: 0.15s;
      transition-delay: 0s;
    }
  }

  .hero-content h1 {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #faf8f4;
    line-height: 1.2;
    max-width: 22ch;
    text-shadow: 0 1px 24px rgba(0, 0, 0, 0.25);
  }

  .hero-content p {
    margin: 12px 0 0;
    font-size: 1rem;
    color: rgba(250, 248, 244, 0.9);
    max-width: 36ch;
    line-height: 1.65;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.2);
  }

  /* 貼在圖片可視下緣：促銷區 -mt-8 會疊上 hero 底部，圓點需在其上方才不會被擋 */
  .hero-dots {
    position: absolute;
    bottom: calc(2rem + max(8px, env(safe-area-inset-bottom, 0px) + 4px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    display: flex;
    gap: 8px;
    pointer-events: auto;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(250, 248, 244, 0.35);
    cursor: pointer;
    transition:
      background 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .carousel-dot:hover {
    background: rgba(250, 248, 244, 0.55);
    transform: scale(1.08);
  }

  .carousel-dot.is-active {
    background: #faf8f4;
    box-shadow: 0 0 0 1px rgba(21, 106, 102, 0.45);
    transform: scale(1.12);
  }

  /* 區塊通用：大留白，展缸間走道感 */
  .section {
    padding: clamp(3rem, 6vw, 4.5rem) 0;
  }

  /**
   * 服務／關於／熱銷：淺沙底 + 極淡微粒質感（面積小）
   */
  .home-below-hero {
    position: relative;
    background: linear-gradient(
      180deg,
      var(--aq-sand) 0%,
      color-mix(in srgb, var(--aq-sand-2) 55%, var(--aq-sand)) 48%,
      var(--aq-sand) 100%
    );
  }

  .home-below-hero::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 18%;
    height: min(42%, 320px);
    pointer-events: none;
    opacity: 0.045;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: multiply;
  }

  @keyframes home-promo-enter {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .home-promo-links-grid .home-promo-link {
      animation: home-promo-enter 0.68s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .home-promo-links-grid .home-promo-link:nth-child(1) {
      animation-delay: 0.06s;
    }

    .home-promo-links-grid .home-promo-link:nth-child(2) {
      animation-delay: 0.18s;
    }

    .home-promo-links-grid .home-promo-link:nth-child(3) {
      animation-delay: 0.3s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-promo-links-grid .home-promo-link {
      animation: none;
    }
  }

  .home-below-hero .home-section {
    position: relative;
    z-index: 1;
    padding-bottom: clamp(2.75rem, 5vw, 4rem);
  }

  .home-below-hero .home-section:first-child {
    padding-top: clamp(3rem, 6.5vw, 4.5rem);
  }

  .home-below-hero .home-section:not(:first-child) {
    padding-top: clamp(2.25rem, 5vw, 3.5rem);
    border-top: 1px solid color-mix(in srgb, var(--aq-ink) 6%, transparent);
  }

  /* 服務項目／關於／熱銷／主打：統一標題層級（:global 讓子元件內 h2 也能套用） */
  :global(.home-section-title) {
    margin: 0 auto clamp(1.5rem, 3.8vw, 2rem);
    max-width: 40rem;
    font-size: clamp(1.375rem, 2.8vw, 1.75rem);
    font-weight: 700;
    text-align: center;
    letter-spacing: 0.08em;
    color: var(--aq-ink);
    line-height: 1.25;
  }

  :global(.home-section-title::after) {
    content: '';
    display: block;
    width: 2.25rem;
    height: 2px;
    margin: 0.75rem auto 0;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--aq-primary), transparent);
    opacity: 0.85;
  }

  /* 服務卡網格：僅用 opacity 進場，避免與漂浮動畫的 transform 衝突 */
  .reveal-stagger .service-card {
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .reveal-stagger:not(.is-revealed) .service-card {
      opacity: 0;
      animation: none;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(1) {
      transition-delay: 0ms;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(2) {
      transition-delay: 55ms;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(3) {
      transition-delay: 110ms;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(4) {
      transition-delay: 165ms;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(5) {
      transition-delay: 220ms;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(6) {
      transition-delay: 275ms;
    }

    .reveal-stagger.is-revealed .service-card:nth-child(n + 7) {
      transition-delay: 320ms;
    }
  }

  /* 主打區：與服務網格相同的 opacity 進場（:global：.reveal-stagger 在子元件內） */
  :global(.reveal-stagger .spotlight__hit) {
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.reveal-stagger:not(.is-revealed) .spotlight__hit) {
      opacity: 0;
      animation: none;
    }

    :global(.reveal-stagger.is-revealed .spotlight__solo .spotlight__hit:nth-child(1)),
    :global(.reveal-stagger.is-revealed .spotlight__duo .spotlight__hit:nth-child(1)),
    :global(.reveal-stagger.is-revealed .spotlight__trio > .spotlight__hit--lead) {
      transition-delay: 0ms;
    }

    :global(.reveal-stagger.is-revealed .spotlight__duo .spotlight__hit:nth-child(2)) {
      transition-delay: 55ms;
    }

    :global(.reveal-stagger.is-revealed .spotlight__rail .spotlight__hit:nth-child(1)) {
      transition-delay: 55ms;
    }

    :global(.reveal-stagger.is-revealed .spotlight__rail .spotlight__hit:nth-child(2)) {
      transition-delay: 110ms;

---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SanityImage from '../../components/SanityImage.astro';
import { getAllProductSlugs, getProductBySlug } from '../../data/products';
import { portableTextToHtml, portableBlocksToPlainText } from '../../lib/portableText';
import { isPortableTextBlocks, strapiBlocksToHtml, strapiBlocksToPlainText } from '../../lib/strapi/blocks';
import { SITE_TITLE_SHORT } from '../../config/site';

export const prerender = true;

export async function getStaticPaths() {
  const slugs = await getAllProductSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const slug = String(Astro.params.slug ?? '').trim();
const product = await getProductBySlug(slug);

if (!product) {
  return Astro.redirect('/products');
}

const categoryLabel = product.categoryLabel;
function truncateForMeta(input: string, maxLen: number) {
  const s = String(input ?? '').trim();
  if (!s) return '';
  if (s.length <= maxLen) return s;
  return `${s.slice(0, maxLen).trim()}...`;
}

function absUrl(href: string) {
  const s = String(href ?? '').trim();
  if (!s) return '';
  if (s.startsWith('http://') || s.startsWith('https://')) return s;
  return new URL(s, Astro.url.origin).href;
}

const bodyPlain = isPortableTextBlocks(product.body)
  ? portableBlocksToPlainText(product.body)
  : strapiBlocksToPlainText(product.body as unknown[] | null);

const bodyHtml = isPortableTextBlocks(product.body)
  ? portableTextToHtml(product.body)
  : strapiBlocksToHtml(product.body as unknown[] | null);

const usePortableBody = Boolean(String(bodyHtml ?? '').trim());

// SEO：優先 Studio 的 seo 欄位，否則由短述或富文本純文字產生
const pageTitle = product.seoTitle
  ? `${product.seoTitle}｜${SITE_TITLE_SHORT}`
  : `${product.name}｜${SITE_TITLE_SHORT}`;
const seoDescription =
  product.seoDescription?.trim() ||
  truncateForMeta(product.excerpt || bodyPlain, 160);

const firstImageSrc = String(product.images[0] ?? '').trim();
const ogImageUrl = firstImageSrc ? absUrl(firstImageSrc) : '';

function normalizeKeyword(input: unknown) {
  return String(input ?? '')
    .trim()
    .replace(/\s+/g, ' ')
    .replace(/^,|,$/g, '');
}

function extractAutoKeywords(text: string, limit = 12): string[] {
  const t = String(text ?? '').trim();
  if (!t) return [];

  // 粗略抓取「中文詞組（連續兩字以上）」與英文/數字（兩個以上）
  const tokens = t.match(/[\u4e00-\u9fff]{2,}|[a-zA-Z0-9]{2,}/g) ?? [];
  if (tokens.length === 0) return [];

  const freq = new Map<string, number>();
  const firstIndex = new Map<string, number>();

  tokens.forEach((tok, i) => {
    // 避免抓到很長的純數字（例如時間戳/ID），讓 keywords 更像「關鍵字」
    if (/^\d+$/.test(tok) && tok.length > 6) return;

    const k = tok.toLowerCase();
    freq.set(k, (freq.get(k) ?? 0) + 1);
    if (!firstIndex.has(k)) firstIndex.set(k, i);
  });

  return [...freq.keys()]
    .sort((a, b) => {
      const fa = freq.get(a) ?? 0;
      const fb = freq.get(b) ?? 0;
      if (fa !== fb) return fb - fa;
      return (firstIndex.get(a) ?? 0) - (firstIndex.get(b) ?? 0);
    })
    .slice(0, limit);
}

// 1) 手動關鍵字：Studio 的 seoKeywords（tags）
// 2) 自動關鍵字：由名稱+內文抓取
// 排序要求：手動在前，接著才是自動抓到的（去重後補上）
const manualKeywords = (product.seoKeywords ?? [])
  .flatMap((k) => String(k).split(/[,，、]/g))
  .map(normalizeKeyword)
  .filter(Boolean);

const manualLower = new Set(manualKeywords.map((k) => k.toLowerCase()));
const autoKeywords = extractAutoKeywords(`${product.name} ${bodyPlain}`);

const finalKeywords: string[] = [...manualKeywords];
for (const k of autoKeywords) {
  const lk = k.toLowerCase();
  if (manualLower.has(lk)) continue;
  if (finalKeywords.some((x) => x.toLowerCase() === lk)) continue;
  finalKeywords.push(k);
  manualLower.add(lk);
}

const keywordsMeta = finalKeywords.join(', ');
Astro.response.headers.set('Cache-Control', 'public, s-maxage=120, stale-while-revalidate=600');
---

<Layout
  title={pageTitle}
  description={seoDescription}
  keywords={keywordsMeta}
  ogImage={ogImageUrl || undefined}
  ogType="article"
>
  <div class="page">
    <header
      class="site-header sticky top-0 z-[100] border-b border-white/20 bg-white/75 shadow-[0_8px_30px_rgba(0,0,0,0.06)] backdrop-blur-xl backdrop-saturate-150"
    >
      <div class="header-inner">
        <a href="/" class="back-link" aria-label="返回首頁">
          <i class="fa-solid fa-arrow-left"></i>
        </a>
        <a href="/" class="brand">水博館水族</a>
        <span class="header-spacer" aria-hidden="true"></span>
      </div>
    </header>

    <main class="wrap">
      <Breadcrumbs
        class="mb-6 reveal-on-scroll"
        items={[
          { label: '首頁', href: '/' },
          { label: '全部商品', href: '/products/1' },
          {
            label: categoryLabel,
            href: `/products/1?category=${encodeURIComponent(product.category)}`
          },
          { label: product.name }
        ]}
      />

      <article class="detail reveal-on-scroll reveal-on-scroll--delay-sm">
        <div class="detail-media">
          {product.images.length > 0 ? (
            <div
              class="product-carousel"
              data-product-carousel
              data-product-lightbox-group
              aria-roledescription="輪播"
              aria-label={`${product.name} 商品圖片`}
            >
              <div class="carousel-main">
                <div class="carousel-viewport" tabindex="0">
                  <div class="carousel-track">
                    {product.images.map((src, i) => {
                      const ref = product.carouselImageRefs?.[i] ?? null;
                      const alt = i === 0 ? product.name : `${product.name}（第 ${i + 1} 張）`;
                      return (
                        <div class="carousel-slide" aria-hidden={i === 0 ? 'false' : 'true'}>
                          <div class="carousel-slide__stack">
                            <img
                              class="carousel-slide__blur"
                              src={src}
                              alt=""
                              aria-hidden="true"
                              width="1000"
                              height="750"
                              loading={i === 0 ? 'eager' : 'lazy'}
                              decoding="async"
                            />
                            {ref ? (
                              <SanityImage
                                source={ref}
                                alt={alt}
                                sizes="(max-width: 900px) 100vw, 50vw"
                                priority={i === 0}
                                width={1200}
                                height={900}
                                omitLqipBackground={true}
                                class="carousel-slide__contain !bg-transparent"
                              />
                            ) : (
                              <div class="carousel-slide__contain">
                                <img
                                  class="carousel-slide__img--front carousel-slide__img--fill"
                                  src={src}
                                  alt={alt}
                                  width="1000"
                                  height="750"
                                  loading={i === 0 ? 'eager' : 'lazy'}
                                  decoding="async"
                                />
                              </div>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
                {product.images.length > 1 && (
                  <>
                    <button type="button" class="carousel-nav carousel-prev" aria-label="上一張圖片">
                      <i class="fa-solid fa-chevron-left" aria-hidden="true" />
                    </button>
                    <button type="button" class="carousel-nav carousel-next" aria-label="下一張圖片">
                      <i class="fa-solid fa-chevron-right" aria-hidden="true" />
                    </button>
                    <div class="carousel-dots" role="tablist" aria-label="選擇圖片">
                      {product.images.map((_, i) => (
                        <button
                          type="button"
                          class:list={['carousel-dot', { 'is-active': i === 0 }]}
                          aria-label={`第 ${i + 1} 張，共 ${product.images.length} 張`}
                          aria-selected={i === 0 ? 'true' : 'false'}
                          role="tab"
                        />
                      ))}
                    </div>
                  </>
                )}
              </div>
            </div>
          ) : (
            <div
              class="product-detail-no-image"
              role="img"
              aria-label={`${product.name} 尚無照片`}
            >
              <i class="fa-solid fa-fish-fins" aria-hidden="true"></i>
              <span class="product-detail-no-image-title">照片準備中</span>
              <span class="product-detail-no-image-hint">上架後可於後台補上圖片</span>
            </div>
          )}
        </div>
        <div class="detail-body">
          <p class="category-pill">{categoryLabel}</p>
          <h1>{product.name}</h1>
          <p class="excerpt">{product.excerpt}</p>
          {usePortableBody ? (
            <div
              class="prose prose-slate max-w-none prose-headings:font-bold prose-p:leading-relaxed prose-li:leading-relaxed"
              set:html={bodyHtml}
            />
          ) : (
            <p class="product-body-empty">尚未填寫商品介紹。</p>
          )}
          <p class="note">網站僅供參考請以現場為準，歡迎來店參觀選購。</p>
          <a href="/products/1" class="btn-secondary">返回全部商品</a>
        </div>
      </article>
    </main>

    <footer class="border-t border-[var(--aq-line)] bg-inherit px-4 py-8 sm:px-6">
      <div class="mx-auto flex w-full max-w-5xl flex-col items-center justify-center gap-2 text-center">
        <a
          href="/#about"
          class="text-sm font-semibold text-[var(--aq-primary-dark)] underline decoration-[1.5px] underline-offset-4 transition hover:text-[var(--aq-primary)]"
        >
          聯絡資訊
        </a>
        <p class="m-0 text-xs tracking-[0.02em] text-[var(--aq-muted)]">© 2026 水博館水族</p>
      </div>
    </footer>

    <div
      id="productImageLightbox"
      class="product-lightbox"
      hidden
      role="dialog"
      aria-modal="true"
      aria-label="放大檢視商品圖"
    >
      <button
        type="button"
        id="productLightboxBackdrop"
        class="product-lightbox__backdrop"
        aria-label="關閉放大圖"
      ></button>
      <div class="product-lightbox__shell">
        <img id="productLightboxImg" class="product-lightbox__img" alt="" decoding="async" />
      </div>
    </div>
  </div>
</Layout>

<style>
  /* 使用 svh 避免 100dvh 隨網址列收合改變高度，導致整頁重排與捲動位置跳動（手機明顯） */
  .page {
    min-height: 100vh;
    min-height: 100svh;
    background: #fff;
    color: #111;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 16px;
    min-height: 56px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: #111;
    transition: transform 0.2s ease, background 0.15s ease, box-shadow 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .back-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(26, 34, 33, 0.06);
    }
  }

  .back-link:hover {
    background: #f5f5f5;
  }

  .brand {
    justify-self: center;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    color: #111;
  }

  .header-spacer {
    width: 40px;
  }

  .wrap {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .detail {
    display: grid;
    gap: 28px;
  }

  @media (min-width: 900px) {
    .detail {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .detail-media {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #eee;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    background: #f5f5f5;
  }

  .product-detail-no-image {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 200px;
    aspect-ratio: 4 / 3;
    padding: 1.5rem 1.25rem;
    text-align: center;
    background: linear-gradient(145deg, #ecfeff 0%, #f1f5f9 50%, #e8f4f8 100%);
    color: #64748b;
  }

  .product-detail-no-image .fa-fish-fins {
    font-size: 2.25rem;
    color: rgba(14, 116, 144, 0.38);
  }

  .product-detail-no-image-title {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #475569;
  }

  .product-detail-no-image-hint {
    font-size: 0.75rem;
    color: #94a3b8;
    max-width: 15rem;
    line-height: 1.45;
  }

  .category-pill {
    display: inline-block;
    margin: 0 0 12px;
    padding: 4px 12px;
    font-size: 0.8125rem;
    font-weight: 600;
    background: #f0f0f0;
    border-radius: 999px;
    color: #333;
  }

  .detail-body h1 {
    margin: 0 0 12px;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.25;
  }

  .excerpt {
    margin: 0 0 20px;
    font-size: 1rem;
    color: #444;
    line-height: 1.6;
  }

  .product-body-empty {
    margin: 0 0 14px;
    padding: 16px 18px;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #64748b;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
  }

  .prose p {
    margin: 0 0 14px;
    line-height: 1.85;
    color: #333;
    font-size: 0.9375rem;
  }

  .note {
    margin: 24px 0 20px;
    padding: 14px 16px;
    background: #fafafa;
    border: 1px solid #eee;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
  }

  .btn-secondary {
    display: inline-block;
    padding: 10px 20px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111;
    border: 1px solid #ccc;
    border-radius: 8px;
    background: #fff;
  }

  .btn-secondary:hover {
    background: #f5f5f5;
  }

  .product-carousel {
    position: relative;
  }

  .carousel-main {
    position: relative;
  }

  .carousel-viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    /* 勿用 CSS smooth：iOS 上易與手勢／snap 衝突；改由 JS 在按鈕換頁時再決定 behavior */
    scroll-behavior: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    touch-action: pan-x pinch-zoom;
  }

  .carousel-viewport::-webkit-scrollbar {
    display: none;
  }

  .carousel-track {
    display: flex;
  }

  .carousel-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e8e8;
  }

  .carousel-slide__stack {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  /**
   * 底層：同圖放大裁切 + 模糊，填滿留白區
   * 前景：完整顯示、不裁切（object-contain）
   */
  .carousel-slide__blur {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    transform: scale(1.14);
    filter: blur(26px);
    opacity: 0.9;
    pointer-events: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-slide__blur {
      filter: none;
      transform: none;
      opacity: 0.45;
    }
  }

  /**
   * 前景圖：填滿輪播格 + object-contain 盡量大（完整顯示、不裁切）
   * 使用 .carousel-slide__img--fill + 強制覆寫全站 img{max-width;height:auto}，避免 flex+max% 變成中間小圖
   */
  .product-carousel .carousel-slide__stack :global(.carousel-slide__contain) {
    position: absolute;
    inset: 0;
    z-index: 1;
    min-height: 0;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    background: transparent;
  }

  /* SanityImage 的 img 在子元件內，須 :global 才會套上 */
  .product-carousel .carousel-slide__stack :global(.carousel-slide__contain > img.carousel-slide__img--fill) {
    position: absolute !important;
    inset: 0 !important;
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    max-height: none !important;
    margin: 0 !important;
    padding: 0 !important;
    object-fit: contain !important;
    object-position: center center !important;
  }

  .carousel-nav {
    position: absolute;
    top: 50%;
    z-index: 3;
    transform: translateY(-50%);
    width: 32px;
    height: 32px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #333;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .carousel-main:hover .carousel-nav,
  .carousel-main:focus-within .carousel-nav,
  .carousel-main.carousel-show-nav .carousel-nav {
    opacity: 1;
    pointer-events: auto;
  }

  .carousel-nav:hover {
    color: #111;
    background: #fff;
    border-color: rgba(0, 0, 0, 0.12);
  }

  .carousel-nav:focus-visible {
    opacity: 1;
    pointer-events: auto;
    outline: 2px solid #111;
    outline-offset: 2px;
  }

  .carousel-prev {
    left: 10px;
  }

  .carousel-next {
    right: 10px;
  }

  @media (min-width: 480px) {
    .carousel-nav {
      width: 36px;
      height: 36px;
      font-size: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-nav {
      transition: none;
    }
  }

  .carousel-dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 12px;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
    pointer-events: none;
  }

  .carousel-dots .carousel-dot {
    pointer-events: auto;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.12);
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .carousel-dot.is-active {
    background: #111;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.9);
    transform: scale(1.2);
  }

  .carousel-dot:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .product-carousel .carousel-slide__stack :global(.carousel-slide__contain img) {
    cursor: zoom-in;
    -webkit-tap-highlight-color: transparent;
  }

  .product-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: max(12px, env(safe-area-inset-top)) max(12px, env(safe-area-inset-right))
      max(12px, env(safe-area-inset-bottom)) max(12px, env(safe-area-inset-left));
    box-sizing: border-box;
  }

  .product-lightbox[hidden] {
    display: none !important;
  }

  .product-lightbox:not([hidden]) {
    animation: product-lb-fade-in 0.22s ease-out;
  }

  @keyframes product-lb-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .product-lightbox__backdrop {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(0, 0, 0, 0.78);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .product-lightbox__shell {
    position: relative;
    z-index: 1;
    max-width: min(96vw, 1400px);
    max-height: min(92vh, 900px);
    margin: 0;
    pointer-events: none;
  }

  .product-lightbox__img {
    display: block;
    max-width: 100%;
    max-height: min(92vh, 900px);
    width: auto;
    height: auto;
    object-fit: contain;
    pointer-events: auto;
    border-radius: 4px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.45);
  }

  @media (prefers-reduced-motion: reduce) {
    .product-lightbox:not([hidden]) {
      animation: none;
    }
  }
</style>

<script>
  import { applyBodyScrollLock, releaseBodyScrollLock } from '../../scripts/scrollLock';

  function setupProductCarousels() {
    document.querySelectorAll('[data-product-carousel]').forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.carouselInit === '1') return;
      root.dataset.carouselInit = '1';

      const main = root.querySelector('.carousel-main');
      const viewport = root.querySelector('.carousel-viewport');
      const slides = root.querySelectorAll('.carousel-slide');
      const prevBtn = root.querySelector('.carousel-prev');
      const nextBtn = root.querySelector('.carousel-next');
      const dots = root.querySelectorAll('.carousel-dot');

      if (
        !(main instanceof HTMLElement) ||
        !(viewport instanceof HTMLElement) ||
        slides.length < 2
      ) {
        return;
      }

      const TOUCH_NAV_MS = 4200;
      let hideNavTimer = 0;
      function revealNavForTouch() {
        main.classList.add('carousel-show-nav');
        window.clearTimeout(hideNavTimer);
        hideNavTimer = window.setTimeout(() => {
          main.classList.remove('carousel-show-nav');
        }, TOUCH_NAV_MS);
      }

      main.addEventListener(
        'pointerdown',
        (e) => {
          if (e.pointerType === 'touch') revealNavForTouch();
        },
        { passive: true }
      );

      const reduceMotion =
        typeof window.matchMedia === 'function' &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const AUTOPLAY_MS = 5500;
      let autoplayTimer = 0;
      let scrollProgrammatic = false;
      /** 輪播是否在視窗內；離開視窗時必須停 autoplay，否則背景水平捲動與垂直捲動在 iOS 上會互搶造成顫動 */
      let carouselInView = true;

      let index = 0;
      let ticking = false;

      const slideWidth = () => viewport.clientWidth;

      function syncDots(active) {
        dots.forEach((dot, j) => {
          dot.classList.toggle('is-active', j === active);
          dot.setAttribute('aria-selected', String(j === active));
        });
        slides.forEach((slide, j) => {
          slide.setAttribute('aria-hidden', String(j !== active));
        });
      }

      function clearAutoplay() {
        if (autoplayTimer) {
          window.clearInterval(autoplayTimer);
          autoplayTimer = 0;
        }
      }

      function scheduleAutoplay() {
        if (reduceMotion || slides.length < 2 || !carouselInView) return;
        clearAutoplay();
        autoplayTimer = window.setInterval(() => {
          goTo(index + 1, { behavior: 'auto' });
        }, AUTOPLAY_MS);
      }

      function onUserNavigation() {
        clearAutoplay();
        scheduleAutoplay();
      }

      function goTo(i, opts?: { behavior?: ScrollBehavior }) {
        const n = slides.length;
        index = ((i % n) + n) % n;
        scrollProgrammatic = true;
        const behavior: ScrollBehavior =
          opts?.behavior ?? (reduceMotion ? 'auto' : 'smooth');
        viewport.scrollTo({
          left: index * slideWidth(),
          behavior
        });
        syncDots(index);
        window.setTimeout(() => {
          scrollProgrammatic = false;
        }, behavior === 'smooth' ? 1000 : 80);
      }

      const extendTouchNav = (el) => {
        el?.addEventListener(
          'pointerdown',
          (e) => {
            if (e.pointerType === 'touch') revealNavForTouch();
          },
          { passive: true }
        );
      };

      prevBtn?.addEventListener('click', () => {
        goTo(index - 1);
        onUserNavigation();
      });
      nextBtn?.addEventListener('click', () => {
        goTo(index + 1);
        onUserNavigation();
      });
      extendTouchNav(prevBtn);
      extendTouchNav(nextBtn);
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          goTo(i);
          onUserNavigation();
        });
        extendTouchNav(dot);
      });

      viewport.addEventListener(
        'pointerdown',
        () => {
          onUserNavigation();
        },
        { passive: true }
      );

      viewport.addEventListener('scroll', () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          const w = Math.max(1, slideWidth());
          const i = Math.round(viewport.scrollLeft / w);
          if (i >= 0 && i < slides.length && i !== index) {
            index = i;
            syncDots(index);
          }
        });
      }, { passive: true });

      main.addEventListener('mouseenter', clearAutoplay);
      main.addEventListener('mouseleave', scheduleAutoplay);

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) clearAutoplay();
        else if (carouselInView) scheduleAutoplay();
      });

      if (typeof IntersectionObserver !== 'undefined') {
        const vio = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              carouselInView = e.isIntersecting;
              if (carouselInView) scheduleAutoplay();
              else clearAutoplay();
            }
          },
          { root: null, threshold: 0.08 }
        );
        vio.observe(root);
      }

      let resizeTimer;
      let lastInnerWidth = window.innerWidth;
      window.addEventListener('resize', () => {
        const w = window.innerWidth;
        if (w === lastInnerWidth) return;
        lastInnerWidth = w;
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          scrollProgrammatic = true;
          viewport.scrollTo({ left: index * slideWidth(), behavior: 'auto' });
          window.setTimeout(() => {
            scrollProgrammatic = false;
          }, 100);
        }, 120);
      });

      scheduleAutoplay();
    });
  }

  setupProductCarousels();

  function setupProductImageLightbox() {
    const lightbox = document.getElementById('productImageLightbox');
    const backdrop = document.getElementById('productLightboxBackdrop');
    const lbImg = document.getElementById('productLightboxImg');
    if (!lightbox || !backdrop || !lbImg) return;

    let open = false;

    function closeLightbox() {
      if (!open) return;
      open = false;
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      releaseBodyScrollLock();
      lbImg.removeAttribute('src');
      lbImg.alt = '';
    }

    function openLightboxFromImg(img) {
      if (!(img instanceof HTMLImageElement)) return;
      const src = img.currentSrc || img.src;
      if (!src) return;
      lbImg.alt = img.alt || '';
      lbImg.src = src;
      open = true;
      lightbox.hidden = false;
      lightbox.setAttribute('aria-hidden', 'false');
      applyBodyScrollLock();
      backdrop.focus({ preventScroll: true });
    }

    function onCarouselClick(e) {
      const t = e.target;
      if (!(t instanceof Element)) return;
      if (t.closest('.carousel-nav') || t.closest('.carousel-dot')) return;

      const slide = t.closest('.carousel-slide');
      const img = slide?.querySelector('.carousel-slide__contain img');
      if (!img || !(img instanceof HTMLImageElement)) return;

      openLightboxFromImg(img);
    }

    document.querySelectorAll('[data-product-lightbox-group]:not([data-lightbox-bound])').forEach((root) => {
      root.setAttribute('data-lightbox-bound', '1');
      root.addEventListener('click', onCarouselClick);
    });

    if (lightbox.dataset.lightboxGlobalBound === '1') return;
    lightbox.dataset.lightboxGlobalBound = '1';

    backdrop.addEventListener('click', () => {
      closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) {
        e.preventDefault();
        closeLightbox();
      }
    });
  }

  setupProductImageLightbox();
  document.addEventListener('astro:page-load', setupProductImageLightbox);
</script>

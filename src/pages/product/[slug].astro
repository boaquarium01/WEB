---
import Layout from '../../layouts/Layout.astro';
import { getAllProducts, getCategoryLabel, type Product } from '../../data/products';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const categoryLabel = getCategoryLabel(product.category);
const pageTitle = `${product.name}｜水博館水族`;
---

<Layout title={pageTitle} description={product.excerpt}>
  <div class="page">
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="back-link" aria-label="返回首頁">
          <i class="fa-solid fa-arrow-left"></i>
        </a>
        <a href="/" class="brand">水博館水族</a>
        <span class="header-spacer" aria-hidden="true"></span>
      </div>
    </header>

    <main class="wrap">
      <nav class="breadcrumb" aria-label="麵包屑">
        <a href="/">首頁</a>
        <span class="sep">/</span>
        <a href="/products/1">全部商品</a>
        <span class="sep">/</span>
        <a href={`/category/${product.category}`}>{categoryLabel}</a>
        <span class="sep">/</span>
        <span class="current">{product.name}</span>
      </nav>

      {product.isPlaceholder && (
        <p class="placeholder-banner">此筆在 Sanity 後台標為「占位範例」，正式營運請取消勾選或刪除文件。</p>
      )}

      <article class="detail">
        <div class="detail-media">
          <img src={product.image} alt={product.name} width="1000" height="750" loading="eager" />
        </div>
        <div class="detail-body">
          <p class="category-pill">{categoryLabel}</p>
          <h1>{product.name}</h1>
          <p class="excerpt">{product.excerpt}</p>
          <div class="prose">
            {product.description.split('\n').map((para) => (
              <p>{para}</p>
            ))}
          </div>
          <p class="note">以上為門市展示資訊，實際庫存與規格請以現場為準。歡迎來店參觀選購。</p>
          <a href="/products/1" class="btn-secondary">返回全部商品</a>
        </div>
      </article>
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p class="footer-brand">水博館水族</p>
        <p class="footer-copy">© {new Date().getFullYear()} 門市展示網頁</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: #fff;
    color: #111;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 16px;
    min-height: 56px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: #111;
  }

  .back-link:hover {
    background: #f5f5f5;
  }

  .brand {
    justify-self: center;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    color: #111;
  }

  .header-spacer {
    width: 40px;
  }

  .wrap {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .placeholder-banner {
    margin: 0 0 20px;
    padding: 12px 16px;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #664d00;
    background: #fff8e1;
    border: 1px solid #ffe082;
    border-radius: 8px;
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    margin: 0 6px;
    color: #bbb;
  }

  .current {
    color: #333;
  }

  .detail {
    display: grid;
    gap: 28px;
  }

  @media (min-width: 900px) {
    .detail {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .detail-media {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #eee;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    background: #f5f5f5;
  }

  .detail-media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .category-pill {
    display: inline-block;
    margin: 0 0 12px;
    padding: 4px 12px;
    font-size: 0.8125rem;
    font-weight: 600;
    background: #f0f0f0;
    border-radius: 999px;
    color: #333;
  }

  .detail-body h1 {
    margin: 0 0 12px;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.25;
  }

  .excerpt {
    margin: 0 0 20px;
    font-size: 1rem;
    color: #444;
    line-height: 1.6;
  }

  .prose p {
    margin: 0 0 14px;
    line-height: 1.85;
    color: #333;
    font-size: 0.9375rem;
  }

  .note {
    margin: 24px 0 20px;
    padding: 14px 16px;
    background: #fafafa;
    border: 1px solid #eee;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
  }

  .btn-secondary {
    display: inline-block;
    padding: 10px 20px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111;
    border: 1px solid #ccc;
    border-radius: 8px;
    background: #fff;
  }

  .btn-secondary:hover {
    background: #f5f5f5;
  }

  .site-footer {
    border-top: 1px solid #e5e5e5;
    padding: 24px 16px;
    margin-top: auto;
  }

  .footer-inner {
    text-align: center;
  }

  .footer-brand {
    margin: 0 0 6px;
    font-weight: 800;
  }

  .footer-copy {
    margin: 0;
    font-size: 0.8125rem;
    color: #666;
  }
</style>

  .workspace { display: grid; grid-template-columns: 320px 1fr; gap: 10px; min-height: calc(100vh - 170px); }
  .listpane, .formpane { background: #fff; border: 1px solid #dbe4ea; border-radius: 12px; padding: 12px; }
  .listpane {

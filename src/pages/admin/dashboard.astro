  .img-modal__close { position: absolute; top: 16px; right: 16px; width: 44px; height: 44px; border-radius: 999px; border: 0; background: #fff; color: #111827; font-size: 1.1rem; font-weight: 800; z-index: 2; }
  .img-modal__img { position: relative; z-index: 1; max-width: min(94vw, 1280px); max-height: 88vh; width: auto; height: auto; border-radius: 8px; box-shadow: 0 20px 50px rgba(0,0,0,.45); }


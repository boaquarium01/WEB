  .card--bool { grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 4px 8px; }
  .switch { width: 62px; height: 34px; position: relative; display: inline-block; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .switch span { position: absolute; inset: 0; background: #dbe5ec; border-radius: 999px; }
  .switch span::before { content: ''; position: absolute; left: 3px; top: 3px; width: 28px; height: 28px; border-radius: 50%; background: #fff; transition: transform .2s; }
  .switch input:checked + span { background: linear-gradient(120deg, #1e8f89, #34a3ba); }
  .switch input:checked + span::before { transform: translateX(30px); }

  .wall { display: grid; gap: 8px; }
  .grid { display: grid; gap: 8px; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
  .pending-grid { display: grid; gap: 8px; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
  .thumb { border: 1px solid #d2dae3; border-radius: 8px; overflow: hidden; background: #fff; position: relative; }
  .thumb--pending { border: 2px solid #f59e0b; box-shadow: 0 0 0 2px rgba(245, 158, 11, .2); background: linear-gradient(180deg, #fffbeb 0%, #fff 100%); }
  .thumb--pending:hover { border-color: #d97706; box-shadow: 0 0 0 3px rgba(217, 119, 6, .22); }
  .pending-tag { position: absolute; top: 6px; left: 6px; z-index: 2; background: #b45309; color: #fff; font-size: .72rem; font-weight: 800; border-radius: 999px; padding: 3px 8px; letter-spacing: .02em; }
  .order-badge { position: absolute; left: 6px; top: 6px; z-index: 2; background: rgba(17, 24, 39, .86); color: #fff; font-size: .74rem; font-weight: 800; border-radius: 999px; padding: 2px 7px; }
  .thumb img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; }
  .ph { height: 100px; display: grid; place-items: center; color: #475569; background: #e8f4f3; font-weight: 700; }
  .ops { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; padding: 6px; }
  .ops button, .mini { border: 0; border-radius: 6px; background: #166f6a; color: #fff; font-size: .78rem; padding: 6px; }

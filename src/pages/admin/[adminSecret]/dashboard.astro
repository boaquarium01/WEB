          const heroSpotlight = Boolean(row.heroSpotlight);
          const thumbSrc = getProductThumbSrc(row);
          const cat = categoryName(row) || '未分類';
          const title = String(row[titleKey] ?? '').trim() || `項目 #${row.id}`;

          b.className = `item item--product ${isActive ? 'is-active' : ''} ${enabled ? 'item--enabled' : 'item--disabled'}`;

          const thumbWrap = document.createElement('span');
          thumbWrap.className = 'item__thumbWrap';
          if (thumbSrc) {
            const img = document.createElement('img');
            img.className = 'item__thumb';
            img.src = thumbSrc;
            img.alt = '首圖';
            img.loading = 'lazy';
            thumbWrap.appendChild(img);
          } else {
            const ph = document.createElement('span');
            ph.className = 'item__thumb item__thumb--empty';
            ph.setAttribute('aria-hidden', 'true');
            thumbWrap.appendChild(ph);
          }

          const main = document.createElement('span');
          main.className = 'item__main';

          const row1 = document.createElement('span');
          row1.className = 'item__row1';

          const titleEl = document.createElement('span');
          titleEl.className = 'item__title';
          titleEl.textContent = title;
          row1.appendChild(titleEl);

          const meta = document.createElement('span');
          meta.className = 'item__meta item__meta--withTags';

          const catEl = document.createElement('span');
          catEl.className = 'item__metaCategory';
          catEl.textContent = cat;

          const tagWrap = document.createElement('span');
          tagWrap.className = 'item__metaTags';
          tagWrap.setAttribute('aria-label', '商品標籤');
          if (heroSpotlight) {
            const spot = document.createElement('span');
            spot.className = 'badge badge--spotlight';
            spot.textContent = '主打';
            tagWrap.appendChild(spot);
          }
          if (featured) {
            const hot = document.createElement('span');
            hot.className = 'badge badge--hot';
            hot.textContent = '熱銷';
            tagWrap.appendChild(hot);
          }

          meta.append(catEl, tagWrap);

          main.append(row1, meta);
          b.append(thumbWrap, main);
        } else {
          b.className = `item ${isActive ? 'is-active' : ''}`;
          b.textContent = String(row[titleKey] ?? `項目 #${row.id}`);
        }
        b.onclick = () => select(row);
        entryList.appendChild(b);
      });
    }
    function select(row) {
      if (isCategorySortMode() || isProductSortMode()) return;
      fill(row);
      state.dirty = false;
      setStatus(`已載入 ${defs[state.model].label}`);
      if (isMobileNarrow()) setMobilePanel('editor');
    }

    function fieldEl(field, cfg) {
      const wrap = document.createElement('section');
      wrap.className = 'card';
      wrap.dataset.field = field;
      wrap.dataset.type = cfg.type;
      wrap.dataset.multiple = String(Boolean(cfg.multiple));
      if (cfg.type === 'media' || field === 'content' || field === 'body') wrap.classList.add('span2');
      wrap.innerHTML = `<label>${labelOf(state.model, field)}</label>`;

      if (cfg.type === 'boolean') {
        wrap.classList.add('card--bool');
        wrap.insertAdjacentHTML('beforeend', `<label class="switch"><input type="checkbox"><span></span></label>`);
      } else if (cfg.type === 'text' || cfg.type === 'blocks') {
        const rows = cfg.type === 'blocks' ? 7 : field === 'excerpt' ? 2 : 4;
        wrap.insertAdjacentHTML('beforeend', `<textarea rows="${rows}"></textarea>`);
      } else if (cfg.type === 'relation') {
        wrap.insertAdjacentHTML('beforeend', `<select></select>`);
      } else if (cfg.type === 'media') {
        wrap.insertAdjacentHTML(
          'beforeend',
          `<div class="wall"><div class="grid"></div><div class="pending-grid"></div><div class="uploader"><input class="file-input" type="file" accept="image/*" ${cfg.multiple ? 'multiple' : ''}><span class="pick-info">未選擇檔案</span></div><div class="pick-files" aria-live="polite"></div></div>`
        );
      } else {
        wrap.insertAdjacentHTML('beforeend', `<input type="${cfg.type === 'datetime' ? 'datetime-local' : 'text'}">`);
      }
      wrap.insertAdjacentHTML('beforeend', `<p class="err"></p>`);
      return wrap;
    }

    /** 商品分頁必備：篩選下拉與表單分類選項（排序模式會略過 drawForm，須單獨載入） */
    async function ensureProductCategoryFilter() {
      const prev = String(categoryFilter.value ?? '').trim();
      const cat = await api('/api/categories?fields[0]=name&fields[1]=orderRank&pagination[pageSize]=200');
      state.categoryOptions = sortCategoriesByOrderRank(Array.isArray(cat?.data) ? cat.data : []);
      categoryFilter.style.display = 'block';
      categoryFilter.innerHTML = '<option value="">全部分類</option>';
      state.categoryOptions.forEach((x) => {
        const o = document.createElement('option');
        o.value = String(x.documentId ?? x.id ?? '');
        o.textContent = String(x.attributes?.name ?? x.name ?? x.id);
        categoryFilter.appendChild(o);
      });
      if (prev && Array.from(categoryFilter.options).some((opt) => opt.value === prev)) {
        categoryFilter.value = prev;
      }
    }

    async function drawForm() {
      formRoot.innerHTML = '';
      const attrs = schemas[state.model]?.attributes ?? {};
      const advancedKeys = [];
      Object.keys(attrs).forEach((f) => {
        if (state.model === 'product' && f === 'slug') return;
        if (state.model === 'product' && f === 'gallery') return;
        // Strapi 只保留 orderRank，避免出現第二個舊排序欄位
        if (state.model === 'category' && f === 'legacySortOrder') return;
        if (state.model === 'promotion' && f === 'title' && state.simpleMode) {
          advancedKeys.push(f);
          return;
        }
        const cfg = attrs[f];
        if (state.simpleMode && advancedField(f)) {
          advancedKeys.push(f);
          return;
        }
        if (state.simpleMode && !essentialField(f) && !cfg.required && cfg.type !== 'media' && cfg.type !== 'boolean') {
          advancedKeys.push(f);
          return;
        }
        formRoot.appendChild(fieldEl(f, cfg));
      });

      if (advancedKeys.length > 0) {
        const details = document.createElement('details');
        details.className = 'advanced';
        details.innerHTML = `<summary>進階設定（slug / SEO / 排序）</summary><div class="advanced-grid"></div>`;
        const grid = details.querySelector('.advanced-grid');
        if (grid) {
          advancedKeys.forEach((f) => grid.appendChild(fieldEl(f, attrs[f])));
        }
        formRoot.appendChild(details);
      }

      if (state.model === 'product') {
        const slugCard = document.createElement('section');
        slugCard.className = 'card span2 slug-card';
        slugCard.innerHTML =
          '<label>商品 slug (自動生成)</label><input id="productSlugReadonly" type="text" readonly />';
        formRoot.appendChild(slugCard);
      }
      if (state.model === 'product') {
        if (!state.categoryOptions.length) {
          await ensureProductCategoryFilter();
        }
      } else {
        categoryFilter.style.display = 'none';
        categoryFilter.value = '';
      }
      fill(state.selected);
      formRoot.oninput = (e) => {
        const t = e.target;
        if (t instanceof HTMLInputElement && t.readOnly) return;
        markDirty();
        if (t instanceof Element) {
          const card = t.closest('.card');
          const key = String(defs[state.model]?.title ?? '').trim();
          if (key && card instanceof HTMLElement && card.dataset.field === key) updateSectionLabels();
        }
      };
      formRoot.onchange = () => markDirty();
    }

    async function applyPendingUploads(card, { interactive = true } = {}) {
      const grid = card.querySelector('.grid');
      const info = card.querySelector('.pick-info');
      const fileList = card.querySelector('.pick-files');
      const field = card.dataset.field ?? '';
      if (!(grid instanceof HTMLElement) || !(info instanceof HTMLElement)) return;
      const files = Array.isArray(state.pendingUploads[field]) ? [...state.pendingUploads[field]] : [];
      if (!files.length) return;

      const max = state.model === 'promotion' && field === 'promoImages' ? 25 : Infinity;
      if (Number.isFinite(max) && grid.children.length + files.length > max) {
        const overflow = grid.children.length + files.length - max;
        if (interactive) {
          const yes = window.confirm(`促銷圖片上限 25 張。\n將以新圖片取代最後 ${overflow} 張舊圖，是否繼續？`);
          if (!yes) return;
        }
        for (let i = 0; i < overflow; i += 1) {
          const last = grid.lastElementChild;
          if (last) last.remove();
        }
      }
      const ids = await upload(files);
      ids.forEach((id) => {
        const c = document.createElement('article');
        c.className = 'thumb pending';
        c.dataset.id = String(id);
        const label = String(id).length > 24 ? `${String(id).slice(0, 12)}…` : String(id);
        c.innerHTML = `<div class="ph">ID ${label}</div><div class="ops"><button type="button" class="op-btn op-left" data-a="l" aria-label="左移"><i class="fa-solid fa-arrow-left"></i></button><button type="button" class="op-btn op-right" data-a="r" aria-label="右移"><i class="fa-solid fa-arrow-right"></i></button><button type="button" class="op-btn op-del" data-a="d" aria-label="移除"><i class="fa-solid fa-trash"></i></button></div>`;
        grid.appendChild(c);
      });
      state.pendingUploads[field] = [];
      info.textContent = '未選擇檔案';
      const pendingGrid = card.querySelector('.pending-grid');
      if (pendingGrid instanceof HTMLElement) pendingGrid.innerHTML = '';
      if (fileList instanceof HTMLElement) fileList.innerHTML = '';
      const input = card.querySelector('.file-input');
      if (input instanceof HTMLInputElement) input.value = '';
      markDirty();
    }

    function mediaBind(card) {
      const grid = card.querySelector('.grid');
      const pendingGrid = card.querySelector('.pending-grid');
      const input = card.querySelector('.file-input');
      const info = card.querySelector('.pick-info');
      const fileList = card.querySelector('.pick-files');
      const field = card.dataset.field ?? '';
      if (!(grid instanceof HTMLElement) || !(pendingGrid instanceof HTMLElement) || !(input instanceof HTMLInputElement) || !(info instanceof HTMLElement) || !(fileList instanceof HTMLElement)) return;

      if (!Array.isArray(state.pendingUploads[field])) state.pendingUploads[field] = [];
      const renderPending = () => {
        const files = Array.isArray(state.pendingUploads[field]) ? state.pendingUploads[field] : [];
        pendingGrid.innerHTML = '';
        fileList.innerHTML = '';
        files.forEach((file, idx) => {
          const src = URL.createObjectURL(file);
          const item = document.createElement('article');
          item.className = 'thumb thumb--pending';
          item.innerHTML = `<span class="pending-tag">新圖片</span><img src="${src}" alt="${file.name}"><div class="ops"><button type="button" data-rm="${idx}">移除圖片</button></div>`;
          const rm = item.querySelector('button[data-rm]');
          if (rm) {
            rm.onclick = () => {
              state.pendingUploads[field].splice(idx, 1);
              renderPending();
              info.textContent = state.pendingUploads[field].length > 0 ? `已選 ${state.pendingUploads[field].length} 張` : '未選擇檔案';
              if (state.pendingUploads[field].length === 0) input.value = '';
              markDirty();
            };
          }
          pendingGrid.appendChild(item);

          const nameRow = document.createElement('div');
          nameRow.className = 'pick-file-row';
          nameRow.textContent = `${idx + 1}. ${file.name}`;
          fileList.appendChild(nameRow);
        });
      };

      input.onchange = () => {
        const files = Array.from(input.files ?? []);
        if (!files.length) return;
        state.pendingUploads[field].push(...files);
        info.textContent = `已選 ${state.pendingUploads[field].length} 張`;
        renderPending();
        markDirty();
      };

      grid.querySelectorAll('.thumb').forEach((el, i) => {
        const l = el.querySelector('[data-a="l"]');
        const r = el.querySelector('[data-a="r"]');
        const d = el.querySelector('[data-a="d"]');
        const img = el.querySelector('img');
        const existingBadge = el.querySelector('.order-badge');
        if (!existingBadge) {
          const badge = document.createElement('span');
          badge.className = 'order-badge';
          badge.textContent = state.model === 'product' && card.dataset.field === 'image' && i === 0 ? '主圖' : String(i + 1);
          el.prepend(badge);
        } else {
          existingBadge.textContent = state.model === 'product' && card.dataset.field === 'image' && i === 0 ? '主圖' : String(i + 1);
        }
        if (img instanceof HTMLImageElement) {
          img.style.cursor = 'zoom-in';
          img.onclick = () => openPreview(img.src);
        }
        if (l) l.onclick = () => {
          if (i > 0) {
            grid.insertBefore(el, grid.children[i - 1]);
            markDirty();
          }
          mediaBind(card);
        };
        if (r) r.onclick = () => {
          if (grid.children[i + 1]) {
            grid.insertBefore(grid.children[i + 1], el);
            markDirty();
          }
          mediaBind(card);
        };
        if (d) d.onclick = () => {
          if (window.confirm('確定移除此圖片？')) {
            el.remove();
            markDirty();
            mediaBind(card);
          }
        };
      });
    }

    function fillMedia(card, value) {
      const grid = card.querySelector('.grid');
      if (!(grid instanceof HTMLElement)) return;
      const arr = Array.isArray(value) ? value : Array.isArray(value?.data) ? value.data : value?.data ? [value.data] : value ? [value] : [];
      grid.innerHTML = '';
      arr.forEach((m) => {
        const raw = m?.url ?? m?.attributes?.url ?? '';
        const src = raw.startsWith('http') ? raw : `${base}${raw}`;
        const c = document.createElement('article');
        c.className = 'thumb';
        c.dataset.id = String(m?.id ?? '');
        c.innerHTML = `<img src="${src}" alt=""><div class="ops"><button type="button" class="op-btn op-left" data-a="l" aria-label="左移"><i class="fa-solid fa-arrow-left"></i></button><button type="button" class="op-btn op-right" data-a="r" aria-label="右移"><i class="fa-solid fa-arrow-right"></i></button><button type="button" class="op-btn op-del" data-a="d" aria-label="移除"><i class="fa-solid fa-trash"></i></button></div>`;
        grid.appendChild(c);
      });
      mediaBind(card);
    }

    function fill(row) {
      state.selected = row ?? {};
      state.selectedId = kOf(state.selected);
      if (state.model === 'product') {
        const slugInput = document.getElementById('productSlugReadonly');
        if (slugInput instanceof HTMLInputElement) {
          const value = String(state.selected.slug ?? '').trim();
          slugInput.value = value;
        }
      }
      formRoot.querySelectorAll('.card').forEach((card) => {
        const field = card.dataset.field;
        const type = card.dataset.type;
        if (!field) return;
        const v = state.selected[field];
        if (type === 'boolean') {
          const c = card.querySelector('input[type="checkbox"]');
          if (c) c.checked = Boolean(v);
        } else if (type === 'relation') {
          const s = card.querySelector('select');
          if (!(s instanceof HTMLSelectElement)) return;
          s.innerHTML = '<option value="">請選擇分類</option>';
          state.categoryOptions.forEach((x) => {
            const o = document.createElement('option');
            o.value = String(x.documentId ?? x.id ?? '');
            o.textContent = String(x.attributes?.name ?? x.name ?? x.id);
            s.appendChild(o);
          });
          s.value = String(v?.data?.documentId ?? v?.documentId ?? v?.data?.id ?? v?.id ?? '');
        } else if (type === 'media') {
          if (state.model === 'product' && field === 'image') {
            const merged = [];
            const head = Array.isArray(state.selected.image) ? state.selected.image : state.selected.image ? [state.selected.image] : [];
            const tail = Array.isArray(state.selected.gallery) ? state.selected.gallery : state.selected.gallery ? [state.selected.gallery] : [];
            merged.push(...head, ...tail);
            fillMedia(card, merged);
          } else {
            fillMedia(card, v);
          }
        } else {
          const i = card.querySelector('input,textarea');
          if (!i) return;
          if (type === 'datetime') i.value = v ? String(v).slice(0, 16) : '';
          else if (type === 'json') i.value = v ? JSON.stringify(v) : '';
          else if (type === 'blocks') {
            if (Array.isArray(v)) {
              const fb = v[0];
              const isPortable = Boolean(fb && typeof fb === 'object' && fb._type === 'block');
              i.value = isPortable ? portableBlocksToPlainText(v) : strapiBlocksToPlainText(v);
            } else i.value = v == null ? '' : String(v);
          } else i.value = v == null ? '' : String(v);
        }
      });
      drawList();
      updateSectionLabels();
      syncPublicSiteButtons();
    }

    function collect() {
      const attrs = schemas[state.model].attributes;
      const out = {};
      let ok = true;
      formRoot.querySelectorAll('.card').forEach((card) => {
        const f = card.dataset.field;
        const t = card.dataset.type;
        if (!f) return;
        const err = card.querySelector('.err');
        if (err) err.textContent = '';

        if (t === 'boolean') {
          const c = card.querySelector('input[type="checkbox"]');
          out[f] = Boolean(c?.checked);
        } else if (t === 'relation') {
          const s = card.querySelector('select');
          out[f] = normalizeRelationValue(s?.value);
        } else if (t === 'media') {
          const rawIds = Array.from(card.querySelectorAll('.thumb'))
            .map((x) => String(x.dataset.id ?? '').trim())
            .filter(Boolean)
            .map((s) => (/^\d+$/.test(s) ? Number(s) : s));
          if (state.model === 'product' && f === 'image') {
            out.image = rawIds[0] ?? null;
            out.gallery = rawIds.slice(1);
          } else {
            out[f] = attrs[f].multiple ? rawIds : rawIds[0] ?? null;
          }
        } else {
          const i = card.querySelector('input,textarea');
          const raw = i?.value ?? '';
          if (t === 'integer') out[f] = raw.trim() ? Number(raw) : null;
          else if (t === 'json') out[f] = raw.trim() ? JSON.parse(raw) : null;
          else if (t === 'blocks') out[f] = plainTextToStrapiBlocks(raw);
          else out[f] = raw;
        }

        if (attrs[f]?.required && (out[f] === '' || out[f] == null)) {
          if (err) err.textContent = '此欄位必填';
          ok = false;
        }
      });
      if (state.model === 'product') {
        const slugInput = document.getElementById('productSlugReadonly');
        const slugValue =
          slugInput instanceof HTMLInputElement ? slugInput.value.trim() : String(state.selected.slug ?? '').trim();
        out.slug = slugValue;
      }
      return { ok, out };
    }

    /**
     * @param {string} [selectIdAfter] 載入後自動選取（維持編輯畫面，避免儲存後表單被清空／手機跳出編輯）
     */
    async function load(selectIdAfter) {
      setStatus('載入中...');
      const j = await api(`${defs[state.model].api}?populate=*`);
      state.entries = norm(j);
      if (state.model === 'product' && state.entries.length) {
        state.entries = applySortOrderWithinEachCategory(state.entries);
      }
      if (isCategorySortMode()) {
        // 只在載入時依 orderRank 排序一次，後續調整以陣列順序為準
        state.entries = [...state.entries].sort((a, b) => {
          const ra = Number.isFinite(Number(a.orderRank)) ? Number(a.orderRank) : 999999;
          const rb = Number.isFinite(Number(b.orderRank)) ? Number(b.orderRank) : 999999;
          if (ra !== rb) return ra - rb;
          return String(a.name ?? '').localeCompare(String(b.name ?? ''), 'zh-Hant');
        });
      }
      state.selected = {};
      state.selectedId = '';
      fill({});
      drawList();
      state.dirty = false;
      setLoadedStatus();
      const sid = String(selectIdAfter ?? '').trim();
      if (sid) {
        const row = state.entries.find((e) => kOf(e) === sid);
        if (row) select(row);
      }
      syncPublicSiteButtons();
    }

    async function switchModel(model, options = {}) {
      const {
        selectPromotionSlug,
        mobilePanel,
        // 「分類管理」預設開排序模式：只調整順序、不顯示右側表單
        categorySortMode = model === 'category',
        productSortMode = false
      } = options;
      try {
        state.model = model;
        state.categorySortMode = model === 'category' ? Boolean(categorySortMode) : false;
        state.productSortMode = model === 'product' ? Boolean(productSortMode) : false;
        root.dataset.categorySortMode = state.categorySortMode ? '1' : '0';
        root.dataset.productSortMode = state.productSortMode ? '1' : '0';
        root.dataset.model = model;
        if (model === 'product') {
          await ensureProductCategoryFilter();
        }
        if (isMobileNarrow()) {
          if (mobilePanel !== undefined) setMobilePanel(mobilePanel);
          else if (state.categorySortMode || state.productSortMode) setMobilePanel('list');
          else setMobilePanel('list');
        }
        drawTabs();
        if (state.categorySortMode || state.productSortMode) {
          formRoot.innerHTML = '';
          state.selected = {};
          state.selectedId = '';
        } else {
          await drawForm();
        }
        await load();
        if (selectPromotionSlug) {
          const slug = String(selectPromotionSlug).trim();
          const row = state.entries.find((e) => String(e.slug ?? '').trim() === slug);
          if (row) select(row);
          else setStatus(`找不到促銷頁（slug）：${slug}`);
        }
        updateSectionLabels();
      } catch (e) {
        setStatus(`分頁切換失敗：${e instanceof Error ? e.message : String(e)}`);
      }
    }

    async function hubAction(hubKey) {
      if (!confirmDiscardIfDirty()) return;
      state.dirty = false;
      try {
        if (hubKey === 'promo-weekly') await switchModel('promotion', { selectPromotionSlug: 'weekly-new' });
        else if (hubKey === 'promo-special') await switchModel('promotion', { selectPromotionSlug: 'special-offers' });
        else if (hubKey === 'promo-equipment') await switchModel('promotion', { selectPromotionSlug: 'equipment-sale' });
        else if (hubKey === 'products-all') {
          await switchModel('product');
          categoryFilter.value = '';
          drawList();
        } else if (hubKey === 'products-by-category') {
          await switchModel('product', { productSortMode: true, mobilePanel: 'list' });
          if (categoryFilter.options.length > 1 && !categoryFilter.value) categoryFilter.value = String(categoryFilter.options[1].value ?? '');
          drawList();
          setStatus('選分類→↑↓→頂部「儲存」');
          queueMicrotask(() => categoryFilter.focus());
        } else if (hubKey === 'categories-sort') {
          await switchModel('category', { categorySortMode: true, mobilePanel: 'list' });
          setStatus('分類管理：可用 ↑↓ 調整');
        }
      } catch (e) {
        setStatus(`無法開啟：${e instanceof Error ? e.message : String(e)}`);
      }
    }

    async function saveCategoryOrder() {
      // 逐筆更新（避免大量 Promise.all 併發造成偶發失敗，也方便定位哪筆出錯）
      for (let idx = 0; idx < state.entries.length; idx += 1) {
        const row = state.entries[idx];
        const id = kOf(row);
        if (!id) continue;
        // Strapi schema: orderRank 是 string
        const nextRank = String(idx + 1);
        const current = String(row.orderRank ?? '').trim();
        if (current === nextRank) continue;
        setStatus(`儲存中…（${idx + 1}/${state.entries.length}）`);
        await api(`${defs.category.api}/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ data: { orderRank: nextRank } })
        });
      }
      state.dirty = false;
      await load();
      setStatus('分類順序已儲存');
    }

    async function saveProductCategoryOrder() {
      const selectedCategory = String(categoryFilter.value ?? '').trim();
      if (!selectedCategory) {
        setStatus('請先選擇分類');
        return;
      }
      const items = state.entries.filter((x) => productCategoryId(x) === selectedCategory);
      const updates = [];
      for (let idx = 0; idx < items.length; idx += 1) {
        const row = items[idx];
        const id = kOf(row);
        if (!id) continue;
        const nextSort = idx + 1;
        const current = Number(row.sortOrder);
        if (Number.isFinite(current) && current === nextSort) continue;
        updates.push({ id, sortOrder: nextSort });
      }
      if (!updates.length) {
        state.dirty = false;
        setStatus('順序與後端一致，無需儲存');
        return;
      }
      setStatus(`儲存中…（${updates.length} 筆）`);
      if (adminBackend === 'sanity') {
        await api('/api/products/batch-sort-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ data: { items: updates } })
        });
      } else {
        const chunkSize = 6;
        for (let i = 0; i < updates.length; i += chunkSize) {
          const chunk = updates.slice(i, i + chunkSize);
          setStatus(`儲存中…（${Math.min(i + chunk.length, updates.length)}/${updates.length}）`);
          await Promise.all(
            chunk.map((u) =>
              api(`${defs.product.api}/${u.id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ data: { sortOrder: u.sortOrder } })
              })
            )
          );
        }
      }
      state.dirty = false;
      const keepCat = selectedCategory;
      await load();
      if (keepCat && Array.from(categoryFilter.options).some((o) => o.value === keepCat)) {
        categoryFilter.value = keepCat;
      }
      drawList();
      setStatus('商品排序已儲存');
    }

    const catModalState = { mode: 'create', id: '', originalSlug: '', manualSlug: false };

    function openCategoryModal(mode, row = null) {
      catModalState.mode = mode;
      catModalState.manualSlug = false;
      catModalState.id = row ? kOf(row) : '';
      const currentName = row ? String(row.name ?? '') : '';
      const currentSlug = row ? String(row.slug ?? row?.attributes?.slug ?? '') : '';
      catModalState.originalSlug = currentSlug;
      catModalTitle.textContent = mode === 'edit' ? '編輯分類' : '新增分類';
      catModalName.value = currentName;
      catModalSlug.value = currentSlug;
      catModalDelete.hidden = mode !== 'edit';
      if (catModalHint instanceof HTMLElement) catModalHint.textContent = 'slug 建議小寫英數與連字號（-），需唯一。';
      catManageModal.hidden = false;
      catManageModal.setAttribute('aria-hidden', 'false');
      try { applyBodyScrollLock(); } catch {}
      queueMicrotask(() => catModalName.focus());
    }

    function closeCategoryModal() {
      catManageModal.hidden = true;
      catManageModal.setAttribute('aria-hidden', 'true');
      try { releaseBodyScrollLock(); } catch {}
    }

    async function deleteCategory(row) {
      const id = kOf(row);
      if (!id) return;
      const name = String(row.name ?? '').trim() || '此分類';
      const yes = window.confirm(`確定要刪除「${name}」？\n\n刪除後無法復原。`);
      if (!yes) return;
      setStatus('刪除分類中…');
      await api(`${defs.category.api}/${id}`, { method: 'DELETE' });
      await load();
      setStatus('已刪除分類');
    }

    async function saveCategoryModal() {
      const name = String(catModalName.value ?? '').trim();
      let slug = String(catModalSlug.value ?? '').trim();
      if (!name) throw new Error('請輸入分類名稱');
      if (!slug) slug = slugify(name) || `cat-${slug5()}`;
      const payload = { name, slug };
      if (catModalState.mode === 'create') {
        const nextRank = String(state.entries.length + 1);
        setStatus('新增分類中…');
        await api(defs.category.api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ data: { ...payload, orderRank: nextRank } })
        });
        await load();
        setStatus('已新增分類');
      } else {
        if (!catModalState.id) throw new Error('缺少分類 ID');
        setStatus('更新分類中…');
        await api(`${defs.category.api}/${catModalState.id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ data: payload })
        });
        await load();
        setStatus('已更新分類');
      }
      closeCategoryModal();
    }

    async function save() {
      if (state.saving) return;
      state.saving = true;
      saveBtn.setAttribute('disabled', 'true');
      if (isCategorySortMode()) {
        try {
          await saveCategoryOrder();
        } finally {
          state.saving = false;
          saveBtn.removeAttribute('disabled');
        }
        return;
      }
      if (isProductSortMode()) {
        try {
          await saveProductCategoryOrder();
        } finally {
          state.saving = false;
          saveBtn.removeAttribute('disabled');
        }
        return;
      }
      const { ok, out } = collect();
      if (!ok) {
        setStatus('請先修正欄位');
        state.saving = false;
        saveBtn.removeAttribute('disabled');
        return;
      }
      try {
        const mediaCards = Array.from(formRoot.querySelectorAll('.card')).filter((x) => x.dataset.type === 'media');
        for (const card of mediaCards) {
          await applyPendingUploads(card, { interactive: false });
        }
        const { ok: ok2, out: out2 } = collect();
        if (!ok2) {
          setStatus('請先修正欄位');
          return;
        }
        const hasId = Boolean(state.selectedId);
        const endpoint = hasId ? `${defs[state.model].api}/${state.selectedId}` : defs[state.model].api;
        const idBeforeSave = state.selectedId;
        const resJson = await api(endpoint, { method: hasId ? 'PUT' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ data: out2 }) });
        let reselectId = idBeforeSave;
        if (!hasId) {
          const created = normOne(resJson);
          if (created) reselectId = kOf(created);
        }
        state.dirty = false;
        setStatus(hasId ? '更新成功' : '新增成功');
        await load(reselectId || undefined);
      } finally {
        state.saving = false;
        saveBtn.removeAttribute('disabled');
      }
    }

    searchInput.addEventListener('input', () => {
      if (isProductSortMode()) return;
      drawList();
    });
    categoryFilter.addEventListener('change', drawList);
    const simpleModeLabel = simpleModeToggle.querySelector('.action-btn__label');
    simpleModeToggle.onclick = () => {
      state.simpleMode = !state.simpleMode;
      simpleModeToggle.classList.toggle('is-on', state.simpleMode);
      simpleModeToggle.classList.toggle('is-off', !state.simpleMode);
      simpleModeToggle.setAttribute('aria-pressed', state.simpleMode ? 'true' : 'false');
      const t = state.simpleMode ? '簡易' : '完整';
      if (simpleModeLabel) simpleModeLabel.textContent = t;
      void drawForm()
        .then(() => syncPublicSiteButtons())
        .catch((e) => setStatus(`表單更新失敗：${e.message}`));
    };
    refreshBtn.onclick = () =>
      switchModel(state.model, {
        categorySortMode: state.categorySortMode,
        productSortMode: state.productSortMode
      }).catch((e) => setStatus(`載入失敗：${e.message}`));
    newBtn.onclick = () => {
      if (isCategorySortMode()) {
        openCategoryModal('create');
        return;
      }
      if (isProductSortMode()) {
        setStatus('此頁僅調整排序，不提供新增');
        return;
      }
      const attrs = schemas[state.model].attributes;
      const x = {};
      Object.keys(attrs).forEach((k) => {
        if (attrs[k].type === 'boolean') x[k] = Boolean(attrs[k].default);
        else if (attrs[k].type === 'media') x[k] = attrs[k].multiple ? [] : null;
        else x[k] = attrs[k].default ?? '';
      });
      if (state.model === 'product') x.slug = slug5();
      if (state.model === 'product') x.enabled = true;
      fill(x);
      state.dirty = true;
      setStatus('新增模式（待儲存）');
      if (isMobileNarrow()) setMobilePanel('editor');
    };

    // 分類 modal events
    catModalBackdrop.addEventListener('click', closeCategoryModal);
    catModalClose.addEventListener('click', closeCategoryModal);
    catModalCancel.addEventListener('click', closeCategoryModal);
    catModalSave.addEventListener('click', () => {
      void saveCategoryModal().catch((e) => setStatus(`儲存失敗：${e instanceof Error ? e.message : String(e)}`));
    });
    catModalDelete.addEventListener('click', () => {
      if (catModalState.mode !== 'edit') return;
      const row = state.entries.find((x) => kOf(x) === catModalState.id) ?? null;
      if (!row) {
        setStatus('找不到分類');
        return;
      }
      void deleteCategory(row).then(() => closeCategoryModal()).catch((e) => setStatus(`刪除失敗：${e instanceof Error ? e.message : String(e)}`));
    });
    catModalName.addEventListener('input', () => {
      if (catModalState.manualSlug) return;
      const next = slugify(catModalName.value);
      if (next) catModalSlug.value = next;
    });
    catModalSlug.addEventListener('input', () => {
      catModalState.manualSlug = true;
    });
    mobileSanityMenuBtn.addEventListener('click', () => {
      if (root.dataset.mobilePanel === 'home') return;
      if (!confirmDiscardIfDirty()) return;
      state.dirty = false;
      setMobilePanel('home');
    });
    mobileHub.addEventListener('click', (ev) => {
      const t = ev.target;
      if (!(t instanceof Element)) return;
      const row = t.closest('[data-hub]');
      if (!(row instanceof HTMLButtonElement)) return;
      const key = row.dataset.hub ?? '';
      if (!key) return;
      void hubAction(key);
    });
    window.addEventListener('resize', () => {
      if (!isMobileNarrow()) setMobilePanel('editor');
      else {
        const p = root.dataset.mobilePanel;
        if (p !== 'home' && p !== 'list' && p !== 'editor') setMobilePanel('home');
      }
    });
    saveBtn.onclick = () => save().catch((e) => setStatus(`儲存失敗：${e instanceof Error ? e.message : String(e)}`));

    if (openFrontendBtn) {
      openFrontendBtn.addEventListener('click', () => {
        const url = buildPublicFrontendUrl();
        if (!url) return;
        window.open(url, '_blank', 'noopener,noreferrer');
      });
    }
    if (showQrBtn) {
      showQrBtn.addEventListener('click', () => {
        const url = buildPublicFrontendUrl();
        if (!url) return;
        openQrModal(url);
      });
    }
    if (qrModalBackdrop) qrModalBackdrop.addEventListener('click', closeQrModal);
    if (qrModalClose) qrModalClose.addEventListener('click', closeQrModal);
    if (qrModalSaveImg) qrModalSaveImg.addEventListener('click', () => void saveQrPhoto());
    if (qrModalShare) qrModalShare.addEventListener('click', () => void shareQrContent());

    // 若後端沒有設 STRAPI_API_TOKEN，通常會得到 401/403；提供一次性輸入 token 的 fallback。
    window.addEventListener('keydown', (e) => {
      if (!(e instanceof KeyboardEvent)) return;
      if (e.key !== 'T' || !e.altKey) return;
      const current = readToken();
      const next = window.prompt('輸入 Strapi API Token（僅保存在此瀏覽器）\n\n清空可輸入空字串。', current);
      if (next == null) return;
      writeToken(String(next).trim());
      setStatus(readToken() ? '已設定 Token（Alt+T 可修改）' : '已清除 Token（改用部署環境變數）');
    });

    state.simpleMode = true;
    simpleModeToggle.classList.add('is-on');
    if (simpleModeLabel) simpleModeLabel.textContent = '簡易';
    drawTabs();
    const narrow = isMobileNarrow();
    if (narrow) setMobilePanel('home');
    else setMobilePanel('editor');
    switchModel('promotion', narrow ? { mobilePanel: 'home' } : {})
      .catch((e) => setStatus(`初始化失敗：${e.message}`));
    imgPreviewBackdrop.addEventListener('click', closePreview);
    imgPreviewClose.addEventListener('click', closePreview);
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (qrModal instanceof HTMLElement && !qrModal.hidden) {
        closeQrModal();
        return;
      }
      if (!(imgPreviewModal instanceof HTMLElement) || imgPreviewModal.hidden) return;
      closePreview();
    });
  </script>
</Layout>


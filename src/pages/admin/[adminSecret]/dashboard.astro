    function drawList() {
      const getProductThumbSrc = (row) => {
        let media = row?.image ?? row?.images ?? null;
        if (Array.isArray(media)) media = media[0] ?? null;
        const raw =
          media?.url ??
          media?.attributes?.url ??
          media?.data?.attributes?.url ??
          media?.data?.url ??
          '';
        const s = String(raw ?? '');
        if (!s) return '';
        return s.startsWith('http') ? s : `${base}${s}`;
      };

      if (isCategorySortMode()) {
        // 分類管理模式：只在載入時排序一次；之後以 state.entries 的順序為準（避免上下移後又被 orderRank 排回去）
        const items = [...state.entries];
        listCount.textContent = `共 ${items.length} 個分類`;
        entryList.innerHTML = '';
        items.forEach((row, idx) => {
          const wrap = document.createElement('div');
          wrap.className = 'cat-manage-row';
          const rank = idx + 1;
          const slugText = String(row.slug ?? row?.attributes?.slug ?? '').trim();
          wrap.innerHTML = `<span class="cat-manage-row__name">${String(row.name ?? `分類 #${idx + 1}`)}</span><span class="cat-manage-row__meta">排序：${rank}${slugText ? `　｜　slug：${slugText}` : ''}</span><span class="cat-manage-row__ops"><button type="button" class="cat-manage-row__btn" data-dir="up" ${idx === 0 ? 'disabled' : ''} aria-label="上移"><i class="fa-solid fa-arrow-up"></i></button><button type="button" class="cat-manage-row__btn" data-dir="down" ${idx === items.length - 1 ? 'disabled' : ''} aria-label="下移"><i class="fa-solid fa-arrow-down"></i></button><button type="button" class="cat-manage-row__btn cat-manage-row__btn--edit" data-act="edit" aria-label="編輯"><i class="fa-solid fa-pen"></i></button><button type="button" class="cat-manage-row__btn cat-manage-row__btn--del" data-act="del" aria-label="刪除"><i class="fa-solid fa-trash"></i></button></span>`;
          wrap.querySelectorAll('.cat-manage-row__btn').forEach((btn) => {
            btn.addEventListener('click', (ev) => {
              ev.stopPropagation();
              const t = ev.currentTarget;
              if (!(t instanceof HTMLButtonElement)) return;
              const act = t.dataset.act ?? '';
              if (act === 'edit') {
                openCategoryModal('edit', row);
                return;
              }
              if (act === 'del') {
                void deleteCategory(row).catch((e) => setStatus(`刪除失敗：${e instanceof Error ? e.message : String(e)}`));
                return;
              }
              const dir = t.dataset.dir;
              const to = dir === 'up' ? idx - 1 : idx + 1;
              if (to < 0 || to >= state.entries.length) return;
              const next = [...state.entries];
              const [moved] = next.splice(idx, 1);
              next.splice(to, 0, moved);
              state.entries = next;
              markDirty();
              drawList();
              setStatus('已調整分類順序，請按儲存');
            });
          });
          entryList.appendChild(wrap);
        });
        return;
      }
      if (isProductSortMode()) {
        const titleKey = defs.product.title;
        const selectedCategory = String(categoryFilter.value ?? '').trim();
        const allItems = [...state.entries];
        const categoryName = (row) =>
          String(row?.category?.name ?? row?.category?.data?.attributes?.name ?? row?.category?.data?.name ?? '').trim();
        // 順序必須與 state.entries 一致（僅篩選該分類），不可再依 sortOrder 排序；
        // 否則使用者調整順序後會立刻被 sort 回舊順序，看起來像按鈕無反應。
        const items = selectedCategory ? allItems.filter((x) => productCategoryId(x) === selectedCategory) : [];
        if (!selectedCategory) {
          listCount.textContent = '請先選擇分類';
          entryList.innerHTML = '';
          return;
        }
        listCount.textContent = `共 ${items.length} 個商品`;
        entryList.innerHTML = '';
        items.forEach((row, idx) => {
          const rank = idx + 1;
          const enabled = Boolean(row.enabled);
          const featured = Boolean(row.featured);
          const heroSpotlight = Boolean(row.heroSpotlight);
          const thumbSrc = getProductThumbSrc(row);
          const cat = categoryName(row) || '未分類';
          const title = String(row[titleKey] ?? '').trim() || `商品 #${idx + 1}`;

          const wrap = document.createElement('div');
          wrap.className = `item item--product item--product-sort ${enabled ? 'item--enabled' : 'item--disabled'}`;
          wrap.setAttribute('role', 'group');
          wrap.setAttribute('aria-label', `${title}，排序第 ${rank} 位`);

          const thumbWrap = document.createElement('span');
          thumbWrap.className = 'item__thumbWrap';
          if (thumbSrc) {
            const img = document.createElement('img');
            img.className = 'item__thumb';
            img.src = thumbSrc;
            img.alt = '首圖';
            img.loading = 'lazy';
            thumbWrap.appendChild(img);
          } else {
            const ph = document.createElement('span');
            ph.className = 'item__thumb item__thumb--empty';
            ph.setAttribute('aria-hidden', 'true');
            thumbWrap.appendChild(ph);
          }

          const main = document.createElement('span');
          main.className = 'item__main';

          const row1 = document.createElement('span');
          row1.className = 'item__row1';
          const titleEl = document.createElement('span');
          titleEl.className = 'item__title';
          titleEl.textContent = title;
          const rankEl = document.createElement('span');
          rankEl.className = 'item__sortRank';
          rankEl.textContent = `排序：${rank}`;
          row1.append(titleEl, rankEl);

          const meta = document.createElement('span');
          meta.className = 'item__meta item__meta--withTags';
          const catEl = document.createElement('span');
          catEl.className = 'item__metaCategory';
          catEl.textContent = cat;
          const tagWrap = document.createElement('span');
          tagWrap.className = 'item__metaTags';
          tagWrap.setAttribute('aria-label', '商品標籤');
          if (heroSpotlight) {
            const spot = document.createElement('span');
            spot.className = 'badge badge--spotlight';
            spot.textContent = '主打';
            tagWrap.appendChild(spot);
          }
          if (featured) {
            const hot = document.createElement('span');
            hot.className = 'badge badge--hot';
            hot.textContent = '熱銷';
            tagWrap.appendChild(hot);
          }
          meta.append(catEl, tagWrap);

          main.append(row1, meta);

          const rail = document.createElement('div');
          rail.className = 'item__sortRail';
          const btnRow = document.createElement('div');
          btnRow.className = 'item__sortBtnRow';

          const btnUp = document.createElement('button');
          btnUp.type = 'button';
          btnUp.className = 'item__sortBtn';
          btnUp.dataset.dir = 'up';
          btnUp.setAttribute('aria-label', '上移');
          btnUp.innerHTML = '<i class="fa-solid fa-arrow-up" aria-hidden="true"></i>';
          if (idx === 0) btnUp.disabled = true;

          const btnDown = document.createElement('button');
          btnDown.type = 'button';
          btnDown.className = 'item__sortBtn';
          btnDown.dataset.dir = 'down';
          btnDown.setAttribute('aria-label', '下移');
          btnDown.innerHTML = '<i class="fa-solid fa-arrow-down" aria-hidden="true"></i>';

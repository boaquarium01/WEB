          btnDel.innerHTML = '<i class="fa-solid fa-trash" aria-hidden="true"></i>';

          btnRow.append(btnUp, btnDown, btnEdit, btnDel);
          rail.appendChild(btnRow);

          wrap.append(thumbWrap, main, rail);

          btnRow.querySelectorAll('button').forEach((btn) => {
            btn.addEventListener('click', (ev) => {
              ev.stopPropagation();
              const t = ev.currentTarget;
              if (!(t instanceof HTMLButtonElement)) return;
              const act = t.dataset.act ?? '';
              if (act === 'edit') {
                const keepCat = String(categoryFilter.value ?? '').trim();

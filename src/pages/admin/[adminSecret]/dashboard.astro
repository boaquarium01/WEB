                if (!yes) return;
                const id = kOf(row);
                if (!id) return;
                setStatus('刪除商品中…');
                void api(`${defs.product.api}/${id}`, { method: 'DELETE' })
                  .then(async () => {
                    await load();
                    categoryFilter.value = selectedCategory;
                    drawList();
                    setStatus('已刪除商品');
                  })
                  .catch((e) => setStatus(`刪除失敗：${e instanceof Error ? e.message : String(e)}`));
                return;
              }
              const dir = t.dataset.dir;
              const to = dir === 'up' ? idx - 1 : idx + 1;
              if (to < 0 || to >= items.length) return;
              const movedItems = [...items];
              const [moved] = movedItems.splice(idx, 1);
              movedItems.splice(to, 0, moved);
              const cat = selectedCategory;
              let mi = 0;
              const next = state.entries.map((r) => (productCategoryId(r) === cat ? movedItems[mi++] : r));
              if (mi !== movedItems.length) {
                setStatus('排序合併異常：請刷新頁面');

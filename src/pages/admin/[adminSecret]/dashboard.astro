---
import Layout from '../../../layouts/Layout.astro';
import { SITE_TITLE_SHORT } from '../../../config/site';
import { readStrapiAdminBaseUrl } from '../../../lib/strapi/env';
import { readAdminBackend } from '../../../lib/admin/adminBackend';
import promotionSchema from '../../../../strapi-cms/src/api/promotion/content-types/promotion/schema.json';
import productSchema from '../../../../strapi-cms/src/api/product/content-types/product/schema.json';
import categorySchema from '../../../../strapi-cms/src/api/category/content-types/category/schema.json';

type Schema = {
  config?: { metadatas?: Record<string, { edit?: { label?: string } }> };
  attributes: Record<string, { type: string; required?: boolean; multiple?: boolean; default?: unknown }>;
};

const schemas = {
  promotion: promotionSchema as Schema,
  product: productSchema as Schema,
  category: categorySchema as Schema
};

const defs = {
  promotion: { label: '促銷分頁', api: '/api/promotions', title: 'title' },
  product: { label: '商品列表', api: '/api/products', title: 'name' },
  category: { label: '分類管理', api: '/api/categories', title: 'name' }
};

const base = readStrapiAdminBaseUrl() || 'http://localhost:1337';
const adminBackend = readAdminBackend();
/** 官網前台 origin（供「前往前端／QR」）；可用 PUBLIC_SITE_URL 覆寫 */
const publicSiteBase = String(import.meta.env.PUBLIC_SITE_URL ?? 'https://boaquarium.vercel.app').replace(/\/+$/, '');
---

<Layout title={`後台管理｜${SITE_TITLE_SHORT}`} description="員工後台">
  <main
    class="adminx"
    data-schemas={JSON.stringify(schemas)}
    data-defs={JSON.stringify(defs)}
    data-base={base}
    data-admin-backend={adminBackend}
    data-public-site-base={publicSiteBase}
  >
    <div class="mobile-sanity-bar">
      <button type="button" id="mobileSanityMenuBtn" class="mobile-sanity-bar__iconbtn" aria-label="回首頁選單">
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
      </button>
      <span class="mobile-sanity-bar__logo" aria-hidden="true"><i class="fa-solid fa-fish-fins"></i></span>
      <div class="mobile-sanity-bar__mid">
        <div class="mobile-sanity-bar__textcol">
          <span class="mobile-sanity-bar__title">水博館官網後台</span>
          <span id="sectionLabelMobile" class="mobile-sanity-bar__section" aria-live="polite">促銷分頁</span>
        </div>
        <span id="titleStatus" class="title-status title-status--in-mid">準備中</span>
      </div>
    </div>

    <header class="topbar">
      <div class="center-nav">
        <div class="center-nav__meta">
          <span id="titleStatusDesktop" class="title-status title-status--desktop">準備中</span>
          <span id="sectionLabelDesktop" class="section-label section-label--desktop" aria-live="polite">促銷分頁</span>
        </div>
        <div id="modelTabs" class="tabs"></div>
      </div>
      <div class="actions">
        <button id="simpleModeToggle" class="mode-btn is-on action-btn" type="button" aria-pressed="true" aria-label="切換簡易或完整編輯模式">
          <i class="fa-solid fa-sliders" aria-hidden="true"></i>
          <span class="action-btn__label">簡易</span>
        </button>
        <button id="refreshBtn" type="button" class="action-btn action-btn--solid" aria-label="刷新清單">
          <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
          <span class="action-btn__label">刷新</span>
        </button>
        <button id="newBtn" type="button" class="action-btn action-btn--solid" aria-label="新增一筆">
          <i class="fa-solid fa-plus" aria-hidden="true"></i>
          <span class="action-btn__label">新增</span>
        </button>
        <button id="openFrontendBtn" type="button" class="action-btn action-btn--solid action-btn--frontend" hidden aria-label="前往前台對應頁面">
          <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
          <span class="action-btn__label">前端</span>
        </button>
        <button id="showQrBtn" type="button" class="action-btn action-btn--solid action-btn--qrcode" hidden aria-label="顯示前台網址 QR Code">
          <i class="fa-solid fa-qrcode" aria-hidden="true"></i>
          <span class="action-btn__label">QR Code</span>
        </button>
        <button id="saveBtn" type="button" class="action-btn action-btn--solid" aria-label="儲存變更">
          <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
          <span class="action-btn__label">儲存</span>
        </button>
      </div>
    </header>

    <section id="mobileHub" class="mobile-hub" aria-label="管理選單首頁">
      <nav class="mobile-hub__list">
        <button type="button" class="mobile-hub__row" data-hub="promo-weekly">
          <span class="mobile-hub__icon" aria-hidden="true"><i class="fa-solid fa-fish-fins"></i></span>
          <span class="mobile-hub__label">每週新進魚隻 🐠</span>
          <span class="mobile-hub__chev" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
        </button>
        <button type="button" class="mobile-hub__row" data-hub="promo-special">
          <span class="mobile-hub__icon" aria-hidden="true"><i class="fa-solid fa-tags"></i></span>
          <span class="mobile-hub__label">預定優惠</span>
          <span class="mobile-hub__chev" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
        </button>
        <button type="button" class="mobile-hub__row" data-hub="promo-equipment">
          <span class="mobile-hub__icon" aria-hidden="true"><i class="fa-solid fa-screwdriver-wrench"></i></span>
          <span class="mobile-hub__label">器材促銷</span>
          <span class="mobile-hub__chev" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
        </button>
        <button type="button" class="mobile-hub__row" data-hub="products-all">
          <span class="mobile-hub__icon" aria-hidden="true"><i class="fa-solid fa-box-open"></i></span>
          <span class="mobile-hub__label">全部商品</span>
          <span class="mobile-hub__chev" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
        </button>
        <button type="button" class="mobile-hub__row" data-hub="products-by-category">
          <span class="mobile-hub__icon" aria-hidden="true"><i class="fa-solid fa-arrow-down-wide-short"></i></span>
          <span class="mobile-hub__label">調整分類內順序</span>
          <span class="mobile-hub__chev" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
        </button>
        <button type="button" class="mobile-hub__row" data-hub="categories-sort">
          <span class="mobile-hub__icon" aria-hidden="true"><i class="fa-solid fa-folder-tree"></i></span>
          <span class="mobile-hub__label">分類管理</span>
          <span class="mobile-hub__chev" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
        </button>
      </nav>
    </section>

    <section class="workspace">
      <aside class="listpane">
        <div class="listpane__filters">
          <select id="categoryFilter" class="search search--category" style="display:none;">
            <option value="">全部分類</option>
          </select>
          <div class="search-wrap">
            <span class="search-icon" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input id="searchInput" class="search search--with-icon" placeholder="搜尋目前清單..." />
          </div>
        </div>
        <div id="listCount" class="count">載入中...</div>
        <div id="entryList" class="entry-list"></div>
      </aside>

      <section class="formpane">
        <div class="formpane__section-head">
          <span id="sectionLabelForm" class="formpane__section-title" aria-live="polite"></span>
        </div>
        <p id="statusText" class="status" style="display:none;">準備中...</p>
        <form id="formRoot" class="form-grid"></form>
      </section>
    </section>

    <!-- 分類管理：新增/編輯/刪除（避免 prompt 在手機被阻擋） -->
    <div id="catManageModal" class="cat-modal" hidden role="dialog" aria-modal="true" aria-label="分類管理">
      <button id="catModalBackdrop" class="cat-modal__backdrop" type="button" aria-label="關閉"></button>
      <section class="cat-modal__panel" role="document">
        <header class="cat-modal__head">
          <h3 id="catModalTitle" class="cat-modal__title">分類管理</h3>
          <button id="catModalClose" class="cat-modal__close" type="button" aria-label="關閉">✕</button>
        </header>
        <div class="cat-modal__body">
          <label class="cat-modal__label">
            <span>分類名稱</span>
            <input id="catModalName" type="text" autocomplete="off" />
          </label>
          <label class="cat-modal__label">
            <span>slug（英文網址名稱）</span>
            <input id="catModalSlug" type="text" autocomplete="off" placeholder="例如 fish / equipment" />
          </label>
          <p class="cat-modal__hint">slug 建議小寫英數與連字號（-），需唯一。</p>
        </div>
        <footer class="cat-modal__foot">
          <button id="catModalDelete" type="button" class="cat-modal__btn cat-modal__btn--danger" hidden>刪除</button>
          <div class="cat-modal__spacer"></div>
          <button id="catModalCancel" type="button" class="cat-modal__btn">取消</button>
          <button id="catModalSave" type="button" class="cat-modal__btn cat-modal__btn--primary">儲存</button>
        </footer>
      </section>
    </div>
  </main>

  <!-- 置於 main 外：全螢幕 fixed 不受 .adminx overflow／寬度影響（RWD 預覽） -->
    <div id="qrModal" class="qr-modal" hidden role="dialog" aria-modal="true" aria-label="前台網址 QR Code">
      <button type="button" id="qrModalBackdrop" class="qr-modal__backdrop" aria-label="關閉"></button>
      <div class="qr-modal__panel">
        <header class="qr-modal__head">
          <span class="qr-modal__title">前台網址</span>
          <button type="button" id="qrModalClose" class="qr-modal__close" aria-label="關閉">✕</button>
        </header>
        <div class="qr-modal__body">
          <p id="qrModalUrl" class="qr-modal__url"></p>
          <div class="qr-modal__imgWrap">
            <img id="qrModalImg" class="qr-modal__img" width="240" height="240" alt="" />
          </div>
          <div class="qr-modal__actions">
            <button type="button" id="qrModalSaveImg" class="qr-modal__btn qr-modal__btn--primary">儲存照片</button>
            <button type="button" id="qrModalShare" class="qr-modal__btn qr-modal__btn--secondary">分享</button>
          </div>
        </div>
      </div>
    </div>
    <div id="imgPreviewModal" class="img-modal" hidden>
    <button id="imgPreviewBackdrop" class="img-modal__backdrop" type="button" aria-label="關閉預覽"></button>
    <button id="imgPreviewClose" class="img-modal__close" type="button" aria-label="關閉">✕</button>
    <img id="imgPreviewEl" class="img-modal__img" alt="圖片預覽" />
  </div>

  <script>
    import { applyBodyScrollLock, releaseBodyScrollLock } from '../../../scripts/scrollLock';
    import { plainTextToStrapiBlocks, strapiBlocksToPlainText } from '../../../lib/strapi/blocks';
    import { portableBlocksToPlainText } from '../../../lib/portableText';

    const root = document.querySelector('.adminx');
    if (!(root instanceof HTMLElement)) throw new Error('missing root');
    const schemas = JSON.parse(root.dataset.schemas ?? '{}');
    const defs = JSON.parse(root.dataset.defs ?? '{}');
    const base = (root.dataset.base ?? 'http://localhost:1337').replace(/\/+$/, '');
    const adminBackend = root.dataset.adminBackend === 'strapi' ? 'strapi' : 'sanity';

    const openFrontendBtn = document.getElementById('openFrontendBtn');
    const showQrBtn = document.getElementById('showQrBtn');
    const qrModal = document.getElementById('qrModal');
    const qrModalBackdrop = document.getElementById('qrModalBackdrop');
    const qrModalClose = document.getElementById('qrModalClose');
    const qrModalUrl = document.getElementById('qrModalUrl');
    const qrModalImg = document.getElementById('qrModalImg');
    const qrModalSaveImg = document.getElementById('qrModalSaveImg');
    const qrModalShare = document.getElementById('qrModalShare');

    const modelTabs = document.getElementById('modelTabs');
    const refreshBtn = document.getElementById('refreshBtn');
    const newBtn = document.getElementById('newBtn');
    const saveBtn = document.getElementById('saveBtn');
    const simpleModeToggle = document.getElementById('simpleModeToggle');
    const searchInput = document.getElementById('searchInput');
    const entryList = document.getElementById('entryList');
    const categoryFilter = document.getElementById('categoryFilter');
    const listCount = document.getElementById('listCount');
    const formRoot = document.getElementById('formRoot');
    const statusText = document.getElementById('statusText');
    const titleStatus = document.getElementById('titleStatus');
    const titleStatusDesktop = document.getElementById('titleStatusDesktop');
    const sectionLabelMobile = document.getElementById('sectionLabelMobile');
    const sectionLabelForm = document.getElementById('sectionLabelForm');
    const sectionLabelDesktop = document.getElementById('sectionLabelDesktop');
    const imgPreviewModal = document.getElementById('imgPreviewModal');
    const imgPreviewBackdrop = document.getElementById('imgPreviewBackdrop');
    const imgPreviewClose = document.getElementById('imgPreviewClose');
    const imgPreviewEl = document.getElementById('imgPreviewEl');
    const mobileSanityMenuBtn = document.getElementById('mobileSanityMenuBtn');
    const mobileHub = document.getElementById('mobileHub');
    const catManageModal = document.getElementById('catManageModal');
    const catModalBackdrop = document.getElementById('catModalBackdrop');
    const catModalClose = document.getElementById('catModalClose');
    const catModalTitle = document.getElementById('catModalTitle');
    const catModalName = document.getElementById('catModalName');
    const catModalSlug = document.getElementById('catModalSlug');
    const catModalHint = document.querySelector('.cat-modal__hint');
    const catModalCancel = document.getElementById('catModalCancel');
    const catModalSave = document.getElementById('catModalSave');
    const catModalDelete = document.getElementById('catModalDelete');
    if (!modelTabs || !refreshBtn || !newBtn || !saveBtn || !simpleModeToggle || !searchInput || !entryList || !categoryFilter || !listCount || !formRoot || !statusText || !titleStatus || !titleStatusDesktop || !sectionLabelMobile || !sectionLabelForm || !sectionLabelDesktop || !imgPreviewModal || !imgPreviewBackdrop || !imgPreviewClose || !imgPreviewEl || !mobileSanityMenuBtn || !mobileHub) {
      throw new Error('missing ui');
    }
    if (!catManageModal || !catModalBackdrop || !catModalClose || !catModalTitle || !catModalName || !catModalSlug || !catModalCancel || !catModalSave || !catModalDelete) {
      throw new Error('missing category modal ui');
    }

    const state = { model: 'promotion', entries: [], selectedId: '', selected: {}, categoryOptions: [], simpleMode: true, pendingUploads: {}, dirty: false, saving: false, categorySortMode: false, productSortMode: false };
    const isCategorySortMode = () => state.model === 'category' && state.categorySortMode;
    const isProductSortMode = () => state.model === 'product' && state.productSortMode;

    function getPublicSiteOrigin() {
      const raw = root.dataset.publicSiteBase ?? '';
      const s = String(raw).trim().replace(/\/+$/, '');
      return s || 'https://boaquarium.vercel.app';
    }
    /** 對應官網前台路徑：促銷 /promo/:slug、商品 /product/:slug、分類 /products/1?category=:slug */
    function buildPublicFrontendUrl() {
      if (isCategorySortMode() || isProductSortMode()) return '';
      const m = state.model;
      if (m === 'promotion') {
        const s = String(state.selected?.slug ?? '').trim();
        if (!s) return '';
        return `${getPublicSiteOrigin()}/promo/${encodeURIComponent(s)}`;
      }
      if (m === 'product') {
        const s = String(state.selected?.slug ?? '').trim();
        if (!s) return '';
        return `${getPublicSiteOrigin()}/product/${encodeURIComponent(s)}`;
      }
      if (m === 'category' && !isCategorySortMode()) {
        const s = String(state.selected?.slug ?? state.selected?.attributes?.slug ?? '').trim();
        if (!s) return '';
        return `${getPublicSiteOrigin()}/products/1?category=${encodeURIComponent(s)}`;
      }
      return '';
    }
    function syncPublicSiteButtons() {
      const url = buildPublicFrontendUrl();
      const has = Boolean(url);
      if (openFrontendBtn instanceof HTMLButtonElement) {
        openFrontendBtn.hidden = !has;
        openFrontendBtn.disabled = !has;
      }
      if (showQrBtn instanceof HTMLButtonElement) {
        showQrBtn.hidden = !has;
        showQrBtn.disabled = !has;
        showQrBtn.dataset.frontendUrl = url;
      }
    }
    function openQrModal(url) {
      if (!(qrModal instanceof HTMLElement) || !qrModalUrl || !(qrModalImg instanceof HTMLImageElement)) return;
      qrModalUrl.textContent = url;
      qrModalImg.alt = `QR：${url}`;
      qrModalImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=240x240&margin=10&data=${encodeURIComponent(url)}`;
      qrModal.hidden = false;
      qrModal.setAttribute('aria-hidden', 'false');
      try {
        applyBodyScrollLock();
      } catch {}
    }
    function closeQrModal() {
      if (!(qrModal instanceof HTMLElement)) return;
      qrModal.hidden = true;
      qrModal.setAttribute('aria-hidden', 'true');
      if (qrModalImg instanceof HTMLImageElement) {
        qrModalImg.removeAttribute('src');
        qrModalImg.alt = '';
      }
      try {
        releaseBodyScrollLock();
      } catch {}
    }

    async function getQrImageBlob() {
      if (!(qrModalImg instanceof HTMLImageElement) || !qrModalImg.src) return null;
      try {
        const res = await fetch(qrModalImg.src, { mode: 'cors' });
        if (!res.ok) return null;
        return await res.blob();
      } catch {
        return null;
      }
    }

    function suggestQrFilename() {
      const publicUrl = qrModalUrl?.textContent?.trim() ?? '';
      if (!publicUrl) return `boaquarium-qrcode-${Date.now()}.png`;
      try {
        const u = new URL(publicUrl);
        const parts = u.pathname.split('/').filter(Boolean);
        const last = parts[parts.length - 1] || 'qrcode';
        const safe = String(last).replace(/[^a-zA-Z0-9\u4e00-\u9fff-_]/g, '_').slice(0, 48);
        return `boaquarium-qrcode-${safe || 'link'}.png`;
      } catch {
        return `boaquarium-qrcode-${Date.now()}.png`;
      }
    }

    async function saveQrPhoto() {
      const fn = suggestQrFilename();
      const blob = await getQrImageBlob();
      if (blob && blob.size > 0) {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fn;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        setStatus('已下載 QR 圖');
        return;
      }
      const src = qrModalImg instanceof HTMLImageElement ? qrModalImg.src : '';
      if (!src) {
        setStatus('無 QR 圖可下載');
        return;
      }
      const a = document.createElement('a');
      a.href = src;
      a.download = fn;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      a.remove();
      setStatus('已觸發下載（若未儲存請在新分頁長按圖片另存）');
    }

    function isAbortError(err) {
      return (
        (err instanceof DOMException && err.name === 'AbortError') ||
        (err != null && typeof err === 'object' && 'name' in err && err.name === 'AbortError')
      );
    }

    async function shareQrContent() {
      const url = qrModalUrl?.textContent?.trim() ?? '';
      if (!url) {
        setStatus('沒有可分享的網址');
        return;
      }
      const title = '水博館｜前台連結';
      const sharePayload = { title, text: url, url };
      if (!navigator.share) {
        try {
          await navigator.clipboard.writeText(url);
          setStatus('已複製網址到剪貼簿');
        } catch {
          setStatus('無法複製，請手動複製上方網址');
        }
        return;
      }
      const blob = await getQrImageBlob();
      if (blob && blob.size > 0) {
        const fn = suggestQrFilename();
        const mime = blob.type && blob.type.startsWith('image/') ? blob.type : 'image/png';
        const file = new File([blob], fn, { type: mime });
        if (navigator.canShare?.({ files: [file] })) {
          try {
            await navigator.share({ ...sharePayload, files: [file] });
            return;
          } catch (e) {
            if (isAbortError(e)) return;
          }
        }
      }
      try {
        await navigator.share(sharePayload);
      } catch (e) {
        if (isAbortError(e)) return;
        try {
          await navigator.clipboard.writeText(url);
          setStatus('已複製網址到剪貼簿（分享不可用）');
        } catch {
          setStatus('分享失敗，請複製上方網址');
        }
      }
    }

    const TOKEN_KEY = 'adminx_strapi_token';
    const readToken = () => {
      try {
        return String(localStorage.getItem(TOKEN_KEY) ?? '').trim();
      } catch {
        return '';
      }
    };
    const writeToken = (token) => {
      try {
        if (!token) localStorage.removeItem(TOKEN_KEY);
        else localStorage.setItem(TOKEN_KEY, token);
      } catch {}
    };
    const authHeaders = () => {
      const t = readToken();
      return t ? { 'x-admin-token': t } : {};
    };

    const labelOf = (model, field) => {
      // 後台精簡：商品主圖欄位統一顯示「圖片」
      if (model === 'product' && field === 'image') return '圖片';
      return schemas[model]?.config?.metadatas?.[field]?.edit?.label ?? field;
    };
    const kOf = (row) => String(row.documentId ?? row.id ?? '');
    /** 與分類下拉 option.value 一致（documentId 優先，相容 Strapi populate / Sanity） */
    function productCategoryId(row) {
      const c = row?.category;
      if (c == null || typeof c !== 'object') return '';
      const raw =
        c.documentId ??
        c.id ??
        c?.data?.documentId ??
        c?.data?.id ??
        c?._id ??
        '';
      return String(raw ?? '').trim();
    }
    /**
     * 在各分類「出現槽位」不變下，依 sortOrder、名稱重排該分類內商品（用於載入後與後端一致）。
     */
    function applySortOrderWithinEachCategory(entries) {
      const titleKey = defs.product.title;
      const catKey = (row) => productCategoryId(row) || '__none';
      const buckets = new Map();
      for (const row of entries) {
        const k = catKey(row);
        if (!buckets.has(k)) buckets.set(k, []);
        buckets.get(k).push(row);
      }
      for (const [, rows] of buckets) {
        rows.sort((a, b) => {
          const sa = Number.isFinite(Number(a.sortOrder)) ? Number(a.sortOrder) : 999999;
          const sb = Number.isFinite(Number(b.sortOrder)) ? Number(b.sortOrder) : 999999;
          if (sa !== sb) return sa - sb;
          return String(a[titleKey] ?? '').localeCompare(String(b[titleKey] ?? ''), 'zh-Hant');
        });
      }
      const ptr = new Map();
      for (const k of buckets.keys()) ptr.set(k, 0);
      return entries.map((row) => {
        const k = catKey(row);
        const arr = buckets.get(k);
        const i = ptr.get(k);
        ptr.set(k, i + 1);
        return arr[i];
      });
    }
    const norm = (json) => Array.isArray(json?.data) ? json.data.map((x) => ({ ...(x.attributes ?? {}), ...x, id: x.id, documentId: x.documentId })) : [];
    /** POST/PUT 單筆回傳 { data: {...} } → 與 norm 列項目同形 */
    function normOne(json) {
      const x = json?.data;
      if (x == null) return null;
      if (Array.isArray(x)) {
        const first = x[0];
        if (!first) return null;
        return { ...(first.attributes ?? {}), ...first, id: first.id, documentId: first.documentId };
      }
      return { ...(x.attributes ?? {}), ...x, id: x.id, documentId: x.documentId };
    }
    /** Strapi categories API 回傳列，依 orderRank（數字 1,2,3…）排序，供篩選與表單下拉一致 */
    function sortCategoriesByOrderRank(raw) {
      if (!Array.isArray(raw)) return [];
      return [...raw].sort((a, b) => {
        const ra = Number(String(a.attributes?.orderRank ?? a.orderRank ?? '').trim());
        const rb = Number(String(b.attributes?.orderRank ?? b.orderRank ?? '').trim());
        const na = Number.isFinite(ra) ? ra : 999999;
        const nb = Number.isFinite(rb) ? rb : 999999;
        if (na !== nb) return na - nb;
        const nameA = String(a.attributes?.name ?? a.name ?? '');
        const nameB = String(b.attributes?.name ?? b.name ?? '');
        return nameA.localeCompare(nameB, 'zh-Hant');
      });
    }

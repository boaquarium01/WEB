---
import Layout from '../../layouts/Layout.astro';
import SanityImage from '../../components/SanityImage.astro';
import { getPromotionBySlug } from '../../data/promotions';
import type { SanityImageSource } from '@sanity/image-url/lib/types/types';
import { buildDefaultSrc } from '../../lib/sanity/image';

function isStrapiPromoImg(img: unknown): boolean {
  return Boolean(
    img &&
      typeof img === 'object' &&
      'url' in img &&
      typeof (img as { url?: unknown }).url === 'string' &&
      String((img as { url: string }).url).trim() !== ''
  );
}

function promoImageFullSrc(img: unknown, width: number): string {
  if (img && typeof img === 'object' && 'url' in img) {
    const u = (img as { url?: unknown }).url;
    if (typeof u === 'string' && u.trim()) return u.trim();
  }
  return (
    buildDefaultSrc(img as SanityImageSource, width) ||
    buildDefaultSrc(img as SanityImageSource, Math.min(width, 1200)) ||
    buildDefaultSrc(img as SanityImageSource, 800) ||
    buildDefaultSrc(img as SanityImageSource, 600) ||
    ''
  );
}

// 促銷頁圖片排序需即時反映 Sanity 拖曳順序，避免被建置時快取住
export const prerender = false;

Astro.response.headers.set('Cache-Control', 'private, no-store, max-age=0, must-revalidate');

const BRAND_SUFFIX = '水博館水族館';
const PROMO_TABS = [
  { slug: 'weekly-new', label: '每週新進魚隻🐠' },
  { slug: 'special-offers', label: '預定優惠' },
  { slug: 'equipment-sale', label: '器材促銷' }
] as const;

const slug = String(Astro.params.slug ?? '').trim();
const promo = await getPromotionBySlug(slug);
if (!promo) return Astro.redirect('/');

const contentText = String(promo.content ?? '').trim();
const pageTitle = `${promo.title}｜${BRAND_SUFFIX}`;
const description = contentText ? contentText.slice(0, 160) : `${promo.title} 最新資訊與圖片。`;
const tabs = PROMO_TABS.filter((tab) => tab.slug !== slug);
const promoImages = promo.promoImages.slice(0, 25).map((img) => ({
  source: img,
  fullSrc:
    promoImageFullSrc(img, 1600) ||
    promoImageFullSrc(img, 1200) ||
    promoImageFullSrc(img, 800) ||
    promoImageFullSrc(img, 600) ||
    ''
}));
const heroImageSrc = promoImages[0]?.fullSrc || '';
const heroImageAbs = heroImageSrc ? new URL(heroImageSrc, Astro.url.origin).toString() : '';
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: promo.title,
  description,
  url: Astro.url.href,
  inLanguage: 'zh-Hant',
  ...(heroImageAbs ? { image: [heroImageAbs] } : {})
};
---

<Layout title={pageTitle} description={description}>
  <Fragment slot="head">
    {heroImageSrc ? <link rel="preload" as="image" href={heroImageSrc} /> : null}
    <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)}></script>
  </Fragment>
  <div id="promoPageRoot" class="min-h-screen bg-white text-slate-900">
    <header class="site-header sticky top-0 z-[100] border-b border-white/20 bg-white/75 shadow-[0_8px_30px_rgba(0,0,0,0.06)] backdrop-blur-xl backdrop-saturate-150 reveal-on-scroll">
      <div class="mx-auto grid min-h-[56px] w-full max-w-[1200px] grid-cols-[auto_1fr_auto] items-center gap-3 px-4 py-3">
        <a href="/" class="aq-btn-soft aq-hover-lift inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-900 transition" aria-label="首頁"><i class="fa-solid fa-house"></i></a>
        <a href="/" class="justify-self-center text-[1.0625rem] font-extrabold tracking-[0.04em] text-slate-900">水博館水族</a>
        <a href="https://lin.ee/nG8kcR2" target="_blank" rel="noopener noreferrer" class="group inline-flex min-h-[36px] items-center gap-1.5 rounded-full bg-white px-3.5 py-2 text-xs font-extrabold !text-[#06c755] shadow-[0_8px_20px_rgba(6,199,85,0.22),0_2px_0_rgba(6,199,85,0.2)] ring-1 ring-[#06c755]/35 transition duration-200 hover:-translate-y-0.5 hover:bg-[#06c755] hover:!text-white hover:shadow-[0_12px_26px_rgba(6,199,85,0.34)] active:translate-y-0 active:shadow-[0_4px_12px_rgba(6,199,85,0.28)]">
          <i class="fa-brands fa-line text-sm !text-[#06c755] opacity-95 transition group-hover:!text-white" aria-hidden="true"></i>
          LINE 諮詢預訂
        </a>
      </div>
      <div class="mx-auto w-full max-w-5xl px-4 pb-3 sm:px-6">
        <nav class="grid grid-cols-2 gap-2" aria-label="促銷分頁切換">
          {tabs.map((tab) => (
            <a href={`/promo/${tab.slug}`} class="aq-btn-soft aq-hover-lift rounded-xl border border-slate-200 bg-white px-3 py-2 text-center text-sm font-semibold text-slate-700 transition">{tab.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl px-4 py-6 sm:px-6 sm:py-8">
      <h1 class="reveal-on-scroll reveal-on-scroll--delay-sm text-center text-balance text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl">{promo.title}</h1>

      {contentText ? (
        <section class="reveal-on-scroll reveal-on-scroll--delay-md prose prose-slate mt-6 max-w-none">
          <p class="whitespace-pre-line leading-relaxed text-slate-700">{contentText}</p>
        </section>
      ) : null}

      {promoImages.length > 0 ? (
        <section class="reveal-on-scroll reveal-on-scroll--delay-md mt-8">
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {promoImages.map(({ source, fullSrc }, i) => (
              <button
                type="button"
                class="group block w-full text-left"
                data-promo-lightbox-trigger
                data-index={String(i)}
                data-src={fullSrc}
                data-alt={`${promo.title}（第 ${i + 1} 張）`}
                aria-label={`放大檢視第 ${i + 1} 張圖片`}
              >
                <div class="promo-thumb relative isolate aspect-square w-full overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 shadow-sm">
                  {isStrapiPromoImg(source) ? (
                    <img
                      src={fullSrc}
                      alt={`${promo.title}（第 ${i + 1} 張）`}
                      width={900}
                      height={900}
                      loading={i === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                      class="h-full w-full object-cover object-center"
                    />
                  ) : (
                    <SanityImage
                      source={source as SanityImageSource}
                      alt={`${promo.title}（第 ${i + 1} 張）`}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                      width={900}
                      height={900}
                      priority={i === 0}
                      fit="cover"
                      class="h-full w-full"
                    />
                  )}
                </div>
              </button>
            ))}
          </div>
        </section>
      ) : (
        <section class="reveal-on-scroll reveal-on-scroll--delay-md mt-8">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 text-center shadow-sm">
            <p class="text-sm font-semibold text-slate-700">此分頁暫無促銷圖片</p>
            <p class="mt-1 text-xs text-slate-500">可先透過 LINE 詢問最新上架與優惠資訊</p>
          </div>
        </section>
      )}
    </main>

    <footer class="reveal-on-scroll reveal-on-scroll--delay-lg border-t border-[var(--aq-line)] bg-inherit px-4 py-8 sm:px-6">
      <div class="mx-auto flex w-full max-w-5xl flex-col items-center justify-center gap-2 text-center">
        <a href="/#about" class="text-sm font-semibold text-[var(--aq-primary-dark)] underline decoration-[1.5px] underline-offset-4 transition hover:text-[var(--aq-primary)]">聯絡資訊</a>
        <p class="m-0 text-xs tracking-[0.02em] text-[var(--aq-muted)]">© 2026 水博館水族</p>
      </div>
    </footer>

    <div
      id="promoLightbox"
      class="promo-lightbox"
      hidden
      role="dialog"
      aria-modal="true"
      aria-label="放大檢視促銷圖片"
    >
      <button type="button" id="promoLbBackdrop" class="promo-lightbox__backdrop" aria-label="關閉放大圖"></button>
      <button type="button" id="promoLbClose" class="promo-lightbox__close" aria-label="關閉">
        <i class="fa-solid fa-xmark text-lg" aria-hidden="true"></i>
      </button>
      <button
        type="button"
        id="promoLbPrev"
        class="promo-lightbox__nav promo-lightbox__nav--prev"
        aria-label="上一張"
        hidden
      >
        <i class="fa-solid fa-chevron-left text-xl" aria-hidden="true"></i>
      </button>
      <button
        type="button"
        id="promoLbNext"
        class="promo-lightbox__nav promo-lightbox__nav--next"
        aria-label="下一張"
        hidden
      >
        <i class="fa-solid fa-chevron-right text-xl" aria-hidden="true"></i>
      </button>
      <div id="promoLbShell" class="promo-lightbox__shell">
        <img id="promoLbImg" class="promo-lightbox__img" alt="" decoding="async" />
      </div>
      <p id="promoLbCounter" class="promo-lightbox__counter" aria-live="polite" hidden></p>
    </div>

    <button
      id="promoScrollTopBtn"
      type="button"
      class="promo-scroll-top-btn"
      aria-label="回到頁面頂部"
      title="回到頂部"
    >
      <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
    </button>

    <script>
      import { mountPromoPage } from '../../scripts/promoPage';
      mountPromoPage();
    </script>
  </div>
</Layout>

<style>
  /* 子元件根節點／內層 img 須 :global 才會套上（Astro scoped） */
  .promo-thumb :global(> *) {
    display: block;
    min-height: 0;
    height: 100%;
    width: 100%;
  }

  .promo-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .promo-scroll-top-btn {
    position: fixed;
    right: 18px;
    bottom: calc(84px + env(safe-area-inset-bottom, 0px));
    z-index: 9998;
    width: 46px;
    height: 46px;
    border: 0;
    border-radius: 999px;
    background: #ffffff;
    color: #156a66;
    box-shadow:
      0 10px 24px rgba(0, 0, 0, 0.18),
      0 2px 0 rgba(21, 106, 102, 0.18);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .promo-scroll-top-btn.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .promo-scroll-top-btn:hover {
    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.24),
      0 2px 0 rgba(21, 106, 102, 0.22);
  }

  .promo-scroll-top-btn:active {
    transform: translateY(1px);
  }

  .aq-btn-soft {
    box-shadow:
      0 6px 16px rgba(15, 23, 42, 0.08),
      0 1px 0 rgba(15, 23, 42, 0.08);
  }

  .aq-btn-soft:hover {
    border-color: rgba(148, 163, 184, 0.55);
    background: #f8fafc;
    box-shadow:
      0 10px 20px rgba(15, 23, 42, 0.12),
      0 1px 0 rgba(15, 23, 42, 0.12);
  }

  .aq-btn-soft:active {
    transform: translateY(1px);
    box-shadow:
      0 4px 10px rgba(15, 23, 42, 0.12),
      0 1px 0 rgba(15, 23, 42, 0.1);
  }

  @media (max-width: 639px) {
    .promo-scroll-top-btn {
      right: 14px;
      bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    }
  }

  .promo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10050;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: max(12px, env(safe-area-inset-top)) max(12px, env(safe-area-inset-right))
      max(12px, env(safe-area-inset-bottom)) max(12px, env(safe-area-inset-left));
    box-sizing: border-box;
  }

  .promo-lightbox[hidden] {
    display: none !important;
  }

  .promo-lightbox:not([hidden]) {
    animation: promo-lb-fade-in 0.22s ease-out;
  }

  @keyframes promo-lb-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .promo-lightbox__backdrop {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(0, 0, 0, 0.82);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .promo-lightbox__close {
    position: absolute;
    top: max(10px, env(safe-area-inset-top, 0px));
    right: max(10px, env(safe-area-inset-right, 0px));
    z-index: 2;
    display: inline-flex;
    width: 46px;
    height: 46px;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    color: #0f172a;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .promo-lightbox__close:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
  }

  .promo-lightbox__close:active {
    transform: scale(0.96);
  }

  .promo-lightbox__nav {
    position: absolute;
    top: 50%;
    z-index: 3;
    display: none;
    width: min(20vw, 160px);
    height: min(72vh, 560px);
    max-height: calc(100% - 120px);
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.92);
    cursor: pointer;
    transform: translateY(-50%);
    transition: background 0.18s ease, color 0.18s ease;
    -webkit-tap-highlight-color: transparent;
  }

  @media (pointer: fine) {
    .promo-lightbox__nav:not([hidden]) {
      display: inline-flex;
    }
  }

  .promo-lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  .promo-lightbox__nav:active {
    background: rgba(255, 255, 255, 0.1);
  }

  .promo-lightbox__nav:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.85);
    outline-offset: 3px;
  }

  .promo-lightbox__nav--prev {
    left: max(10px, env(safe-area-inset-left, 0px));
  }

  .promo-lightbox__nav--next {
    right: max(10px, env(safe-area-inset-right, 0px));
  }

  .promo-lightbox__shell {
    position: relative;
    z-index: 1;
    max-width: min(96vw, 1200px);
    max-height: min(88vh, 900px);
    margin: 0;
    touch-action: none;
    cursor: grab;
  }

  .promo-lightbox__shell:active,
  .promo-lightbox__shell.is-dragging {
    cursor: grabbing;
  }

  @media (pointer: fine) {
    .promo-lightbox__shell {
      cursor: default;
      touch-action: auto;
    }

    .promo-lightbox__shell:active,
    .promo-lightbox__shell.is-dragging {
      cursor: default;
    }
  }

  .promo-lightbox__shell.is-dragging .promo-lightbox__img {
    will-change: transform, opacity;
  }

  .promo-lightbox__counter {
    position: absolute;
    left: 50%;
    bottom: max(8px, env(safe-area-inset-bottom, 0px));
    z-index: 4;
    margin: 0;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(15, 23, 42, 0.72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transform: translateX(-50%);
    pointer-events: none;
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .promo-lightbox__counter[hidden] {
    display: none !important;
  }

  .promo-lightbox__img {
    display: block;
    max-width: 100%;
    max-height: min(88vh, 900px);
    width: auto;
    height: auto;
    object-fit: contain;
    pointer-events: auto;
    border-radius: 6px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.45);
    user-select: none;
    transform-origin: center center;
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-lightbox:not([hidden]) {
      animation: none;
    }
  }
</style>

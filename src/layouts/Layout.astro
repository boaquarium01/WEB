---
import '../styles/global.css';
import { SITE_TITLE as defaultTitle, SITE_DESCRIPTION as defaultDescription } from '../config/site';

const {
  title = defaultTitle,
  description = defaultDescription,
  keywords,
  ogImage,
  ogType = 'website'
} = Astro.props;

const pageUrl = Astro.url.href;
const keywordsContent = Array.isArray(keywords) ? keywords.join(', ') : typeof keywords === 'string' ? keywords : '';
const twitterCard = ogImage ? 'summary_large_image' : 'summary';
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="水博館水族" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{keywordsContent ? <meta name="keywords" content={keywordsContent} /> : null}
		<title>{title}</title>
		<link rel="canonical" href={pageUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:locale" content="zh_TW" />
		{ogImage ? (
			<>
				<meta property="og:image" content={ogImage} />
				<meta property="og:image:alt" content={title} />
				<meta name="twitter:image" content={ogImage} />
			</>
		) : null}
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
			crossorigin="anonymous"
			referrerpolicy="no-referrer"
		/>
		<slot name="head" />
	</head>
	<body>
		<slot />
		<a
			class="line-float"
			href="https://lin.ee/nG8kcR2"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="使用 LINE 私訊聯絡（另開新視窗）"
		>
			<img class="line-float__icon" src="/line.png" alt="LINE" width="56" height="56" loading="lazy" />
		</a>

		<script>
			import { initScrollReveal } from '../scripts/initScrollReveal';

			const runReveal = () => initScrollReveal();
			runReveal();
			document.addEventListener('astro:page-load', runReveal);
		</script>
	</body>
</html>

<style is:global>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: var(--aq-sand, #faf8f4);
		color: var(--aq-ink, #1a2221);
		font-family: system-ui, -apple-system, 'Segoe UI', 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		max-width: 100%;
		height: auto;
		display: block;
	}

	.line-float {
		position: fixed;
		right: 18px;
		bottom: calc(18px + env(safe-area-inset-bottom, 0px));
		z-index: 9999;
		width: 56px;
		height: 56px;
		border-radius: 999px;
		background: #06c755;
		color: inherit;
		display: block;
		text-decoration: none;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.22);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.line-float:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.22);
	}

	/* 來源圖周圍為淺灰留白：放大裁切後只保留中央綠方塊＋對話框；外圈仍為 LINE 綠 */
	.line-float__icon {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
		object-position: center;
		border-radius: 999px;
		display: block;
		transform: scale(1.8);
		transform-origin: center center;
	}

	@media (max-width: 639px) {
		.line-float {
			right: 14px;
			bottom: calc(14px + env(safe-area-inset-bottom, 0px));
			/* 與桌機同尺寸，避免與 scale 疊加後視覺比例不一致 */
			width: 56px;
			height: 56px;
		}
	}
</style>

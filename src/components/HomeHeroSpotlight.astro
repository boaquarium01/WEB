---
export type HeroSpotlightItem = {
  slug: string;
  name: string;
  excerpt: string;
  /** 後台仍可有分類資料，畫面不顯示 */
  categoryLabel?: string;
  imageUrl?: string | null;
};

type Props = {
  items: HeroSpotlightItem[];
};

const { items } = Astro.props as Props;
const n = items.length;
---

<!-- 外層為 index 內與 #services、#about 相同的 section；標題與服務區同一模式 -->
<div class="spotlight">
  <h2 id="hero-spotlight-heading" class="home-section-title reveal-on-scroll">主打商品</h2>

  <div class="spotlight__content reveal-stagger">
  {
    n === 1 ? (
      <div class="spotlight__solo">
        {items.map((p) => (
          <a href={`/product/${p.slug}`} class="spotlight__hit spotlight__hit--solo">
            <figure class="spotlight__figure spotlight__figure--solo">
              {p.imageUrl ? (
                <img
                  src={p.imageUrl}
                  alt=""
                  width={960}
                  height={640}
                  loading="eager"
                  decoding="async"
                  class="spotlight__img"
                />
              ) : (
                <div class="spotlight__placeholder" aria-hidden="true">
                  <i class="fa-solid fa-fish-fins" />
                </div>
              )}
            </figure>
            <div class="spotlight__copy spotlight__copy--solo">
              <h3 class="spotlight__name">{p.name}</h3>
              <p class="spotlight__excerpt">{p.excerpt}</p>
              <span class="spotlight__linkline">
                進一步了解
                <span class="spotlight__linkline-mark" aria-hidden="true" />
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : n === 2 ? (
      <div class="spotlight__duo">
        {items.map((p, i) => (
          <a href={`/product/${p.slug}`} class="spotlight__hit spotlight__hit--half">
            <figure class="spotlight__figure spotlight__figure--half">
              {p.imageUrl ? (
                <img
                  src={p.imageUrl}
                  alt=""
                  width={720}
                  height={480}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="spotlight__img"
                />
              ) : (
                <div class="spotlight__placeholder" aria-hidden="true">
                  <i class="fa-solid fa-fish-fins" />
                </div>
              )}
            </figure>
            <div class="spotlight__copy">
              <h3 class="spotlight__name">{p.name}</h3>
              <p class="spotlight__excerpt">{p.excerpt}</p>
              <span class="spotlight__linkline">
                進一步了解
                <span class="spotlight__linkline-mark" aria-hidden="true" />
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="spotlight__trio">
        <a href={`/product/${items[0].slug}`} class="spotlight__hit spotlight__hit--lead">
          <figure class="spotlight__figure spotlight__figure--lead">
            {items[0].imageUrl ? (
              <img
                src={items[0].imageUrl}
                alt=""
                width={960}
                height={640}
                loading="eager"
                decoding="async"
                class="spotlight__img"
              />
            ) : (
              <div class="spotlight__placeholder" aria-hidden="true">
                <i class="fa-solid fa-fish-fins" />
              </div>
            )}
          </figure>
          <div class="spotlight__copy spotlight__copy--lead">
            <h3 class="spotlight__name spotlight__name--lead">{items[0].name}</h3>
            <p class="spotlight__excerpt">{items[0].excerpt}</p>
            <span class="spotlight__linkline">
              進一步了解
              <span class="spotlight__linkline-mark" aria-hidden="true" />
            </span>
          </div>
        </a>
        <div class="spotlight__rail" role="list">
          {items.slice(1, 3).map((p) => (
            <a href={`/product/${p.slug}`} class="spotlight__hit spotlight__hit--rail" role="listitem">
              <figure class="spotlight__figure spotlight__figure--rail">
                {p.imageUrl ? (
                  <img
                    src={p.imageUrl}
                    alt=""
                    width={320}
                    height={240}
                    loading="lazy"
                    decoding="async"
                    class="spotlight__img"
                  />
                ) : (
                  <div class="spotlight__placeholder spotlight__placeholder--sm" aria-hidden="true">
                    <i class="fa-solid fa-fish-fins" />
                  </div>
                )}
              </figure>
              <div class="spotlight__copy spotlight__copy--rail">
                <h3 class="spotlight__name">{p.name}</h3>
                <p class="spotlight__excerpt spotlight__excerpt--rail">{p.excerpt}</p>
                <span class="spotlight__linkline spotlight__linkline--rail">
                  進一步了解
                  <span class="spotlight__linkline-mark" aria-hidden="true" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )
  }
  </div>
</div>

<style>
  /**
   * 與全站 wrap（1200px）、熱銷 4:3 卡片尺度對齊：圖區用固定高度區間 + cover，
   * 避免桌面主圖等高於一列商品卡太多、手機也不會直向佔滿螢幕。
   */
  .spotlight {
    --spotlight-figure-h-xs: clamp(8.5rem, 30vw, 11rem);
    --spotlight-figure-h-sm: clamp(9rem, 18vw, 12.25rem);
    --spotlight-figure-h-md: clamp(9.25rem, 16vw, 13rem);
    /* 一主兩副：主圖高度上限略低，避免區塊過大（仍左大右小） */
    --spotlight-lead-h: clamp(7.75rem, 20vw, 10.5rem);
    --spotlight-lead-h-lg: clamp(8.5rem, 17vw, 11.25rem);
    /* 區塊上距由 .home-below-hero .home-section:first-child 負責 */
    padding-top: 0;
    padding-bottom: clamp(0.65rem, 2vw, 1.15rem);
    margin-top: 0;
  }

  /* 與 .services-grid 同寬；標題與商品網格之間略留氣 */
  .spotlight__content {
    width: 100%;
    max-width: 100%;
    margin-inline: 0;
    margin-top: clamp(0.2rem, 1.2vw, 0.45rem);
    box-sizing: border-box;
  }

  .spotlight__hit {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    transition: color 0.2s ease;
  }

  .spotlight__hit:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--aq-primary) 65%, transparent);
    outline-offset: 4px;
  }

  /* 展陳感：細框線＋極淡陰影，避免電商「浮卡」；漸層僅微調光感 */
  .spotlight__figure {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: var(--aq-radius);
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--aq-mist) 92%, var(--aq-sand-2)),
      color-mix(in srgb, var(--aq-sand-2) 88%, var(--aq-muted))
    );
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--aq-ink) 5%, transparent),
      0 1px 3px rgba(26, 34, 33, 0.05),
      0 6px 20px rgba(26, 34, 33, 0.04);
    transition: box-shadow 0.35s ease;
  }

  .spotlight__hit:hover .spotlight__figure {
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--aq-primary) 14%, transparent),
      0 2px 6px rgba(26, 34, 33, 0.06),
      0 10px 28px rgba(26, 34, 33, 0.05);
  }

  .spotlight__figure::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      118deg,
      rgba(255, 255, 255, 0.12) 0%,
      transparent 40%
    );
    opacity: 0.55;
  }

  .spotlight__figure::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--aq-ink) 14%, transparent) 0%,
      transparent 42%
    );
    opacity: 0.35;
    transition: opacity 0.4s ease;
  }

  .spotlight__hit:hover .spotlight__figure::after {
    opacity: 0.45;
  }

  .spotlight__figure--rail::after {
    opacity: 0.28;
  }

  .spotlight__img {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.001);
    transition:
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.45s ease;
    filter: saturate(1.01) contrast(1.01);
  }

  .spotlight__hit:hover .spotlight__img {
    transform: scale(1.018);
    filter: saturate(1.03) contrast(1.02);
  }

  @media (prefers-reduced-motion: reduce) {
    .spotlight__img {
      transition: none;
    }
    .spotlight__hit:hover .spotlight__img {
      transform: none;
      filter: saturate(1.01) contrast(1.01);
    }
  }

  .spotlight__placeholder {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      145deg,
      var(--aq-mist) 0%,
      color-mix(in srgb, var(--aq-primary-soft) 95%, var(--aq-sand-2)) 38%,
      color-mix(in srgb, var(--aq-sand-2) 85%, var(--aq-muted)) 100%
    );
    color: color-mix(in srgb, var(--aq-primary) 36%, transparent);
    font-size: clamp(1.35rem, 4vw, 1.85rem);
  }

  .spotlight__placeholder--sm {
    font-size: 1.1rem;
  }

  .spotlight__name {
    margin: 0 0 0.5rem;
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.4;
    color: var(--aq-ink);
    transition: color 0.2s ease;
  }

  .spotlight__hit:hover .spotlight__name {
    color: color-mix(in srgb, var(--aq-primary-dark) 88%, var(--aq-ink));
  }

  .spotlight__name--lead {
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    letter-spacing: 0.03em;
  }

  .spotlight__excerpt {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.72;
    color: var(--aq-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .spotlight__excerpt--rail {
    -webkit-line-clamp: 2;
    font-size: 0.8125rem;
    line-height: 1.55;
  }

  /* 編輯式文字連結，非按鈕／非「立即購買」語氣 */
  .spotlight__linkline {
    position: relative;
    display: inline-block;
    margin-top: 0.85rem;
    padding-bottom: 0.15rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--aq-primary) 82%, var(--aq-muted));
    transition: color 0.25s ease;
  }

  .spotlight__linkline-mark {
    display: block;
    height: 1px;
    margin-top: 0.35rem;
    transform-origin: left;
    transform: scaleX(0.35);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--aq-primary) 55%, transparent),
      transparent
    );
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .spotlight__hit:hover .spotlight__linkline {
    color: var(--aq-primary-dark);
  }

  .spotlight__hit:hover .spotlight__linkline-mark {
    transform: scaleX(1);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--aq-primary) 70%, transparent),
      transparent
    );
  }

  .spotlight__linkline--rail {
    margin-top: 0.45rem;
    font-size: 0.75rem;
  }

  /* —— 1 件：圖 + 文（寬度隨 wrap，圖高與熱銷單卡接近） —— */
  .spotlight__solo {
    width: 100%;
    max-width: 100%;
    margin-inline: auto;
  }

  .spotlight__hit--solo {
    display: grid;
    gap: clamp(1.15rem, 3vw, 1.85rem);
    align-items: center;
  }

  @media (min-width: 768px) {
    .spotlight__hit--solo {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }

  .spotlight__figure--solo {
    width: 100%;
    height: var(--spotlight-figure-h-xs);
  }

  @media (min-width: 768px) {
    .spotlight__figure--solo {
      height: var(--spotlight-figure-h-md);
    }
  }

  .spotlight__copy--solo {
    padding-block: 0.25rem;
  }

  /* —— 2 件：與 .services-grid 相同斷點（640+ 兩欄）與 gap —— */
  .spotlight__duo {
    display: grid;
    gap: clamp(1.1rem, 2.8vw, 1.45rem);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .spotlight__duo {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .spotlight__hit--half {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .spotlight__figure--half {
    width: 100%;
    height: var(--spotlight-figure-h-xs);
    margin-bottom: 0.85rem;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .spotlight__figure--half {
      height: var(--spotlight-figure-h-sm);
    }
  }

  /* —— 3 件：一主兩副（左大右小）；gap 與 .services-grid 一致 */
  .spotlight__trio {
    display: grid;
    gap: clamp(1.1rem, 2.8vw, 1.5rem);
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  @media (min-width: 900px) {
    .spotlight__trio {
      grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.88fr);
      gap: clamp(1.15rem, 2.8vw, 1.5rem);
      align-items: stretch;
    }
  }

  .spotlight__hit--lead {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .spotlight__figure--lead {
    width: 100%;
    height: var(--spotlight-lead-h);
    margin-bottom: 0.85rem;
    flex-shrink: 0;
  }

  @media (min-width: 900px) {
    .spotlight__figure--lead {
      height: var(--spotlight-lead-h-lg);
      margin-bottom: 0.85rem;
    }
  }

  .spotlight__copy--lead {
    padding-top: 0;
  }

  .spotlight__rail {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
    min-height: 0;
    /* 手機上以留白＋極淡線分隔主欄與副列，避免硬線 */
    border-top: 1px solid color-mix(in srgb, var(--aq-line) 42%, transparent);
    padding-top: clamp(0.65rem, 2vw, 0.85rem);
    margin-top: clamp(0.15rem, 0.8vw, 0.35rem);
  }

  @media (min-width: 900px) {
    .spotlight__rail {
      border-top: none;
      padding-top: 0;
      height: 100%;
      justify-content: flex-start;
      gap: 0.125rem;
    }
  }

  .spotlight__hit--rail {
    display: grid;
    grid-template-columns: minmax(3.75rem, 4.5rem) minmax(0, 1fr);
    gap: 0.65rem 0.8rem;
    align-items: center;
    padding-block: 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--aq-line) 38%, transparent);
    border-left: 2px solid transparent;
    transition:
      border-left-color 0.22s ease,
      background 0.22s ease;
  }

  .spotlight__hit--rail:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (min-width: 900px) {
    .spotlight__hit--rail:first-child {
      padding-top: 0;
    }
  }

  .spotlight__hit--rail:hover {
    background: color-mix(in srgb, var(--aq-sand-2) 48%, transparent);
    border-left-color: color-mix(in srgb, var(--aq-primary) 26%, transparent);
  }

  .spotlight__figure--rail {
    width: 100%;
    height: 3.75rem;
    max-width: 4.25rem;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .spotlight__figure--rail {
      height: 4rem;
      max-width: 4.5rem;
    }
  }

  .spotlight__copy--rail {
    padding: 0;
    min-width: 0;
  }

  .spotlight__hit--rail .spotlight__name {
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
  }

  @media (max-width: 399.98px) {
    .spotlight__hit--rail {
      grid-template-columns: 3.5rem minmax(0, 1fr);
      gap: 0.5rem;
    }
  }
</style>

---
import type { SanityImageSource } from '@sanity/image-url/lib/types/types';
import { buildSrcSet, buildLqipUrl, buildDefaultSrc, SANITY_IMAGE_WIDTHS } from '../lib/sanity/image';

type Props = {
  source: SanityImageSource | null | undefined;
  alt: string;
  sizes?: string;
  class?: string;
  imgClass?: string;
  priority?: boolean;
  width?: number;
  height?: number;
  /**
   * 輪播等已有「底層模糊圖」時設為 true，關閉 LQIP 背景，避免雙重模糊、主體看起來過小。
   */
  omitLqipBackground?: boolean;
  /**
   * LQIP 以 cover 填滿容器（預設 contain 在方形容器內會像中央一條／一塊，主圖載入後改 cover 會像由中往左右撐開）。
   */
  lqipCover?: boolean;
};

const {
  source,
  alt,
  sizes = '(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 400px',
  class: cls,
  imgClass,
  priority = false,
  width = 800,
  height = 600,
  omitLqipBackground = false,
  lqipCover = false
} = Astro.props as Props;

const srcSet = source ? buildSrcSet(source, SANITY_IMAGE_WIDTHS) : '';
const lqip = source ? buildLqipUrl(source) : null;
const src = source ? buildDefaultSrc(source, width) : null;
---

{
  src ? (
    <div
      class:list={[
        'relative min-h-0 min-w-0',
        omitLqipBackground ? 'bg-transparent h-full w-full overflow-visible' : 'overflow-hidden bg-slate-100',
        cls
      ]}
      style={
        lqip && !omitLqipBackground
          ? {
              backgroundImage: `url(${lqip})`,
              backgroundSize: lqipCover ? 'cover' : 'contain',
              backgroundPosition: 'center',
              backgroundRepeat: 'no-repeat'
            }
          : undefined
      }
    >
      <img
        src={src}
        srcset={srcSet || undefined}
        sizes={srcSet ? sizes : undefined}
        alt={alt}
        width={width}
        height={height}
        loading={priority ? 'eager' : 'lazy'}
        fetchpriority={priority ? 'high' : undefined}
        decoding="async"
        class:list={[
          omitLqipBackground
            ? 'opacity-100 carousel-slide__img--fill'
            : 'h-full w-full object-contain object-center transition-opacity duration-500 opacity-0',
          imgClass
        ]}
        onload={omitLqipBackground ? undefined : "this.classList.remove('opacity-0')"}
      />
    </div>
  ) : null
}
